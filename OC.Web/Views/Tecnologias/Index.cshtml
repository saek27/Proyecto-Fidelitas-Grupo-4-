@model IEnumerable<OC.Core.Domain.Entities.TecnologiaLente>
@{
    ViewData["Title"] = "Tecnologías de Lente";
}

<div class="container-fluid px-4">
    <div class="page-header animate-fade-up">
        <div class="page-header-text">
            <div class="page-header-icon"><i class="bi bi-eyedropper"></i></div>
            <div>
                <h1 class="page-title">Tecnologías de Lente</h1>
                <p class="page-subtitle">
                    <i class="bi bi-info-circle me-1"></i>
                    @(Model.Any() ? $"{Model.Count()} tecnología(s) en el catálogo." : "Sin tecnologías en el catálogo.")
                </p>
            </div>
        </div>
        <div class="page-actions">
            <a asp-action="Create" class="btn btn-brand">
                <i class="bi bi-plus-circle me-1"></i> Nueva tecnología
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show animate-fade-up mb-3" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card-dashboard animate-fade-up delay-1">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-eyedropper"></i></div>
                    <h5 class="empty-state-title">No hay tecnologías registradas</h5>
                    <p class="empty-state-text">Agrega la primera tecnología de lente.</p>
                    <a asp-action="Create" class="btn btn-brand">
                        <i class="bi bi-plus-circle me-1"></i> Agregar primera
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Nombre</th>
                                <th>Precio</th>
                                <th class="text-center" style="width:120px">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="entity-cell">
                                            <div class="entity-avatar bg-info-subtle text-info-emphasis">
                                                <i class="bi bi-eyedropper"></i>
                                            </div>
                                            <div class="fw-semibold">@item.Nombre</div>
                                        </div>
                                    </td>
                                    <td class="fw-semibold">@($"₡{item.Precio:N0}")</td>
                                    <td class="text-center">
                                        <div class="action-buttons">
                                            <a asp-action="Edit" asp-route-id="@item.Id"
                                               class="btn-action btn-action-primary" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                                  class="d-inline" onsubmit="return confirm('¿Eliminar esta tecnología?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn-action btn-action-danger" title="Eliminar">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Inventory" asp-action="Index" asp-route-seccion="productos" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i> Volver al inventario
        </a>
    </div>
</div>
