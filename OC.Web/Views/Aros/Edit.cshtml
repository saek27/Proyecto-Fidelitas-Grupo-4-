@model OC.Core.Domain.Entities.Aro
@{
    ViewData["Title"] = "Editar Aro";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card-dashboard animate-on-scroll" data-delay="0">
                <h4 class="mb-4"><i class="bi bi-eyeglasses me-2"></i> Editar Aro</h4>

                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Nombre" class="form-label fw-semibold">Nombre *</label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="SKU" class="form-label fw-semibold">SKU</label>
                            <input asp-for="SKU" class="form-control" readonly />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Precio" class="form-label fw-semibold">Precio (₡)</label>
                            <input asp-for="Precio" type="number" step="0.01" min="0" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Stock" class="form-label fw-semibold">Stock *</label>
                            <input asp-for="Stock" type="number" min="0" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3 d-flex align-items-center">
                            <div class="form-check mt-4">
                                <input class="form-check-input" type="checkbox" asp-for="Activo" />
                                <label class="form-check-label" asp-for="Activo">Activo</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Imagen del aro</label>
                        @if (!string.IsNullOrEmpty(Model.RutaImagen))
                        {
                            <div class="mb-2">
                                <img src="@Model.RutaImagen" alt="@Model.Nombre" class="rounded border"
                                     style="max-height:100px; max-width:100px; object-fit:contain" />
                            </div>
                        }
                        <input type="file" name="imagenAro" class="form-control" accept=".jpg,.jpeg,.png,.gif,.webp" />
                        <div class="form-text">Deje vacío para conservar la imagen actual.</div>
                    </div>

                    <div class="form-footer-actions">
                        <div class="btn-group" role="group">
                            <button type="submit" class="btn btn-brand btn-ripple">
                                <i class="bi bi-check-lg me-2"></i> Guardar cambios
                            </button>
                            <a asp-controller="Inventory" asp-action="Index" asp-route-seccion="aros" class="btn btn-outline-secondary btn-ripple">
                                <i class="bi bi-x-lg me-2"></i> Cancelar
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        anime({ targets: '.animate-on-scroll', opacity: [0,1], translateY: [15,0], duration: 500, easing: 'easeOutQuad' });
    </script>
}