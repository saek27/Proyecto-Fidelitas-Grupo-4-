@model IEnumerable<OC.Core.Domain.Entities.Aro>
@{
    ViewData["Title"] = "Aros";
}

<div class="container-fluid px-4">
    <div class="page-header animate-fade-up">
        <div class="page-header-text">
            <div class="page-header-icon"><i class="bi bi-eyeglasses"></i></div>
            <div>
                <h1 class="page-title">Aros</h1>
                <p class="page-subtitle">
                    <i class="bi bi-info-circle me-1"></i>
                    @(Model.Any() ? $"{Model.Count()} aro(s) en el catálogo." : "Sin aros en el catálogo.")
                </p>
            </div>
        </div>
        <div class="page-actions">
            <a asp-action="Create" class="btn btn-brand">
                <i class="bi bi-plus-circle me-1"></i> Nuevo aro
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show animate-fade-up mb-3" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card-dashboard animate-fade-up delay-1">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-eyeglasses"></i></div>
                    <h5 class="empty-state-title">No hay aros registrados</h5>
                    <p class="empty-state-text">Empieza agregando el primer aro al catálogo.</p>
                    <a asp-action="Create" class="btn btn-brand">
                        <i class="bi bi-plus-circle me-1"></i> Agregar primero
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:72px">Imagen</th>
                                <th>Nombre</th>
                                <th>SKU</th>
                                <th>Precio</th>
                                <th>Stock</th>
                                <th class="text-center" style="width:120px">Estado</th>
                                <th class="text-center" style="width:140px">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(item.RutaImagen))
                                        {
                                            <img src="@item.RutaImagen" alt=""
                                                 class="rounded border" style="height:48px;width:48px;object-fit:contain" />
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="entity-cell">
                                            <div class="entity-avatar bg-info-subtle text-info-emphasis">
                                                <i class="bi bi-eyeglasses"></i>
                                            </div>
                                            <div class="fw-semibold">@item.Nombre</div>
                                        </div>
                                    </td>
                                    <td><code class="text-muted small">@item.SKU</code></td>
                                    <td class="fw-semibold">@($"₡{item.Precio:N0}")</td>
                                    <td class="@(item.Stock < 6 ? "text-danger fw-bold" : "")">@item.Stock</td>
                                    <td class="text-center">
                                        @if (item.Activo)
                                        {
                                            <span class="status-badge status-badge-active">
                                                <i class="bi bi-check-circle-fill"></i> Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-badge-inactive">
                                                <i class="bi bi-pause-circle-fill"></i> Inactivo
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="action-buttons">
                                            <a asp-action="Edit" asp-route-id="@item.Id"
                                               class="btn-action btn-action-primary" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                                  class="d-inline" onsubmit="return confirm('¿Desactivar este aro?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn-action btn-action-danger" title="Desactivar">
                                                    <i class="bi bi-archive"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Inventory" asp-action="Index" asp-route-seccion="productos" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i> Volver al inventario
        </a>
    </div>
</div>
