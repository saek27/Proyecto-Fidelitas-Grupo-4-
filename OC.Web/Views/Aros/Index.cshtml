@model IEnumerable<OC.Core.Domain.Entities.Aro>
@{
    ViewData["Title"] = "Aros";
}

<div class="container-fluid px-4">
    <div class="d-flex flex-column flex-md-row gap-3 justify-content-md-between align-items-md-center mb-4">
        <h2 class="text-dark mb-0">
            <i class="bi bi-eyeglasses me-2"></i> Aros
        </h2>
        <div class="btn-toolbar page-header-toolbar mb-0 justify-content-md-end">
            <a asp-action="Create" class="btn btn-brand btn-ripple">
                <i class="bi bi-plus-circle me-2"></i> Nuevo aro
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card-dashboard animate-on-scroll" data-delay="0">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-circle text-muted" style="font-size:3rem"></i>
                    <p class="text-muted mt-3">No hay aros registrados.</p>
                    <a asp-action="Create" class="btn btn-brand"><i class="bi bi-plus-circle me-2"></i>Agregar primero</a>
                </div>
            }
            else
            {
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:64px">Imagen</th>
                            <th>Nombre</th>
                            <th>SKU</th>
                            <th>Precio</th>
                            <th>Stock</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(item.RutaImagen))
                                    {
                                        <img src="@item.RutaImagen" alt="" class="rounded border" style="height:48px;width:48px;object-fit:contain" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td><strong>@item.Nombre</strong></td>
                                <td>@item.SKU</td>
                                <td>₡@item.Precio.ToString("N2")</td>
                                <td class="@(item.Stock < 6 ? "text-danger fw-bold" : "")">@item.Stock</td>
                                <td>
                                    @if (item.Activo)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary"><i class="bi bi-x-circle"></i> Inactivo</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-toolbar justify-content-center">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary">
                                                <i class="bi bi-pencil"></i><span class="d-none d-xl-inline ms-1">Editar</span>
                                            </a>
                                        </div>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="ms-1"
                                              onsubmit="return confirm('¿Desactivar este aro?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i><span class="d-none d-xl-inline ms-1">Desactivar</span>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Inventory" asp-action="Index" asp-route-seccion="productos" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Volver al inventario
        </a>
    </div>
</div>

@section Scripts {
    <script>
        anime({ targets: '.animate-on-scroll', opacity: [0,1], translateY: [15,0], duration: 500, easing: 'easeOutQuad' });
    </script>
}