@model OC.Core.Common.PagedResult<OC.Core.Domain.Entities.Proveedor>

@{
    ViewData["Title"] = "Proveedores";
    var pagination = new PaginationInfo
    {
        CurrentPage = Model.PageIndex,
        TotalPages = Model.TotalPages,
        GetPageUrl = (page) => Url.Action("Index", new { page })
    };
}

<h2>Proveedores</h2>

<a asp-action="Create" class="btn btn-primary mb-3">
    Nuevo Proveedor
</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Numero</th>
            <th>Correo</th>
            <th>Estado</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.NumeroTelefonico</td>
                <td>@item.Correo</td>
                <td>
                    @(item.Activo ? "Activo" : "Inactivo")
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="ToggleStatus" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                        @(item.Activo ? "Desactivar" : "Activar")
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Items.Any())
{
    <div class="alert alert-info text-center m-3">
        No hay proveedores registrados.
        <a asp-action="Create" class="alert-link">Crear el primero</a>
    </div>
}

@await Html.PartialAsync("_Pagination", pagination)