@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Agendar Cita";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <h2 class="text-center mb-4">Agendar Cita</h2>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    <form method="post" id="formAgendarCita">
                        @Html.AntiForgeryToken()

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="sucursalId" class="form-label">Sede</label>
                                <select name="sucursalId" id="sucursalId" class="form-select" required>
                                    <option value="">Seleccione una sede</option>
                                    @if (ViewBag.SucursalesList != null)
                                    {
                                        foreach (var suc in ViewBag.SucursalesList)
                                        {
                                            <option value="@suc.Value">@suc.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="fecha" class="form-label">Fecha</label>
                                <input type="date" name="fecha" id="fecha" class="form-control" required min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="servicio" class="form-label">Servicio</label>
                            <select name="servicio" id="servicio" class="form-select" required>
                                <option value="">Seleccione un servicio</option>
                                @if (ViewBag.ServiciosList != null)
                                {
                                    foreach (var servicio in ViewBag.ServiciosList)
                                    {
                                        <option value="@servicio.Value">@servicio.Text</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3" id="bloqueHorario" style="display: none;">
                            <label class="d-block mb-2">Horario</label>
                            <p class="text-muted small mb-2">Elija un horario disponible para el día seleccionado:</p>
                            <input type="hidden" name="hora" id="hora" required />
                            <div id="slotsContainer" class="d-flex flex-wrap gap-2"></div>
                            <div id="slotsCargando" class="text-muted small" style="display: none;">Cargando horarios...</div>
                            <div id="slotsVacios" class="text-muted small" style="display: none;">No hay horarios disponibles para esta fecha en la sede elegida.</div>
                        </div>

                        <div class="mb-3">
                            <label for="motivo" class="form-label">Notas (opcional)</label>
                            <input type="text" name="motivo" id="motivo" class="form-control" placeholder="Ej: revisión de lentes" maxlength="500" />
                        </div>

                        <button type="submit" class="btn btn-primary w-100"><i class="bi bi-calendar-check"></i> Confirmar reserva</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            const $sucursal = $('#sucursalId');
            const $fecha = $('#fecha');
            const $bloqueHorario = $('#bloqueHorario');
            const $slotsContainer = $('#slotsContainer');
            const $slotsCargando = $('#slotsCargando');
            const $slotsVacios = $('#slotsVacios');
            const $hora = $('#hora');

            function cargarHorarios() {
                var sucursalId = $sucursal.val();
                var fecha = $fecha.val();
                if (!sucursalId || !fecha) {
                    $bloqueHorario.hide();
                    return;
                }

                $slotsContainer.empty();
                $bloqueHorario.show();
                $slotsCargando.show();
                $slotsVacios.hide();
                $hora.val('');

                $.get('@Url.Action("ObtenerHorasDisponibles", "Landing")', { sucursalId: sucursalId, fecha: fecha })
                    .done(function (data) {
                        $slotsCargando.hide();
                        if (data && data.length > 0) {
                            data.forEach(function (slot) {
                                var btn = $('<button type="button" class="btn btn-outline-primary slot-btn">' + slot + '</button>');
                                btn.click(function () {
                                    $('.slot-btn').removeClass('btn-primary').addClass('btn-outline-primary');
                                    $(this).removeClass('btn-outline-primary').addClass('btn-primary');
                                    $hora.val(slot);
                                });
                                $slotsContainer.append(btn);
                            });
                        } else {
                            $slotsVacios.show();
                        }
                    })
                    .fail(function () {
                        $slotsCargando.hide();
                        $slotsVacios.text('Error al cargar horarios. Intente más tarde.').show();
                    });
            }

            $sucursal.change(cargarHorarios);
            $fecha.change(cargarHorarios);

            $('#formAgendarCita').submit(function (e) {
                if (!$hora.val()) {
                    alert('Debe seleccionar un horario disponible.');
                    e.preventDefault();
                }
            });
        });
    </script>
}