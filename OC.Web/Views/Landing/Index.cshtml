@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Inicio - Óptica Comunal";
    var destacados = ViewBag.Destacados as IEnumerable<OC.Core.Domain.Entities.Producto>;
    var productosCarrusel = ViewBag.ProductosCarrusel as IEnumerable<OC.Core.Domain.Entities.Producto>;
}

<!-- CARRUSEL HERO -->
@if (productosCarrusel != null && productosCarrusel.Any())
{
    <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-indicators">
            @for (int i = 0; i < productosCarrusel.Count(); i++)
            {
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")" aria-label="Slide @(i + 1)"></button>
            }
        </div>
        <div class="carousel-inner">
            @foreach (var (prod, index) in productosCarrusel.Select((value, i) => (value, i)))
            {
                <div class="carousel-item @(index == 0 ? "active" : "")">
                    <div class="carousel-bg" style="background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('@(string.IsNullOrEmpty(prod.RutaImagen) ? "/images/default-product.jpg" : prod.RutaImagen)') center/cover;"></div>
                    <div class="carousel-caption d-flex flex-column justify-content-center h-100">
                        <h1 class="display-4 fw-bold">@prod.Nombre</h1>
                        <p class="lead">@prod.DescripcionCorta</p>
                        <p class="h3 text-warning">₡@prod.PrecioPublico.ToString("N2")</p>
                        <a href="/landing/detalle-producto/@prod.Id" class="btn btn-primary btn-lg mt-3">Ver detalles</a>
                    </div>
                </div>
            }
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Anterior</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Siguiente</span>
        </button>
    </div>
}
else
{
    <!-- Hero estático por si no hay productos -->
    <section class="hero py-5 text-center text-white" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('/images/hero-bg.jpg') center/cover; background-size: cover; min-height: 60vh;">
        <div class="container d-flex flex-column justify-content-center h-100">
            <h1 class="display-4 fw-bold">Tu visión, nuestra pasión</h1>
            <p class="lead">Los mejores lentes con tecnología de punta y atención personalizada.</p>
            <a href="/landing/catalogo" class="btn btn-primary btn-lg mt-3">Ver catálogo</a>
        </div>
    </section>
}

<!-- Productos Destacados -->
<section class="container my-5">
    <h2 class="text-center mb-4">Productos Destacados</h2>
    <div class="row g-4">
        @foreach (var prod in destacados)
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card product-card h-100 shadow-sm">
                    <img src="@(string.IsNullOrEmpty(prod.RutaImagen) ? "/images/default-product.jpg" : prod.RutaImagen)" class="card-img-top" alt="@prod.Nombre">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@prod.Nombre</h5>
                        <p class="card-text small">@prod.DescripcionCorta</p>
                        <p class="price text-primary fw-bold">₡@prod.PrecioPublico.ToString("N2")</p>
                        <a href="/landing/detalle-producto/@prod.Id" class="btn btn-outline-primary mt-auto">Ver más</a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>