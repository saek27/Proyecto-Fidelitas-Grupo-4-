@model IEnumerable<OC.Core.Domain.Entities.Sucursal>
@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Contacto";
}

<div class="container my-5">
    <h1 class="text-center mb-4">Contáctanos</h1>
    <p class="text-center text-muted mb-5">Todas nuestras sucursales activas. Los datos se actualizan automáticamente al agregar sucursales en el sistema.</p>

    <div class="row g-4 mb-5">
        <div class="col-12 col-lg-4">
            <div class="card h-100 shadow-sm border-0 landing-contact-card">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-building text-primary"></i> Casa matriz (corporativo)</h5>
                    <p class="mb-1"><i class="bi bi-geo-alt"></i> San José, Costa Rica</p>
                    <p class="mb-1"><i class="bi bi-telephone"></i> <a href="tel:+50622211187">2221-1187</a></p>
                    <p class="mb-0"><i class="bi bi-envelope"></i> <a href="mailto:lentesyprocesos@hotmail.com">lentesyprocesos@hotmail.com</a></p>
                    <p class="mt-2 mb-0"><i class="bi bi-whatsapp text-success"></i> <a href="https://wa.me/50686970611" target="_blank" rel="noopener">WhatsApp +506 8697-0611</a></p>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-8">
            <div class="row g-3">
                @foreach (var s in Model)
                {
                    <div class="col-12 col-md-6">
                        <div class="card h-100 shadow-sm border-0 landing-contact-card">
                            <div class="card-body">
                                <h5 class="card-title text-primary">@s.Nombre</h5>
                                <p class="mb-2 small"><i class="bi bi-geo-alt"></i> @s.Direccion</p>
                                @if (!string.IsNullOrWhiteSpace(s.Telefono))
                                {
                                    <p class="mb-1 small"><i class="bi bi-telephone"></i> <a href="tel:@s.Telefono.Replace(" ", "").Replace("-", "")">@s.Telefono</a></p>
                                }
                                @if (!string.IsNullOrWhiteSpace(s.TelefonoAdicional))
                                {
                                    <p class="mb-1 small"><i class="bi bi-phone"></i> @s.TelefonoAdicional</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(s.HorarioAtencion))
                                {
                                    <p class="mb-0 small text-muted"><i class="bi bi-clock"></i> @s.HorarioAtencion</p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row mt-2">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-chat-dots"></i> Escríbenos</h5>
                    <p class="text-muted small">Este formulario es de referencia; el envío por correo puede configurarse después.</p>
                    <form id="contactForm" method="post" action="/landing/enviar-contacto">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Nombre</label>
                                <input type="text" name="nombre" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Correo electrónico</label>
                                <input type="email" name="email" class="form-control" required />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mensaje</label>
                            <textarea name="mensaje" class="form-control" rows="4" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Enviar mensaje</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
