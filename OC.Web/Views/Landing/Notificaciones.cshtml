@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Mis Notificaciones";
}
@model IEnumerable<OC.Core.Domain.Entities.EnvioNotificacion>

<div class="container my-5 pt-5">

    <div class="text-center mb-5 animate-on-scroll">
        <h6 class="text-uppercase tracking-wide mb-2" style="color: var(--brand-accent); letter-spacing: 2px;">Centro de mensajes</h6>
        <h1 class="display-5 fw-bold text-white">Mis Notificaciones</h1>
        <p class="text-light opacity-75 mb-0">Mantente al día con tus órdenes, citas y avisos importantes.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-lg-10 col-xl-8">

            @if (!Model.Any())
            {
                <div class="card card-premium border-0 shadow-lg text-center py-5 animate-on-scroll">
                    <div class="card-body py-5">
                        <div class="position-relative d-inline-block mb-4">
                            <i class="bi bi-bell-slash display-1 text-light opacity-25"></i>
                        </div>
                        <h3 class="text-white fw-bold mb-3">Todo está tranquilo por aquí</h3>
                        <p class="text-light opacity-75 mb-0">No tienes notificaciones nuevas en este momento. Te avisaremos en cuanto haya actualizaciones.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="card card-premium shadow-lg border-0 animate-on-scroll overflow-hidden">
                    <div class="list-group list-group-flush">
                        @foreach (var notif in Model)
                        {
                            <div class="list-group-item bg-transparent p-4" style="border-bottom: 1px solid var(--glass-border); transition: background 0.3s;" onmouseover="this.style.background='rgba(14, 165, 233, 0.05)'" onmouseout="this.style.background='transparent'">

                                <div class="d-flex gap-3 align-items-start">
                                    <div class="flex-shrink-0 mt-1">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 45px; height: 45px; background: rgba(14, 165, 233, 0.1); border: 1px solid rgba(14, 165, 233, 0.2);">
                                            <i class="bi bi-bell text-primary fs-5"></i>
                                        </div>
                                    </div>

                                    <div class="flex-grow-1 min-width-0">
                                        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-2 gap-2">
                                            <h5 class="text-white fw-bold mb-0 text-truncate">@notif.TipoNotificacion</h5>
                                            <small class="text-light opacity-50 text-nowrap d-flex align-items-center">
                                                <i class="bi bi-clock me-1"></i> @notif.FechaHoraEnvio.ToString("dd/MM/yyyy HH:mm")
                                            </small>
                                        </div>

                                        <p class="text-light opacity-75 mb-3" style="line-height: 1.6;">@notif.MensajeResumen</p>

                                        <div>
                                            <span class="badge rounded-pill fw-normal px-3 py-2" style="background: rgba(255, 255, 255, 0.05); border: 1px solid var(--glass-border); color: var(--text-muted);">
                                                <i class="bi bi-broadcast me-1 text-primary opacity-75"></i> Canal: @notif.Canal
                                            </span>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>