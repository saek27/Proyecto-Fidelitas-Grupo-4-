@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Mis Notificaciones";
}
@model IEnumerable<OC.Core.Domain.Entities.EnvioNotificacion>

<div class="container my-5">
    <h1 class="text-center mb-4">Mis Notificaciones</h1>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">No tienes notificaciones.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var notif in Model)
            {
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-1">@notif.TipoNotificacion</h5>
                        <small>@notif.FechaHoraEnvio.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                    <p class="mb-1">@notif.MensajeResumen</p>
                    <small class="text-muted">Canal: @notif.Canal</small>
                </div>
            }
        </div>
    }
</div>