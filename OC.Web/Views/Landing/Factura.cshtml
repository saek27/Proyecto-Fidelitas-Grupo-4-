@{
    Layout = null;
}
@model OC.Web.ViewModels.FacturaViewModel

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Factura @Model.Venta.NumeroFactura</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            width: 210mm;
            margin: 0 auto;
            padding: 20px;
            line-height: 1.4;
        }

        .header {
            text-align: center;
            border-bottom: 2px solid #1a3c6e;
            margin-bottom: 20px;
            padding-bottom: 10px;
        }

            .header h1 {
                margin: 0;
                font-size: 24px;
            }

        .factura-id {
            text-align: right;
            margin-bottom: 20px;
        }

        .cliente {
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th, td {
            border: 1px solid #ccc;
            padding: 8px;
            text-align: left;
        }

        .text-right {
            text-align: right;
        }

        .total {
            font-weight: bold;
            font-size: 1.2em;
            margin-top: 20px;
            text-align: right;
        }

        .footer {
            margin-top: 40px;
            text-align: center;
            font-size: 12px;
            color: #666;
        }

        .btn-print {
            margin-bottom: 20px;
            text-align: center;
        }

        @@media print {
            .btn-print {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="btn-print">
        <button onclick="window.print()">Imprimir / Guardar PDF</button>
        <a href="/landing/mis-facturas">Volver a mis facturas</a>
    </div>

    <div class="header">
        <h1>Óptica Comunal</h1>
        <p>Comprobante interno de venta</p>
    </div>

    <div class="factura-id">
        <strong>Factura:</strong> @Model.Venta.NumeroFactura<br />
        <strong>Fecha:</strong> @Model.Venta.FechaVenta.ToString("dd/MM/yyyy HH:mm")
    </div>

    <div class="cliente">
        <strong>Cliente:</strong> @Model.Venta.Paciente?.NombreCompleto<br />
        <strong>Cédula:</strong> @Model.Venta.Paciente?.Cedula
    </div>

    <table>
        <thead>
            <tr>
                <th>Producto</th>
                <th class="text-right">Cant.</th>
                <th class="text-right">Precio unit.</th>
                <th class="text-right">Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model.Venta.Detalles)
            {
                <tr>
                    <td>@d.DescripcionSnapshot</td>
                    <td class="text-right">@d.Cantidad</td>
                    <td class="text-right">₡ @d.PrecioUnitario.ToString("N2")</td>
                    <td class="text-right">₡ @d.Subtotal.ToString("N2")</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="total">
        <strong>Total a pagar:</strong> ₡ @Model.Venta.Total.ToString("N2")<br />
        <strong>Método de pago:</strong> @Model.Venta.MetodoPago
    </div>

    @if (!string.IsNullOrEmpty(Model.Venta.Notas))
    {
        <div class="notas">
            <strong>Notas:</strong> @Model.Venta.Notas
        </div>
    }

    <div class="footer">
        Documento generado el @DateTime.Now.ToString("dd/MM/yyyy HH:mm")<br />
        Óptica Comunal © @DateTime.Now.Year
    </div>
</body>
</html>