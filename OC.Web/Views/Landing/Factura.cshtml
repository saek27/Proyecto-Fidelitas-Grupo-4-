@model OC.Web.ViewModels.FacturaViewModel
@{
    Layout = null;
    var v = Model.Venta;
    var subtotal = (v.Detalles ?? Enumerable.Empty<OC.Core.Domain.Entities.DetalleVenta>()).Sum(d => d.Subtotal);
    var iva = Math.Max(0m, v.Total - subtotal);
    var notasLimpias = (v.Notas ?? string.Empty)
        .Split('\n', StringSplitOptions.RemoveEmptyEntries)
        .Where(l => !l.TrimStart().StartsWith("Comprobante adjunto:", StringComparison.OrdinalIgnoreCase));
    var notasMostrar = string.Join('\n', notasLimpias).Trim();
}
@functions {
    private static string MetodoTexto(OC.Core.Domain.Enums.MetodoPago m) => m switch
    {
        OC.Core.Domain.Enums.MetodoPago.Efectivo => "Efectivo",
        OC.Core.Domain.Enums.MetodoPago.SINPE => "SINPE Móvil",
        OC.Core.Domain.Enums.MetodoPago.Tarjeta => "Tarjeta",
        _ => m.ToString()
    };
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Factura @v.NumeroFactura</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --brand: #1a3c6e;
            --brand-light: #2d5a9e;
            --muted: #64748b;
            --border: #e2e8f0;
            --bg-page: #f1f5f9;
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', 'Segoe UI', Arial, sans-serif;
            margin: 0;
            padding: 24px 16px 48px;
            line-height: 1.5;
            color: #0f172a;
            background: var(--bg-page);
            min-height: 100vh;
        }

        .sheet {
            max-width: 720px;
            margin: 0 auto;
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 4px 24px rgba(15, 23, 42, 0.08);
            border: 1px solid var(--border);
            overflow: hidden;
        }

        .actions {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 16px 20px;
            background: linear-gradient(180deg, #f8fafc 0%, #fff 100%);
            border-bottom: 1px solid var(--border);
        }

            .actions button {
                font-family: inherit;
                font-weight: 600;
                font-size: 0.875rem;
                padding: 10px 20px;
                border: none;
                border-radius: 10px;
                background: var(--brand);
                color: #fff;
                cursor: pointer;
                transition: background 0.2s;
            }

                .actions button:hover {
                    background: var(--brand-light);
                }

            .actions a {
                font-size: 0.875rem;
                font-weight: 500;
                color: var(--brand);
                text-decoration: none;
                padding: 8px 14px;
                border-radius: 10px;
                border: 1px solid var(--border);
                background: #fff;
            }

                .actions a:hover {
                    background: #f8fafc;
                }

        .header {
            text-align: center;
            padding: 28px 24px 22px;
            border-bottom: 3px solid var(--brand);
        }

            .header h1 {
                margin: 0 0 6px;
                font-size: 1.75rem;
                font-weight: 700;
                color: var(--brand);
                letter-spacing: -0.02em;
            }

            .header p {
                margin: 0;
                font-size: 0.9rem;
                color: var(--muted);
                font-weight: 500;
            }

        .body-in {
            padding: 24px 24px 28px;
        }

        .meta {
            display: grid;
            gap: 20px;
            margin-bottom: 24px;
        }

        @@media (min-width: 520px) {
            .meta {
                grid-template-columns: 1fr 1fr;
                align-items: start;
            }
        }

        .cliente {
            font-size: 0.9rem;
        }

            .cliente strong {
                color: var(--brand);
                font-weight: 600;
            }

        .factura-id {
            font-size: 0.9rem;
            text-align: left;
        }

        @@media (min-width: 520px) {
            .factura-id {
                text-align: right;
            }
        }

            .factura-id strong {
                color: var(--brand);
            }

        .table-wrap {
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid var(--border);
            margin-bottom: 8px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
        }

        thead th {
            background: var(--brand);
            color: #fff;
            font-weight: 600;
            text-align: left;
            padding: 12px 14px;
            border: none;
        }

        tbody td {
            padding: 12px 14px;
            border-bottom: 1px solid var(--border);
            vertical-align: top;
        }

        tbody tr:last-child td {
            border-bottom: none;
        }

        tbody tr:nth-child(even) {
            background: #f8fafc;
        }

        .text-right {
            text-align: right;
        }

        .totales {
            margin-top: 24px;
            padding-top: 20px;
            border-top: 2px solid var(--brand);
            max-width: 340px;
            margin-left: auto;
        }

        .totales-row {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            gap: 16px;
            padding: 6px 0;
            font-size: 0.9rem;
            color: #334155;
        }

            .totales-row.muted {
                color: var(--muted);
                font-size: 0.85rem;
            }

            .totales-row.grande {
                margin-top: 8px;
                padding-top: 12px;
                border-top: 1px dashed var(--border);
                font-size: 1.15rem;
                font-weight: 700;
                color: var(--brand);
            }

            .totales-row.metodo {
                font-size: 0.9rem;
                font-weight: 600;
                color: #0f172a;
            }

        .notas {
            margin-top: 24px;
            padding: 14px 16px;
            background: #f8fafc;
            border-radius: 10px;
            border-left: 4px solid var(--brand);
            font-size: 0.85rem;
            color: #475569;
            white-space: pre-wrap;
            word-break: break-word;
        }

            .notas strong {
                color: var(--brand);
                display: block;
                margin-bottom: 6px;
            }

        .footer {
            margin-top: 28px;
            padding-top: 20px;
            border-top: 1px solid var(--border);
            text-align: center;
            font-size: 0.75rem;
            color: var(--muted);
        }

        @@media print {
            body {
                background: #fff;
                padding: 0;
            }

            .sheet {
                box-shadow: none;
                border: none;
                border-radius: 0;
                max-width: none;
            }

            .actions {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    <div class="sheet">
        <div class="actions">
            <button type="button" onclick="window.print()">Imprimir / Guardar PDF</button>
            <a href="/landing">Volver al sitio</a>
            <a href="/landing/mis-facturas">Mis facturas</a>
        </div>

        <div class="header">
            <h1>Óptica Comunal</h1>
            <p>Comprobante interno de venta</p>
        </div>

        <div class="body-in">
            <div class="meta">
                <div class="cliente">
                    <strong>Cliente</strong><br />
                    @v.Paciente?.NombreCompleto<br />
                    <strong>Cédula</strong> @v.Paciente?.Cedula
                    @if (v.Sucursal != null)
                    {
                        <br /><strong>Sucursal</strong><br />
                        @(v.Sucursal.Nombre + " - " + v.Sucursal.Direccion)
                    }
                </div>
                <div class="factura-id">
                    <strong>Factura</strong><br />
                    @v.NumeroFactura<br /><br />
                    <strong>Fecha</strong><br />
                    @v.FechaVenta.ToString("dd/MM/yyyy HH:mm")
                </div>
            </div>

            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th class="text-right" style="width:72px">Cant.</th>
                            <th class="text-right" style="width:120px">Precio unit.</th>
                            <th class="text-right" style="width:120px">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in v.Detalles ?? Enumerable.Empty<OC.Core.Domain.Entities.DetalleVenta>())
                        {
                            <tr>
                                <td>@d.DescripcionSnapshot</td>
                                <td class="text-right">@d.Cantidad</td>
                                <td class="text-right">₡ @d.PrecioUnitario.ToString("N2")</td>
                                <td class="text-right">₡ @d.Subtotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="totales">
                <div class="totales-row muted">
                    <span>Subtotal gravado</span>
                    <span>₡ @subtotal.ToString("N2")</span>
                </div>
                <div class="totales-row muted">
                    <span>IVA 13%</span>
                    <span>₡ @iva.ToString("N2")</span>
                </div>
                <div class="totales-row grande">
                    <span>Total a pagar</span>
                    <span>₡ @v.Total.ToString("N2")</span>
                </div>
                <div class="totales-row metodo">
                    <span>Método de pago</span>
                    <span>@MetodoTexto(v.MetodoPago)</span>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(notasMostrar))
            {
                <div class="notas">
                    <strong>Notas</strong>
                    @notasMostrar
                </div>
            }

            <div class="footer">
                Documento generado el @DateTime.Now.ToString("dd/MM/yyyy HH:mm")<br />
                Óptica Comunal © @DateTime.Now.Year
            </div>
        </div>
    </div>
</body>
</html>
