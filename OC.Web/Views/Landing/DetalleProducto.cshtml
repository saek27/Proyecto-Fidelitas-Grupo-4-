@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = Model.Nombre;
}
@model OC.Core.Domain.Entities.Producto

<div class="container my-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-sm">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm">@TempData["Error"]</div>
    }
    <div class="row">
        <div class="col-12 col-md-6 mb-4">
            <img src="@(string.IsNullOrEmpty(Model.RutaImagen) ? "/images/default-product.jpg" : Model.RutaImagen)" class="img-fluid rounded shadow" alt="@Model.Nombre">
        </div>
        <div class="col-12 col-md-6">
            <h1>@Model.Nombre</h1>
            <p class="h3 text-primary">₡@Model.PrecioPublico.ToString("N2")</p>
            <p class="text-muted">SKU: @Model.SKU</p>
            <p>@Model.DescripcionCorta</p>
            <p><strong>Stock:</strong> @Model.Stock unidades</p>
            <form asp-controller="Landing" asp-action="AgregarAlCarrito" method="post" class="mt-3">
                <input type="hidden" name="productoId" value="@Model.Id" />
                <div class="input-group w-50 mb-3">
                    <input type="number" name="cantidad" value="1" min="1" max="@Model.Stock" class="form-control" />
                    <button type="submit" class="btn btn-primary">Agregar al carrito</button>
                </div>
            </form>
            <a href="/landing/catalogo" class="btn btn-secondary">Volver al catálogo</a>
        </div>
    </div>
</div>