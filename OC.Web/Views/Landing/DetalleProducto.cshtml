@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = Model.Nombre;
}
@model OC.Core.Domain.Entities.Producto

<div class="container my-5 pt-5">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-sm rounded-3 animate-on-scroll mb-4">
            <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm rounded-3 animate-on-scroll mb-4">
            <i class="bi bi-exclamation-triangle me-2"></i> @TempData["Error"]
        </div>
    }

    <div class="row g-5 align-items-center animate-on-scroll">

        <div class="col-12 col-lg-6">
            <div class="card card-premium border-0 shadow-lg p-4 d-flex align-items-center justify-content-center position-relative overflow-hidden" style="min-height: 450px; border-radius: 20px;">
                <div class="position-absolute rounded-circle" style="width: 300px; height: 300px; background: rgba(14, 165, 233, 0.15); filter: blur(50px); z-index: 0;"></div>

                <img src="@(string.IsNullOrEmpty(Model.RutaImagen) ? "/images/default-product.jpg" : Model.RutaImagen)"
                     class="img-fluid position-relative z-1"
                     alt="@Model.Nombre"
                     style="max-height: 380px; object-fit: contain; filter: drop-shadow(0 15px 25px rgba(0,0,0,0.4)); transition: transform 0.5s ease;"
                     onmouseover="this.style.transform='scale(1.08)'"
                     onmouseout="this.style.transform='scale(1)'">
            </div>
        </div>

        <div class="col-12 col-lg-6">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/landing/catalogo" class="text-primary text-decoration-none hover-primary transition">Catálogo</a></li>
                    <li class="breadcrumb-item active text-light opacity-50" aria-current="page">Detalles del lente</li>
                </ol>
            </nav>

            <h1 class="display-4 fw-bold text-white mb-2" style="line-height: 1.1;">@Model.Nombre</h1>
            <p class="text-light opacity-50 small mb-4 tracking-wide">SKU: @Model.SKU</p>

            <p class="display-5 fw-bold mb-4" style="color: var(--brand-accent);">₡@Model.PrecioPublico.ToString("N2")</p>

            <div class="mb-4">
                <p class="text-light opacity-75 fs-5" style="line-height: 1.6;">@Model.DescripcionCorta</p>
            </div>

            <div class="mb-4">
                @if (Model.Stock > 0)
                {
                    <span class="badge rounded-pill px-3 py-2 fw-normal shadow-sm" style="background: rgba(25, 135, 84, 0.2); border: 1px solid rgba(25, 135, 84, 0.5); color: #86efac;">
                        <i class="bi bi-check2-circle me-1"></i> Stock disponible: @Model.Stock unidades
                    </span>
                }
                else
                {
                    <span class="badge rounded-pill px-3 py-2 fw-normal shadow-sm" style="background: rgba(220, 53, 69, 0.2); border: 1px solid rgba(220, 53, 69, 0.5); color: #fca5a5;">
                        <i class="bi bi-x-circle me-1"></i> Producto agotado
                    </span>
                }
            </div>

            <hr class="border-secondary mb-4 mt-2">

            <form asp-controller="Landing" asp-action="AgregarAlCarrito" method="post" class="mt-3">
                <input type="hidden" name="productoId" value="@Model.Id" />

                <div class="row g-3 align-items-end">
                    <div class="col-auto">
                        <label class="form-label text-light fw-medium mb-2">Cantidad</label>
                        <input type="number" name="cantidad" value="1" min="1" max="@Model.Stock" class="form-control input-premium text-center" style="width: 100px; height: 55px; font-size: 1.25rem;" />
                    </div>
                    <div class="col">
                        <button type="submit" class="btn btn-premium w-100 d-flex align-items-center justify-content-center gap-2" style="height: 55px;" @(Model.Stock <= 0 ? "disabled" : "")>
                            <i class="bi bi-cart-plus fs-5"></i> Agregar al carrito
                        </button>
                    </div>
                </div>
            </form>

            <div class="mt-4 pt-3">
                <a href="/landing/catalogo" class="btn btn-outline-light px-4 py-2 text-light opacity-75 hover-opacity-100 transition d-inline-flex align-items-center">
                    <i class="bi bi-arrow-left me-2"></i> Volver al catálogo
                </a>
            </div>

        </div>
    </div>
</div>