@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Mi carrito";
    var sucursales = ViewBag.Sucursales as IList<OC.Core.Domain.Entities.Sucursal> ?? new List<OC.Core.Domain.Entities.Sucursal>();
}
@model List<OC.Web.ViewModels.DetalleVentaInputModel>

<div class="container my-5 landing-carrito">
    <h1 class="text-center mb-4 fw-bold">Mi carrito</h1>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-sm">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm">@TempData["Error"]</div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center shadow-sm">
            Tu carrito está vacío. <a href="/landing/catalogo" class="alert-link">Ver productos</a>
        </div>
    }
    else
    {
        <form id="formCarrito" method="post" asp-controller="Landing" asp-action="FinalizarCompra" enctype="multipart/form-data">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <label class="form-label fw-semibold"><i class="bi bi-shop"></i> Sucursal de retiro / atención <span class="text-danger">*</span></label>
                    <select name="sucursalId" id="sucursalId" class="form-select form-select-lg" required>
                        <option value="">Seleccione una sucursal</option>
                        @foreach (var s in sucursales)
                        {
                            <option value="@s.Id">@(s.Nombre + " - " + s.Direccion)</option>
                        }
                    </select>
                    <div class="form-text">Obligatorio. La compra quedará asociada a la sucursal elegida.</div>
                </div>
            </div>

            <div class="table-responsive card border-0 shadow-sm mb-4">
                <table class="table table-hover align-middle mb-0" id="tablaCarrito">
                    <thead class="table-light">
                        <tr>
                            <th>Producto</th>
                            <th style="width:110px">Cantidad</th>
                            <th style="width:130px" class="text-end">Precio unit.</th>
                            <th style="width:130px" class="text-end">Subtotal</th>
                            <th style="width:56px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            <tr data-index="@i">
                                <td>
                                    @Model[i].DescripcionSnapshot
                                    <input type="hidden" name="detalles[@i].ProductoId" value="@Model[i].ProductoId" />
                                    <input type="hidden" name="detalles[@i].DescripcionSnapshot" value="@Model[i].DescripcionSnapshot" />
                                </td>
                                <td>
                                    <input type="number" name="detalles[@i].Cantidad" value="@Model[i].Cantidad" min="1" class="form-control cantidad" />
                                </td>
                                <td class="text-end">
                                    <input type="number" name="detalles[@i].PrecioUnitario" value="@Model[i].PrecioUnitario.ToString("G29", System.Globalization.CultureInfo.InvariantCulture)" step="0.01" min="0" class="form-control precio text-end" />
                                </td>
                                <td class="text-end subtotal">₡ @((Model[i].Cantidad * Model[i].PrecioUnitario).ToString("N2"))</td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-danger eliminar-item" title="Quitar línea"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <th colspan="3" class="text-end">Subtotal gravado</th>
                            <th class="text-end" id="filaSubtotal">₡ 0.00</th>
                            <th></th>
                        </tr>
                        <tr>
                            <th colspan="3" class="text-end">IVA 13%</th>
                            <th class="text-end" id="filaIva">₡ 0.00</th>
                            <th></th>
                        </tr>
                        <tr class="fs-5">
                            <th colspan="3" class="text-end">Total a pagar</th>
                            <th class="text-end text-primary" id="totalGeneral">₡ 0.00</th>
                            <th></th>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title">Método de pago</h5>
                            <p class="small text-muted">En la tienda en línea solo aceptamos efectivo o SINPE Móvil.</p>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="metodoPago" value="1" id="mpEfectivo" checked>
                                <label class="form-check-label" for="mpEfectivo">Efectivo</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="metodoPago" value="2" id="mpSINPE">
                                <label class="form-check-label" for="mpSINPE">SINPE Móvil</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title">Comprobante y notas</h5>
                            <label class="form-label" id="lblComprobante">Comprobante de pago <span class="text-muted" id="hintComprobante">(opcional con efectivo)</span></label>
                            <input type="file" name="comprobantePago" id="comprobantePago" class="form-control" accept=".jpg,.jpeg,.png,.gif,.webp,.pdf" />
                            <div class="form-text mb-3">Imagen o PDF</div>
                            <label class="form-label">Notas (opcional)</label>
                            <textarea name="notas" class="form-control" rows="3" placeholder="Indicaciones de entrega, teléfono alternativo, etc."></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-end mt-4 d-flex flex-wrap gap-2 justify-content-end">
                <a href="/landing/catalogo" class="btn btn-outline-secondary btn-lg">Seguir comprando</a>
                <button type="submit" class="btn btn-success btn-lg">Confirmar compra</button>
            </div>
        </form>
    }
</div>

@section Scripts {
    <script>
        (function () {
            const tasaIva = 0.13;
            const urlActualizar = '@Url.Action("ActualizarCarrito", "Landing")';

            function reindexarFilas() {
                $('#tablaCarrito tbody tr').each(function (idx) {
                    $(this).attr('data-index', idx);
                    $(this).find('input[name^="detalles["]').each(function () {
                        const name = $(this).attr('name');
                        if (!name) return;
                        $(this).attr('name', name.replace(/detalles\[\d+\]/, 'detalles[' + idx + ']'));
                    });
                });
            }

            function actualizarSubtotales() {
                let subtotal = 0;
                $('#tablaCarrito tbody tr').each(function () {
                    const $row = $(this);
                    const cantidad = parseFloat(String($row.find('.cantidad').val()).replace(',', '.')) || 0;
                    const precio = parseFloat(String($row.find('.precio').val()).replace(',', '.')) || 0;
                    const linea = cantidad * precio;
                    $row.find('td.subtotal').text('₡ ' + linea.toFixed(2));
                    subtotal += linea;
                });
                const iva = Math.round(subtotal * tasaIva * 100) / 100;
                const total = Math.round((subtotal + iva) * 100) / 100;
                $('#filaSubtotal').text('₡ ' + subtotal.toFixed(2));
                $('#filaIva').text('₡ ' + iva.toFixed(2));
                $('#totalGeneral').text('₡ ' + total.toFixed(2));
            }

            function sincronizarCarrito() {
                const items = [];
                $('#tablaCarrito tbody tr').each(function () {
                    const $row = $(this);
                    const pid = $row.find('input[name$=".ProductoId"]').val();
                    items.push({
                        productoId: pid ? parseInt(pid, 10) : null,
                        descripcionSnapshot: $row.find('input[name$=".DescripcionSnapshot"]').val() || '',
                        cantidad: parseInt($row.find('.cantidad').val(), 10) || 1,
                        precioUnitario: parseFloat(String($row.find('.precio').val()).replace(',', '.')) || 0
                    });
                });
                $.ajax({
                    url: urlActualizar,
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(items),
                    dataType: 'json'
                }).fail(function () { console.warn('No se pudo sincronizar el carrito en sesión.'); });
            }

            $(function () {
                actualizarSubtotales();

                $(document).on('input change', '.cantidad, .precio', function () {
                    actualizarSubtotales();
                    sincronizarCarrito();
                });

                $(document).on('click', '.eliminar-item', function () {
                    $(this).closest('tr').remove();
                    reindexarFilas();
                    actualizarSubtotales();
                    sincronizarCarrito();
                    if ($('#tablaCarrito tbody tr').length === 0) {
                        location.reload();
                    }
                });

                function actualizarRequisitoComprobante() {
                    const sinpe = $('#mpSINPE').is(':checked');
                    const $f = $('#comprobantePago');
                    const $hint = $('#hintComprobante');
                    if (sinpe) {
                        $f.prop('required', true);
                        $hint.text('(obligatorio con SINPE Móvil)');
                    } else {
                        $f.prop('required', false);
                        $hint.text('(opcional con efectivo)');
                    }
                }

                $('input[name="metodoPago"]').on('change', actualizarRequisitoComprobante);
                actualizarRequisitoComprobante();

                $('#formCarrito').on('submit', function (e) {
                    reindexarFilas();
                    if ($('#tablaCarrito tbody tr').length === 0) {
                        e.preventDefault();
                        alert('El carrito está vacío');
                        return;
                    }
                    const suc = $('#sucursalId').val();
                    if (!suc || suc === '0') {
                        e.preventDefault();
                        alert('Debe seleccionar una sucursal.');
                        return;
                    }
                    if ($('#mpSINPE').is(':checked')) {
                        const fileInput = document.getElementById('comprobantePago');
                        if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
                            e.preventDefault();
                            alert('Con SINPE Móvil debe adjuntar un comprobante (imagen o PDF).');
                        }
                    }
                });
            });
        })();
    </script>
}
