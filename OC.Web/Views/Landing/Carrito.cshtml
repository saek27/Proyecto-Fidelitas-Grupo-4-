@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Mi carrito";
    var sucursales = ViewBag.Sucursales as IList<OC.Core.Domain.Entities.Sucursal> ?? new List<OC.Core.Domain.Entities.Sucursal>();
}
@model List<OC.Web.ViewModels.DetalleVentaInputModel>

<div class="container my-5 pt-5 landing-carrito">

    <div class="text-center mb-5 animate-on-scroll">
        <h6 class="text-uppercase tracking-wide mb-2" style="color: var(--brand-accent); letter-spacing: 2px;">Resumen de tu pedido</h6>
        <h1 class="display-5 fw-bold text-white">Mi Carrito</h1>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-sm rounded-3 animate-on-scroll">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm rounded-3 animate-on-scroll">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="card card-premium border-0 shadow-lg text-center py-5 animate-on-scroll">
            <div class="card-body py-5">
                <i class="bi bi-cart-x display-1 text-light opacity-25 mb-4 d-block"></i>
                <h3 class="text-white fw-bold mb-3">Tu carrito está vacío</h3>
                <p class="text-light opacity-75 mb-4">Aún no has agregado ningún lente a tu pedido.</p>
                <a href="/landing/catalogo" class="btn btn-premium btn-lg px-4">Explorar catálogo <i class="bi bi-arrow-right ms-2"></i></a>
            </div>
        </div>
    }
    else
    {
        <form id="formCarrito" method="post" asp-controller="Landing" asp-action="FinalizarCompra" enctype="multipart/form-data" class="animate-on-scroll">

            <div class="card card-premium border-0 shadow-lg mb-4">
                <div class="card-body p-4">
                    <label class="form-label text-white fw-semibold mb-3 fs-5"><i class="bi bi-shop text-primary me-2"></i> Sucursal de retiro / atención <span class="text-danger">*</span></label>
                    <select name="sucursalId" id="sucursalId" class="form-select form-select-lg input-premium" style="color-scheme: dark;" required>
                        <option value="">Seleccione la sucursal más cercana...</option>
                        @foreach (var s in sucursales)
                        {
                            <option value="@s.Id">@(s.Nombre + " - " + s.Direccion)</option>
                        }
                    </select>
                    <div class="form-text text-light opacity-50 mt-2"><i class="bi bi-info-circle me-1"></i> Obligatorio. La compra quedará asociada a la sucursal elegida para su retiro o examen.</div>
                </div>
            </div>

            <div class="card card-premium border-0 shadow-lg mb-4">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-borderless align-middle mb-0 text-light" id="tablaCarrito" style="--bs-table-bg: transparent; --bs-table-color: var(--text-main);">
                            <thead style="border-bottom: 2px solid var(--glass-border);">
                                <tr>
                                    <th class="py-3 px-4 text-uppercase small text-light opacity-75 fw-medium">Producto</th>
                                    <th style="width:130px" class="py-3 px-2 text-uppercase small text-light opacity-75 fw-medium text-center">Cantidad</th>
                                    <th style="width:150px" class="py-3 px-4 text-uppercase small text-light opacity-75 fw-medium text-end">Precio unit.</th>
                                    <th style="width:150px" class="py-3 px-4 text-uppercase small text-light opacity-75 fw-medium text-end">Subtotal</th>
                                    <th style="width:70px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.Count; i++)
                                {
                                    <tr data-index="@i" style="border-bottom: 1px solid var(--glass-border);">
                                        <td class="py-4 px-4 fw-bold">
                                            @Model[i].DescripcionSnapshot
                                            <input type="hidden" name="detalles[@i].ProductoId" value="@Model[i].ProductoId" />
                                            <input type="hidden" name="detalles[@i].DescripcionSnapshot" value="@Model[i].DescripcionSnapshot" />
                                        </td>
                                        <td class="py-4 px-2">
                                            <input type="number" name="detalles[@i].Cantidad" value="@Model[i].Cantidad" min="1" class="form-control text-center input-premium cantidad" style="max-width: 90px; margin: 0 auto;" />
                                        </td>
                                        <td class="py-4 px-4 text-end">
                                            <input type="number" name="detalles[@i].PrecioUnitario" value="@Model[i].PrecioUnitario.ToString("G29", System.Globalization.CultureInfo.InvariantCulture)" step="0.01" min="0" class="form-control text-end input-premium precio" />
                                        </td>
                                        <td class="py-4 px-4 text-end fw-bold text-white subtotal">₡ @((Model[i].Cantidad * Model[i].PrecioUnitario).ToString("N2"))</td>
                                        <td class="py-4 px-3 text-end">
                                            <button type="button" class="btn btn-outline-danger btn-sm rounded-circle eliminar-item" style="width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;" title="Quitar línea">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot style="background: rgba(14, 165, 233, 0.05); border-top: 2px solid var(--brand-primary);">
                                <tr>
                                    <th colspan="3" class="text-end py-3 px-4 text-light opacity-75 fw-normal">Subtotal gravado</th>
                                    <th class="text-end py-3 px-4 fw-bold text-white" id="filaSubtotal">₡ 0.00</th>
                                    <th></th>
                                </tr>
                                <tr>
                                    <th colspan="3" class="text-end py-3 px-4 text-light opacity-75 fw-normal">IVA 13%</th>
                                    <th class="text-end py-3 px-4 fw-bold text-white" id="filaIva">₡ 0.00</th>
                                    <th></th>
                                </tr>
                                <tr class="fs-4">
                                    <th colspan="3" class="text-end py-4 px-4 fw-bold text-white">Total a pagar</th>
                                    <th class="text-end py-4 px-4 fw-bold" style="color: var(--brand-accent);" id="totalGeneral">₡ 0.00</th>
                                    <th></th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="card card-premium border-0 shadow-lg h-100">
                        <div class="card-body p-4">
                            <h5 class="card-title text-white fw-bold mb-3"><i class="bi bi-wallet2 text-primary me-2"></i> Método de pago</h5>
                            <p class="small text-light opacity-75 mb-4">En la tienda en línea solo aceptamos pagos mediante Efectivo o SINPE Móvil.</p>

                            <div class="d-flex flex-column gap-3">
                                <div class="form-check p-3 rounded-3" style="border: 1px solid var(--glass-border); background: rgba(0,0,0,0.2);">
                                    <input class="form-check-input ms-1 me-3 mt-1" type="radio" name="metodoPago" value="1" id="mpEfectivo" checked style="transform: scale(1.3);">
                                    <label class="form-check-label text-white fw-medium stretched-link" for="mpEfectivo">
                                        <i class="bi bi-cash-stack text-success me-2"></i> Efectivo al retirar
                                    </label>
                                </div>
                                <div class="form-check p-3 rounded-3" style="border: 1px solid var(--glass-border); background: rgba(0,0,0,0.2);">
                                    <input class="form-check-input ms-1 me-3 mt-1" type="radio" name="metodoPago" value="2" id="mpSINPE" style="transform: scale(1.3);">
                                    <label class="form-check-label text-white fw-medium stretched-link" for="mpSINPE">
                                        <i class="bi bi-phone-vibrate text-primary me-2"></i> Transferencia SINPE Móvil
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="card card-premium border-0 shadow-lg h-100">
                        <div class="card-body p-4">
                            <h5 class="card-title text-white fw-bold mb-3"><i class="bi bi-file-earmark-arrow-up text-primary me-2"></i> Comprobante y Notas</h5>

                            <div class="mb-4">
                                <label class="form-label text-light fw-medium" id="lblComprobante">Adjuntar Comprobante <span class="text-light opacity-50 small ms-1" id="hintComprobante">(opcional con efectivo)</span></label>
                                <input type="file" name="comprobantePago" id="comprobantePago" class="form-control input-premium" accept=".jpg,.jpeg,.png,.gif,.webp,.pdf" />
                                <div class="form-text text-light opacity-50 mt-1"><i class="bi bi-paperclip me-1"></i> Imagen o PDF del pago.</div>
                            </div>

                            <div>
                                <label class="form-label text-light fw-medium">Notas del pedido <span class="text-light opacity-50 small ms-1">(opcional)</span></label>
                                <textarea name="notas" class="form-control input-premium" rows="3" placeholder="Ej: Pasaré a recoger los lentes el día martes por la mañana..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-column flex-md-row justify-content-end gap-3 mt-5 pb-5">
                <a href="/landing/catalogo" class="btn btn-outline-premium btn-lg px-4">
                    <i class="bi bi-arrow-left me-2"></i> Seguir comprando
                </a>
                <button type="submit" class="btn btn-premium btn-lg px-5 fs-5">
                    Confirmar pedido <i class="bi bi-check2-circle ms-2"></i>
                </button>
            </div>
        </form>
    }
</div>

@section Scripts {
    <script>
        (function () {
            const tasaIva = 0.13;
            const urlActualizar = '@Url.Action("ActualizarCarrito", "Landing")';

            function reindexarFilas() {
                $('#tablaCarrito tbody tr').each(function (idx) {
                    $(this).attr('data-index', idx);
                    $(this).find('input[name^="detalles["]').each(function () {
                        const name = $(this).attr('name');
                        if (!name) return;
                        $(this).attr('name', name.replace(/detalles\[\d+\]/, 'detalles[' + idx + ']'));
                    });
                });
            }

            function actualizarSubtotales() {
                let subtotal = 0;
                $('#tablaCarrito tbody tr').each(function () {
                    const $row = $(this);
                    const cantidad = parseFloat(String($row.find('.cantidad').val()).replace(',', '.')) || 0;
                    const precio = parseFloat(String($row.find('.precio').val()).replace(',', '.')) || 0;
                    const linea = cantidad * precio;
                    $row.find('td.subtotal').text('₡ ' + linea.toFixed(2));
                    subtotal += linea;
                });
                const iva = Math.round(subtotal * tasaIva * 100) / 100;
                const total = Math.round((subtotal + iva) * 100) / 100;
                $('#filaSubtotal').text('₡ ' + subtotal.toFixed(2));
                $('#filaIva').text('₡ ' + iva.toFixed(2));
                $('#totalGeneral').text('₡ ' + total.toFixed(2));
            }

            function sincronizarCarrito() {
                const items = [];
                $('#tablaCarrito tbody tr').each(function () {
                    const $row = $(this);
                    const pid = $row.find('input[name$=".ProductoId"]').val();
                    items.push({
                        productoId: pid ? parseInt(pid, 10) : null,
                        descripcionSnapshot: $row.find('input[name$=".DescripcionSnapshot"]').val() || '',
                        cantidad: parseInt($row.find('.cantidad').val(), 10) || 1,
                        precioUnitario: parseFloat(String($row.find('.precio').val()).replace(',', '.')) || 0
                    });
                });
                $.ajax({
                    url: urlActualizar,
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(items),
                    dataType: 'json'
                }).fail(function () { console.warn('No se pudo sincronizar el carrito en sesión.'); });
            }

            $(function () {
                actualizarSubtotales();

                $(document).on('input change', '.cantidad, .precio', function () {
                    actualizarSubtotales();
                    sincronizarCarrito();
                });

                $(document).on('click', '.eliminar-item', function () {
                    $(this).closest('tr').remove();
                    reindexarFilas();
                    actualizarSubtotales();
                    sincronizarCarrito();
                    if ($('#tablaCarrito tbody tr').length === 0) {
                        location.reload();
                    }
                });

                function actualizarRequisitoComprobante() {
                    const sinpe = $('#mpSINPE').is(':checked');
                    const $f = $('#comprobantePago');
                    const $hint = $('#hintComprobante');
                    if (sinpe) {
                        $f.prop('required', true);
                        $hint.text('(obligatorio con SINPE Móvil)');
                    } else {
                        $f.prop('required', false);
                        $hint.text('(opcional con efectivo)');
                    }
                }

                $('input[name="metodoPago"]').on('change', actualizarRequisitoComprobante);
                actualizarRequisitoComprobante();

                $('#formCarrito').on('submit', function (e) {
                    reindexarFilas();
                    if ($('#tablaCarrito tbody tr').length === 0) {
                        e.preventDefault();
                        alert('El carrito está vacío');
                        return;
                    }
                    const suc = $('#sucursalId').val();
                    if (!suc || suc === '0') {
                        e.preventDefault();
                        alert('Debe seleccionar una sucursal.');
                        return;
                    }
                    if ($('#mpSINPE').is(':checked')) {
                        const fileInput = document.getElementById('comprobantePago');
                        if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
                            e.preventDefault();
                            alert('Con SINPE Móvil debe adjuntar un comprobante (imagen o PDF).');
                        }
                    }
                });
            });
        })();
    </script>
}