@model IEnumerable<OC.Core.Domain.Entities.Venta>
@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Mis facturas";
    string MetodoTexto(OC.Core.Domain.Enums.MetodoPago m) => m switch
    {
        OC.Core.Domain.Enums.MetodoPago.Efectivo => "Efectivo",
        OC.Core.Domain.Enums.MetodoPago.SINPE => "SINPE Móvil",
        OC.Core.Domain.Enums.MetodoPago.Tarjeta => "Tarjeta",
        _ => m.ToString()
    };
}

<div class="container my-5 landing-mis-facturas">
    <div class="text-center mb-5">
        <h1 class="fw-bold">Mis facturas</h1>
        <p class="text-muted mb-0">Comprobantes de tus compras en línea y en sucursal.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-sm">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm">@TempData["Error"]</div>
    }

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm text-center py-5">
            <div class="card-body">
                <i class="bi bi-receipt display-4 text-muted mb-3"></i>
                <p class="lead text-muted mb-4">Aún no tienes facturas registradas.</p>
                <a href="/landing/catalogo" class="btn btn-primary btn-lg rounded-pill px-4">Ver catálogo</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var venta in Model)
            {
                var sub = (venta.Detalles ?? Enumerable.Empty<OC.Core.Domain.Entities.DetalleVenta>()).Sum(d => d.Subtotal);
                var iva = Math.Max(0, venta.Total - sub);
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card h-100 border-0 shadow-sm landing-factura-card">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge bg-primary rounded-pill">@venta.NumeroFactura</span>
                                <small class="text-muted">@venta.FechaVenta.ToString("dd MMM yyyy", new System.Globalization.CultureInfo("es-CR"))</small>
                            </div>
                            <p class="small text-muted mb-1">@MetodoTexto(venta.MetodoPago)</p>
                            @if (venta.Sucursal != null)
                            {
                                <p class="small mb-3"><i class="bi bi-shop text-secondary"></i> @venta.Sucursal.Nombre</p>
                            }
                            <div class="mt-auto pt-3 border-top">
                                <div class="d-flex justify-content-between small text-muted">
                                    <span>Subtotal</span>
                                    <span>₡@sub.ToString("N2")</span>
                                </div>
                                @if (iva > 0)
                                {
                                    <div class="d-flex justify-content-between small text-muted">
                                        <span>IVA 13%</span>
                                        <span>₡@iva.ToString("N2")</span>
                                    </div>
                                }
                                <div class="d-flex justify-content-between fw-bold fs-5 text-primary mt-2">
                                    <span>Total</span>
                                    <span>₡@venta.Total.ToString("N2")</span>
                                </div>
                            </div>
                            <a href="/landing/factura/@venta.Id" class="btn btn-outline-primary w-100 mt-3 rounded-pill">
                                <i class="bi bi-file-earmark-text"></i> Ver comprobante
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
