@model IEnumerable<OC.Core.Domain.Entities.Venta>
@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Mis facturas";
    string MetodoTexto(OC.Core.Domain.Enums.MetodoPago m) => m switch
    {
        OC.Core.Domain.Enums.MetodoPago.Efectivo => "Efectivo",
        OC.Core.Domain.Enums.MetodoPago.SINPE => "SINPE Móvil",
        OC.Core.Domain.Enums.MetodoPago.Tarjeta => "Tarjeta",
        _ => m.ToString()
    };
}

<div class="container my-5 pt-5 landing-mis-facturas">
    <div class="text-center mb-5 animate-on-scroll">
        <h6 class="text-uppercase tracking-wide mb-2" style="color: var(--brand-accent); letter-spacing: 2px;">Historial de compras</h6>
        <h1 class="display-5 fw-bold text-white">Mis facturas</h1>
        <p class="text-light opacity-75 mb-0">Comprobantes de tus compras en línea y en sucursal.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-sm rounded-3 animate-on-scroll">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm rounded-3 animate-on-scroll">@TempData["Error"]</div>
    }

    @if (!Model.Any())
    {
        <div class="card card-premium border-0 shadow-lg text-center py-5 animate-on-scroll">
            <div class="card-body py-5">
                <i class="bi bi-receipt display-1 text-light opacity-25 mb-4 d-block"></i>
                <h3 class="text-white fw-bold mb-3">Aún no tienes facturas registradas</h3>
                <p class="text-light opacity-75 mb-5 max-w-50 mx-auto">Tu historial de compras está vacío. Explora nuestra colección y encuentra los lentes perfectos para ti.</p>
                <a href="/landing/catalogo" class="btn btn-premium btn-lg px-5">Ver catálogo de lentes <i class="bi bi-arrow-right ms-2"></i></a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4 g-lg-4">
            @foreach (var venta in Model)
            {
                var sub = (venta.Detalles ?? Enumerable.Empty<OC.Core.Domain.Entities.DetalleVenta>()).Sum(d => d.Subtotal);
                var iva = Math.Max(0, venta.Total - sub);

                <div class="col-12 col-md-6 col-xl-4 animate-on-scroll">
                    <div class="card card-premium h-100 border-0 shadow-sm landing-factura-card">
                        <div class="card-body d-flex flex-column p-4">

                            <div class="d-flex justify-content-between align-items-start mb-4">
                                <span class="badge bg-primary px-3 py-2 fw-normal rounded-pill" style="font-size: 0.9rem; letter-spacing: 1px;">@venta.NumeroFactura</span>
                                <small class="text-light opacity-75 bg-dark px-2 py-1 rounded border" style="border-color: var(--glass-border) !important;">
                                    <i class="bi bi-calendar3 me-1"></i> @venta.FechaVenta.ToString("dd MMM yyyy", new System.Globalization.CultureInfo("es-CR"))
                                </small>
                            </div>

                            <div class="mb-4">
                                <p class="small text-light opacity-75 mb-2">
                                    <i class="bi bi-credit-card me-2 text-primary"></i> @MetodoTexto(venta.MetodoPago)
                                </p>
                                @if (venta.Sucursal != null)
                                {
                                    <p class="small text-light opacity-75 mb-0">
                                        <i class="bi bi-shop me-2 text-primary"></i> @venta.Sucursal.Nombre
                                    </p>
                                }
                            </div>

                            <div class="mt-auto pt-3 border-top" style="border-color: var(--glass-border) !important;">
                                <div class="d-flex justify-content-between small text-light opacity-75 mb-1">
                                    <span>Subtotal</span>
                                    <span>₡@sub.ToString("N2")</span>
                                </div>
                                @if (iva > 0)
                                {
                                    <div class="d-flex justify-content-between small text-light opacity-75 mb-2">
                                        <span>IVA 13%</span>
                                        <span>₡@iva.ToString("N2")</span>
                                    </div>
                                }
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span class="text-light fw-medium">Total</span>
                                    <span class="fw-bold fs-4" style="color: var(--brand-accent);">₡@venta.Total.ToString("N2")</span>
                                </div>
                            </div>

                            <a href="/landing/factura/@venta.Id" target="_blank" class="btn btn-outline-premium w-100 mt-4 d-flex justify-content-center align-items-center gap-2">
                                <i class="bi bi-file-earmark-text"></i> Ver comprobante
                            </a>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>