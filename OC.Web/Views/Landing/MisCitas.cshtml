@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Mis Citas";
}
@model IEnumerable<OC.Core.Domain.Entities.Cita>

<div class="container my-5">
    <div class="text-center mb-4">
        <h1 class="display-5 fw-bold">Mis Citas</h1>
        <p class="text-muted">Consulta y gestiona tus citas programadas</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x display-1 text-muted"></i>
            <h3 class="mt-3">No tienes citas registradas</h3>
            <p class="text-muted">Puedes agendar una nueva cita fácilmente.</p>
            <a href="/landing/agendar-cita" class="btn btn-primary btn-lg mt-3">
                <i class="bi bi-plus-circle"></i> Agendar nueva cita
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Fecha y Hora</th>
                        <th>Sucursal</th>
                        <th>Estado</th>
                        <th>Motivo</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cita in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@cita.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(cita.Sucursal?.Nombre ?? "No asignada")</td>
                            <td>
                                @switch (cita.Estado)
                                {
                                    case "Confirmada":
                                        <span class="badge bg-primary rounded-pill px-3">Confirmada</span>
                                        break;
                                    case "Atendida":
                                        <span class="badge bg-success rounded-pill px-3">Atendida</span>
                                        break;
                                    case "Cancelada":
                                        <span class="badge bg-secondary rounded-pill px-3">Cancelada</span>
                                        break;
                                    case "Pendiente":
                                        <span class="badge bg-warning text-dark rounded-pill px-3">Pendiente</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary rounded-pill px-3">@cita.Estado</span>
                                        break;
                                }
                            </td>
                            <td>@(cita.MotivoConsulta ?? "Sin observaciones")</td>
                            <td>
                                @if (cita.Estado == "Confirmada" && cita.FechaHora > DateTime.Now)
                                {
                                    <a href="#" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Cancelar esta cita?')">
                                        <i class="bi bi-x-circle"></i> Cancelar
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="text-center mt-4">
            <a href="/landing/agendar-cita" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Agendar nueva cita
            </a>
        </div>
    }
</div>