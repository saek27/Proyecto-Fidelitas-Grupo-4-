@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Catálogo de Lentes";
}
@model OC.Core.Common.PagedResult<OC.Core.Domain.Entities.Producto>

<div class="container my-5 pt-5">
    <div class="text-center mb-5 animate-on-scroll">
        <h6 class="text-uppercase tracking-wide mb-2" style="color: var(--brand-accent); letter-spacing: 2px;">Explora nuestra colección</h6>
        <h1 class="display-5 fw-bold text-white">Nuestros Lentes</h1>
    </div>

    <div class="row">
        <div class="col-12 col-lg-3 mb-4 animate-on-scroll">
            <div class="card card-premium shadow-lg border-0 sticky-lg-top" style="top: 100px; z-index: 10;">
                <div class="card-body p-0">
                    <div class="p-4 border-bottom" style="border-color: var(--glass-border) !important;">
                        <h6 class="text-uppercase text-light opacity-75 m-0 fw-bold"><i class="bi bi-funnel me-2"></i> Categorías</h6>
                    </div>
                    <div class="list-group list-group-flush list-group-premium">
                        <a href="/landing/catalogo" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(string.IsNullOrEmpty(ViewBag.CategoriaActual) ? "active" : "")">
                            Todos
                            <i class="bi bi-chevron-right small opacity-50"></i>
                        </a>
                        <a href="/landing/catalogo?categoria=Lentes de Sol" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(ViewBag.CategoriaActual == "Lentes de Sol" ? "active" : "")">
                            Lentes de Sol
                            <i class="bi bi-chevron-right small opacity-50"></i>
                        </a>
                        <a href="/landing/catalogo?categoria=Lentes Graduados" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(ViewBag.CategoriaActual == "Lentes Graduados" ? "active" : "")">
                            Lentes Graduados
                            <i class="bi bi-chevron-right small opacity-50"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-9">
            <div class="row g-4 g-lg-4">
                @if (Model.Items != null && Model.Items.Any())
                {
                    @foreach (var prod in Model.Items)
                    {
                        <div class="col-12 col-sm-6 col-xl-4 animate-on-scroll">
                            <div class="card product-card h-100 shadow-sm">
                                <div class="img-wrapper relative">
                                    <img src="@(string.IsNullOrEmpty(prod.RutaImagen) ? "/images/default-product.jpg" : prod.RutaImagen)" alt="@prod.Nombre">
                                </div>
                                <div class="card-body d-flex flex-column p-4">
                                    <h5 class="card-title text-white fw-bold mb-2">@prod.Nombre</h5>
                                    <p class="card-text text-light opacity-75 small mb-4 flex-grow-1">@prod.DescripcionCorta</p>

                                    <div class="d-flex justify-content-between align-items-center mt-auto border-top pt-3" style="border-color: var(--glass-border) !important;">
                                        <span class="price-tag fw-bold">₡@prod.PrecioPublico.ToString("N2")</span>
                                        <a href="/landing/detalle-producto/@prod.Id" class="btn btn-sm btn-outline-light rounded-circle" style="width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;" title="Ver detalles">
                                            <i class="bi bi-arrow-right"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5 animate-on-scroll">
                        <i class="bi bi-emoji-frown display-1 text-light opacity-25 mb-3"></i>
                        <h4 class="text-white">No se encontraron productos</h4>
                        <p class="text-light opacity-75">Intenta buscar en otra categoría.</p>
                    </div>
                }
            </div>

            @{
                var pagination = new OC.Web.Models.PaginationInfo
                {
                    CurrentPage = Model.PageIndex,
                    TotalPages = Model.TotalPages,
                    GetPageUrl = (page) => Url.Action("Catalogo", new { page, categoria = ViewBag.CategoriaActual, busqueda = ViewBag.Busqueda })
                };
            }

            <div class="mt-5 d-flex justify-content-center pagination-premium animate-on-scroll">
                <partial name="_Pagination" model="pagination" />
            </div>

        </div>
    </div>
</div>