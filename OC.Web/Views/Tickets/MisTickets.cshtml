@model OC.Core.Common.PagedResult<OC.Core.Domain.Entities.Ticket>
@using OC.Core.Services
@using OC.Core.Domain.Entities
@{
    ViewData["Title"] = "Mis Tickets";
    var ticketsResueltos = ViewBag.TicketsResueltos as List<Ticket> ?? new List<Ticket>();
    var ticketsActivos = ViewBag.TicketsActivos as List<Ticket> ?? new List<Ticket>();
}

<div class="card-dashboard animate-on-scroll" data-delay="0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4><i class="bi bi-ticket me-2"></i> Mis Tickets de Soporte</h4>
        <a asp-action="Create" class="btn btn-brand btn-ripple">
            <i class="bi bi-plus-lg me-2"></i> Nuevo Ticket
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show animate-fade-up mb-3" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (ticketsActivos.Any())
    {
        <h5 class="mt-3">Tickets activos</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Número</th>
                        <th>Título</th>
                        <th>Prioridad</th>
                        <th>Estado</th>
                        <th>SLA</th>
                        <th>Fecha</th>
                        <th>Técnico</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in ticketsActivos)
                    {
                        var slaStatus = SLAService.ObtenerEstadoSLA(t);
                        var slaClass = SLAService.ObtenerClaseCSS(slaStatus);
                        var slaText = SLAService.ObtenerTextoEstado(slaStatus);
                        <tr class="animate-on-scroll" data-delay="@(ticketsActivos.IndexOf(t) * 30)">
                            <td><strong>@t.NumeroSeguimiento</strong></td>
                            <td>@t.Titulo</td>
                            <td>
                                @if (!string.IsNullOrEmpty(t.Prioridad))
                                {
                                    var priorityClass = t.Prioridad switch
                                    {
                                        "Urgente" => "danger",
                                        "Alta" => "warning text-dark",
                                        "Media" => "info text-dark",
                                        _ => "secondary"
                                    };
                                    <span class="badge bg-@priorityClass">@t.Prioridad</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (t.Estado == "Cerrado")
                                {
                                    <span class="badge bg-success">Cerrado</span>
                                }
                                else if (t.Estado == "Resuelto")
                                {
                                    <span class="badge bg-primary">Resuelto</span>
                                }
                                else if (t.Estado == "En Proceso")
                                {
                                    <span class="badge bg-primary">En Proceso</span>
                                }
                                else if (t.Estado == "Asignado")
                                {
                                    <span class="badge bg-info text-dark">Asignado</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@t.Estado</span>
                                }
                            </td>
                            <td>
                                @if (t.Prioridad != null)
                                {
                                    <span class="@slaClass">@slaText</span>
                                    @if (slaStatus == SLATicketStatus.RespuestaPorVencer && t.FechaRespuestaEsperada.HasValue)
                                    {
                                        <div class="sla-countdown" data-target="@t.FechaRespuestaEsperada.Value.ToString("o")"></div>
                                    }
                                    @if (slaStatus == SLATicketStatus.ResolucionPorVencer && t.FechaResolucionEsperada.HasValue)
                                    {
                                        <div class="sla-countdown" data-target="@t.FechaResolucionEsperada.Value.ToString("o")"></div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>@t.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(t.TecnicoAsignado?.Nombre ?? "Sin asignar")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@t.Id" class="btn btn-sm btn-outline-info" title="Ver detalle">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p>No tienes tickets activos.</p>
    }

    @if (ticketsResueltos.Any())
    {
        <h5 class="mt-5">Tickets resueltos pendientes de calificación</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Número</th>
                        <th>Título</th>
                        <th>Solución aplicada</th>
                        <th>Fecha resolución</th>
                        <th>Calificación</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in ticketsResueltos)
                    {
                        <tr>
                            <td><strong>@t.NumeroSeguimiento</strong></td>
                            <td>@t.Titulo</td>
                            <td>@t.SolucionAplicada</td>
                            <td>@t.FechaResolucion?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <form asp-action="Calificar" method="post" class="row g-2 align-items-end">
                                    <input type="hidden" name="id" value="@t.Id" />
                                    <div class="col-auto">
                                        <select name="calificacion" class="form-select form-select-sm">
                                            <option value="5">⭐⭐⭐⭐⭐ Excelente</option>
                                            <option value="4">⭐⭐⭐⭐ Bueno</option>
                                            <option value="3">⭐⭐⭐ Regular</option>
                                            <option value="2">⭐⭐ Malo</option>
                                            <option value="1">⭐ Pésimo</option>
                                        </select>
                                    </div>
                                    <div class="col-auto">
                                        <input type="text" name="comentario" class="form-control form-control-sm" placeholder="Comentario (opcional)" />
                                    </div>
                                    <div class="col-auto">
                                        <button type="submit" class="btn btn-sm btn-success">Calificar y cerrar</button>
                                    </div>
                                </form>
                            </td>
                            <td>
                                <form asp-action="Reabrir" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@t.Id" />
                                    <input type="text" name="motivo" placeholder="Motivo de reapertura" class="form-control form-control-sm d-inline-block w-auto" required />
                                    <button type="submit" class="btn btn-sm btn-warning">Reabrir ticket</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center mt-4">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" asp-action="MisTickets" asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script>
        anime({
            targets: '.animate-on-scroll',
            opacity: [0, 1],
            translateY: [15, 0],
            delay: function(el, i) { return parseInt(el.getAttribute('data-delay') || i * 30); },
            duration: 500,
            easing: 'easeOutQuad'
        });

        function updateTimers() {
            document.querySelectorAll('.sla-countdown').forEach(el => {
                const target = new Date(el.dataset.target);
                const now = new Date();
                const diff = target - now;
                if (diff <= 0) {
                    el.innerHTML = '<span class="text-danger">Vencido</span>';
                } else {
                    const hours = Math.floor(diff / (1000 * 60 * 60));
                    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                    el.innerHTML = `<i class="bi bi-hourglass-split"></i> ${hours}h ${minutes}m`;
                }
            });
        }
        updateTimers();
        setInterval(updateTimers, 60000);
    </script>
}