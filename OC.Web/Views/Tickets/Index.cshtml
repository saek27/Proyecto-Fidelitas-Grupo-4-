@model OC.Core.Common.PagedResult<OC.Core.Domain.Entities.Ticket>
@using OC.Core.Services
@{
    ViewData["Title"] = "Gestión de Tickets";
}

<div class="card-dashboard animate-on-scroll" data-delay="0">
    <h4 class="mb-4"><i class="bi bi-gear-wide-connected me-2"></i> Gestión de Tickets</h4>

    <form method="get" asp-action="Index" class="row g-3 mb-4 animate-on-scroll" data-delay="100">
        <div class="col-md-3">
            <select name="estado" class="form-select" aria-label="Filtrar por estado">
                <option value="">Todos los estados</option>
                @foreach (var estado in ViewBag.EstadosList as List<SelectListItem>)
                {
                    <option value="@estado.Value" selected="@(ViewBag.EstadoFiltro == estado.Value)">@estado.Text</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <select name="prioridad" class="form-select" aria-label="Filtrar por prioridad">
                <option value="">Todas las prioridades</option>
                @foreach (var prioridad in ViewBag.PrioridadesList as List<SelectListItem>)
                {
                    <option value="@prioridad.Value" selected="@(ViewBag.PrioridadFiltro == prioridad.Value)">@prioridad.Text</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-brand w-100">Filtrar</button>
        </div>
    </form>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show animate-fade-up mb-3" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Items.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox display-1 text-muted"></i>
            <p class="mt-3">No hay tickets que coincidan con los criterios.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Número</th>
                        <th>Título</th>
                        <th>Solicitante</th>
                        <th>Fecha</th>
                        <th>Equipo</th>
                        <th>Estado</th>
                        <th>Prioridad</th>
                        <th>SLA</th>
                        <th>Tipo</th>
                        <th>Técnico</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Items)
                    {
                        var slaStatus = SLAService.ObtenerEstadoSLA(t);
                        var slaClass = SLAService.ObtenerClaseCSS(slaStatus);
                        var slaText = SLAService.ObtenerTextoEstado(slaStatus);
                        <tr class="animate-on-scroll" data-delay="@(Model.Items.ToList().IndexOf(t) * 30)">
                            <td><strong>@t.NumeroSeguimiento</strong></td>
                            <td>@t.Titulo</td>
                            <td>@t.CreadoPor?.Nombre</td>
                            <td>@t.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(t.Equipo != null ? t.Equipo.Nombre : "-")</td>
                            <td>@t.Estado</td>
                            <td>
                                @if (!string.IsNullOrEmpty(t.Prioridad))
                                {
                                    var priorityClass = t.Prioridad switch
                                    {
                                        "Urgente" => "danger",
                                        "Alta" => "warning text-dark",
                                        "Media" => "info text-dark",
                                        _ => "secondary"
                                    };
                                    <span class="badge bg-@priorityClass">@t.Prioridad</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (t.Prioridad != null)
                                {
                                    <span class="@slaClass">@slaText</span>
                                    @if (slaStatus == SLATicketStatus.RespuestaPorVencer && t.FechaRespuestaEsperada.HasValue)
                                    {
                                        <div class="sla-countdown" data-target="@t.FechaRespuestaEsperada.Value.ToString("o")"></div>
                                    }
                                    @if (slaStatus == SLATicketStatus.ResolucionPorVencer && t.FechaResolucionEsperada.HasValue)
                                    {
                                        <div class="sla-countdown" data-target="@t.FechaResolucionEsperada.Value.ToString("o")"></div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>@(t.Tipo ?? "-")</td>
                            <td>@(t.TecnicoAsignado?.Nombre ?? "Sin asignar")</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@t.Id" class="btn btn-sm btn-outline-info" title="Ver">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (t.TecnicoAsignadoId == null || t.Estado == "Pendiente")
                                    {
                                        <a asp-action="Asignar" asp-route-id="@t.Id" class="btn btn-sm btn-outline-primary" title="Asignar">
                                            <i class="bi bi-person-plus"></i>
                                        </a>
                                    }
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-outline-secondary" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center mt-4">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-estado="@ViewBag.EstadoFiltro" asp-route-prioridad="@ViewBag.PrioridadFiltro">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>

@section Scripts {
    <script>
        anime({
            targets: '.animate-on-scroll',
            opacity: [0, 1],
            translateY: [15, 0],
            delay: function(el, i) { return parseInt(el.getAttribute('data-delay') || i * 30); },
            duration: 500,
            easing: 'easeOutQuad'
        });

        function updateTimers() {
            document.querySelectorAll('.sla-countdown').forEach(el => {
                const target = new Date(el.dataset.target);
                const now = new Date();
                const diff = target - now;
                if (diff <= 0) {
                    el.innerHTML = '<span class="text-danger">Vencido</span>';
                } else {
                    const hours = Math.floor(diff / (1000 * 60 * 60));
                    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                    el.innerHTML = `<i class="bi bi-hourglass-split"></i> ${hours}h ${minutes}m`;
                }
            });
        }
        updateTimers();
        setInterval(updateTimers, 60000);
    </script>
}