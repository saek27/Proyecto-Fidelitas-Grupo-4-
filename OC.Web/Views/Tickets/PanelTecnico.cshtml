@model OC.Core.Common.PagedResult<OC.Core.Domain.Entities.Ticket>
@using OC.Core.Services
@{
    ViewData["Title"] = "Panel de Técnico";
}

<div class="card-dashboard animate-on-scroll" data-delay="0">
    <h4 class="mb-4"><i class="bi bi-tools me-2"></i> Panel de Técnico - Tickets</h4>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show animate-fade-up mb-3" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show animate-fade-up mb-3" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Items.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-check-circle display-1 text-muted"></i>
            <p class="mt-3">No hay tickets pendientes o asignados a usted.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Número</th>
                        <th>Título</th>
                        <th>Solicitante</th>
                        <th>Prioridad</th>
                        <th>Estado</th>
                        <th>SLA</th>
                        <th>Fecha</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Items)
                    {
                        var slaStatus = SLAService.ObtenerEstadoSLA(t);
                        var slaClass = SLAService.ObtenerClaseCSS(slaStatus);
                        var slaText = SLAService.ObtenerTextoEstado(slaStatus);
                        <tr class="animate-on-scroll" data-delay="@(Model.Items.ToList().IndexOf(t) * 30)">
                            <td><strong>@t.NumeroSeguimiento</strong></td>
                            <td>@t.Titulo</td>
                            <td>@t.CreadoPor?.Nombre</td>
                            <td>
                                @if (!string.IsNullOrEmpty(t.Prioridad))
                                {
                                    var priorityClass = t.Prioridad switch
                                    {
                                        "Urgente" => "danger",
                                        "Alta" => "warning text-dark",
                                        "Media" => "info text-dark",
                                        _ => "secondary"
                                    };
                                    <span class="badge bg-@priorityClass">@t.Prioridad</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (t.Estado == "Cerrado")
                                {
                                    <span class="badge bg-success">Cerrado</span>
                                }
                                else if (t.Estado == "Resuelto")
                                {
                                    <span class="badge bg-primary">Resuelto</span>
                                }
                                else if (t.Estado == "En Proceso")
                                {
                                    <span class="badge bg-primary">En Proceso</span>
                                }
                                else if (t.Estado == "Asignado")
                                {
                                    <span class="badge bg-info text-dark">Asignado</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@t.Estado</span>
                                }
                            </td>
                            <td>
                                @if (t.Prioridad != null)
                                {
                                    <span class="@slaClass">@slaText</span>
                                    @if (slaStatus == SLATicketStatus.RespuestaPorVencer && t.FechaRespuestaEsperada.HasValue)
                                    {
                                        <div class="sla-countdown" data-target="@t.FechaRespuestaEsperada.Value.ToString("o")"></div>
                                    }
                                    @if (slaStatus == SLATicketStatus.ResolucionPorVencer && t.FechaResolucionEsperada.HasValue)
                                    {
                                        <div class="sla-countdown" data-target="@t.FechaResolucionEsperada.Value.ToString("o")"></div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>@t.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@t.Id" class="btn btn-sm btn-outline-info" title="Ver">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    @if (t.TecnicoAsignadoId == null)
                                    {
                                        <form asp-action="TomarTicket" asp-route-id="@t.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Tomar ticket">
                                                <i class="bi bi-hand-index-thumb"></i> Tomar
                                            </button>
                                        </form>
                                    }
                                    @if (t.TecnicoAsignadoId.ToString() == User.FindFirst("UserId")?.Value)
                                    {
                                        @if (t.Estado != "Resuelto" && t.Estado != "Cerrado")
                                        {
                                            <a asp-action="Clasificar" asp-route-id="@t.Id" class="btn btn-sm btn-outline-warning" title="Clasificar">
                                                <i class="bi bi-tags"></i>
                                            </a>
                                            @if (t.Estado == "Asignado" || t.Estado == "En Proceso")
                                            {
                                                <a asp-action="Resolver" asp-route-id="@t.Id" class="btn btn-sm btn-outline-primary" title="Resolver">
                                                    <i class="bi bi-check-lg"></i>
                                                </a>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary ms-2">Asignado a otro</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center mt-4">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link" asp-action="PanelTecnico" asp-route-page="@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>

@section Scripts {
    <script>
        anime({
            targets: '.animate-on-scroll',
            opacity: [0, 1],
            translateY: [15, 0],
            delay: function(el, i) { return parseInt(el.getAttribute('data-delay') || i * 30); },
            duration: 500,
            easing: 'easeOutQuad'
        });

        function updateTimers() {
            document.querySelectorAll('.sla-countdown').forEach(el => {
                const target = new Date(el.dataset.target);
                const now = new Date();
                const diff = target - now;
                if (diff <= 0) {
                    el.innerHTML = '<span class="text-danger">Vencido</span>';
                } else {
                    const hours = Math.floor(diff / (1000 * 60 * 60));
                    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                    el.innerHTML = `<i class="bi bi-hourglass-split"></i> ${hours}h ${minutes}m`;
                }
            });
        }
        updateTimers();
        setInterval(updateTimers, 60000);
    </script>
}