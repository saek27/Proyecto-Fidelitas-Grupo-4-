@model OC.Core.Domain.Entities.OrdenTrabajo

<div class="card-dashboard">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Detalle de orden de lentes</h4>
        <a asp-action="EstadoOrden" class="btn btn-secondary btn-sm">Volver</a>
    </div>

    @if (Model.Estado == OC.Core.Domain.Entities.EstadoOrdenTrabajo.Lista)
    {
        <div class="alert alert-success">
            Su orden está lista para retiro en <strong>@(Model.Sucursal?.Nombre ?? "la sede")</strong>.
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            La orden no está lista o no existe.
        </div>
    }

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <div class="text-muted small">Estado</div>
                    <div class="fw-bold">@Model.Estado</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <div class="text-muted small">Sucursal</div>
                    <div class="fw-bold">@(Model.Sucursal?.Nombre ?? "—")</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <div class="text-muted small">Fecha de creación</div>
                    <div class="fw-bold">@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Referencia))
    {
        <hr class="my-3" />
        <div>
            <div class="text-muted small">Referencia</div>
            <div>@Model.Referencia</div>
        </div>
    }
</div>

