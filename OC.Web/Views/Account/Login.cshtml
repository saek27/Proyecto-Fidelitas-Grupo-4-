@model OC.Web.ViewModels.LoginViewModel
@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Óptica Comunal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="bg-light">
    <div class="container">
        <div class="row justify-content-center align-items-center vh-100">
            <div class="col-md-4">
                <div class="card shadow-lg border-0">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <h2 class="text-primary fw-bold">Óptica Comunal</h2>
                            <p class="text-muted">Inicia sesión para continuar</p>
                        </div>

                        <form asp-action="Login" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            @if (ViewBag.AttemptsLeft != null)
                            {
                                <div class="alert alert-warning py-2 small">
                                    Tiene <strong>@ViewBag.AttemptsLeft</strong> intento(s) restante(s) antes del bloqueo.
                                </div>
                            }
                            @if (ViewBag.LockoutSeconds != null)
                            {
                                <div class="alert alert-danger py-2 small">
                                    Usuario bloqueado. Espere <strong id="lockoutTimer"></strong>.
                                </div>
                            }

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label">Correo</label>
                                <input asp-for="Email" class="form-control" placeholder=" " />
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label">Contraseña</label>
                                <input asp-for="Password" type="password" class="form-control" />
                            </div>

                            <div class="mb-3 form-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label class="form-check-label" asp-for="RememberMe">Recordarme</label>
                            </div>

                            <div class="mb-3">
                                <a asp-controller="PacienteAccount" asp-action="RecuperarContrasena" class="small text-muted">¿Olvidó su contraseña?</a>
                            </div>

                            <div class="d-grid mb-3">
                                <button type="submit" class="btn btn-brand text-white btn-lg">Entrar</button>
                            </div>

                            <div class="text-center">
                                <hr class="my-3" />
                                <p class="text-muted mb-2">¿Eres paciente y no tienes cuenta?</p>
                                <a asp-controller="Pacientes" asp-action="Registro" class="btn btn-outline-primary">
                                    <i class="bi bi-person-plus"></i> Registrarse como Paciente
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (ViewBag.LockoutSeconds != null)
    {
        <script>
            (function () {
                var seconds = parseInt("@ViewBag.LockoutSeconds", 10);
                if (isNaN(seconds) || seconds <= 0) return;

                function fmt(s) {
                    var m = Math.floor(s / 60);
                    var r = s % 60;
                    return m + ":" + (r < 10 ? "0" + r : r);
                }

                var el = document.getElementById("lockoutTimer");
                if (!el) return;
                el.textContent = fmt(seconds);

                var t = setInterval(function () {
                    seconds--;
                    if (seconds <= 0) {
                        clearInterval(t);
                        el.textContent = "0:00";
                        return;
                    }
                    el.textContent = fmt(seconds);
                }, 1000);
            })();
        </script>
    }
</body>
</html>
