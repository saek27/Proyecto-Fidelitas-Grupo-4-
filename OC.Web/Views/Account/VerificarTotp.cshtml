@model OC.Web.ViewModels.ValidarTotpViewModel
@{
    Layout = "_AuthSimplePage";
    ViewData["Title"] = "Código autenticador";
    var postAction = ViewBag.TotpPostAction as string ?? "VerificarTotpStaff";
}

<div class="text-center mb-4">
    <div class="login-logo mx-auto mb-3" style="width:56px;height:56px;border-radius:14px;background:linear-gradient(135deg,#3b82f6,#06b6d4);display:flex;align-items:center;justify-content:center;">
        <i class="bi bi-shield-lock-fill fs-4"></i>
    </div>
    <h4 class="mb-1">Verificación en dos pasos</h4>
    <p class="text-muted small mb-0">Ingrese el código de 6 dígitos de Microsoft Authenticator u otra app compatible.</p>
</div>

<form asp-action="@postAction" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
    <div class="mb-3">
        <label asp-for="Codigo" class="form-label"></label>
        <input asp-for="Codigo" class="form-control text-center" maxlength="6" placeholder="123456" autocomplete="one-time-code" style="font-size:1.4rem;letter-spacing:4px;" />
        <span asp-validation-for="Codigo" class="text-danger small"></span>
    </div>
    <button type="submit" class="btn btn-primary w-100 mb-2">Continuar</button>
    <a asp-action="Login" class="btn btn-outline-light w-100 btn-sm">Volver al inicio de sesión</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
