@model OC.Core.Common.PagedResult<OC.Core.Domain.Entities.SolicitudCita>
@{
    ViewData["Title"] = "Solicitudes de Cita";
}

<div class="container-fluid px-4">
    <div class="page-header animate-fade-up">
        <div class="page-header-text">
            <div class="page-header-icon"><i class="bi bi-calendar-plus"></i></div>
            <div>
                <h1 class="page-title">Solicitudes de Cita</h1>
                <p class="page-subtitle">
                    <i class="bi bi-info-circle me-1"></i>
                    @(Model.TotalCount == 0 ? "Sin solicitudes." : $"{Model.TotalCount} solicitud(es) en revisión.")
                </p>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show animate-fade-up mb-3" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (ViewBag.PendientesCount > 0)
    {
        <div class="alert alert-info d-flex align-items-center animate-fade-up mb-3">
            <i class="bi bi-bell-fill me-2"></i>
            <strong>Tiene @ViewBag.PendientesCount solicitud(es) pendiente(s) de revisar</strong>
        </div>
    }

    <div class="card-dashboard animate-fade-up delay-1">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Paciente</th>
                            <th>Cédula</th>
                            <th>Contacto</th>
                            <th>Fecha de Solicitud</th>
                            <th>Motivo</th>
                            <th class="text-center" style="width:120px">Estado</th>
                            <th class="text-center" style="width:160px">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="entity-cell">
                                        <div class="entity-avatar bg-info-subtle text-info-emphasis">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                        <div>
                                            <div class="fw-semibold">@s.Paciente.NombreCompleto</div>
                                            <div class="text-muted small">Solicitud #@s.Id</div>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="text-muted">@s.Paciente.Cedula</span></td>
                                <td>
                                    <div class="contact-line">
                                        <i class="bi bi-envelope-fill text-primary"></i>
                                        <a href="mailto:@s.Paciente.Email">@(s.Paciente.Email ?? "—")</a>
                                    </div>
                                    <div class="contact-line">
                                        <i class="bi bi-telephone-fill text-success"></i>
                                        <a href="tel:@s.Paciente.Telefono">@(s.Paciente.Telefono ?? "—")</a>
                                    </div>
                                </td>
                                <td>@s.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-muted">@(s.Motivo ?? "Sin motivo especificado")</td>
                                <td class="text-center">
                                    <span class="status-badge" style="background:rgba(245,158,11,.12);color:#92400e;">
                                        <i class="bi bi-clock"></i> @s.Estado
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="action-buttons">
                                        <a asp-action="Agendar" asp-route-id="@s.Id"
                                           class="btn-action btn-action-success" title="Agendar">
                                            <i class="bi bi-calendar-check"></i>
                                        </a>
                                        <form asp-action="Rechazar" asp-route-id="@s.Id" method="post"
                                              class="d-inline" onsubmit="return confirm('¿Rechazar esta solicitud?');">
                                            <button type="submit" class="btn-action btn-action-danger" title="Rechazar">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Items.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-calendar-plus"></i></div>
                    <h5 class="empty-state-title">No hay solicitudes pendientes</h5>
                    <p class="empty-state-text">Cuando un paciente solicite una cita, aparecerá aquí para revisarla.</p>
                </div>
            }
        </div>
    </div>
</div>
