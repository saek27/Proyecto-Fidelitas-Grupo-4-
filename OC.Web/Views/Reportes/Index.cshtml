@{
    ViewData["Title"] = "Reportes Gerenciales";
}

<style>
    :root {
        --rpt-navy: #1d2452;
        --rpt-navy-mid: #2a3466;
        --rpt-blue: #3b82f6;
        --rpt-amber: #d4a843;
        --rpt-amber-dark: #a8852e;
        --rpt-bg: #f1f5f9;
        --rpt-card: #ffffff;
        --rpt-text: #1e293b;
        --rpt-muted: #64748b;
        --rpt-success: #10b981;
        --rpt-danger: #ef4444;
    }

    body { background: var(--rpt-bg); }

    .rpt-page-header {
        background: linear-gradient(135deg, var(--rpt-navy) 0%, var(--rpt-navy-mid) 100%);
        color: white;
        padding: 1.5rem 2rem;
        border-radius: .75rem .75rem 0 0;
        margin-bottom: 0;
    }

    .rpt-body {
        background: var(--rpt-bg);
        padding: 1.5rem 2rem 2rem;
        border-radius: 0 0 .75rem .75rem;
    }

    .report-card {
        border: none;
        border-radius: .6rem;
        overflow: hidden;
        background: var(--rpt-card);
        transition: transform .2s ease, box-shadow .2s ease;
        box-shadow: 0 2px 12px rgba(15,23,42,.10);
        cursor: pointer;
        height: 100%;
    }

    .report-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 30px rgba(15,23,42,.20);
    }

    .report-card .card-body { padding: 1.5rem 1.5rem 1rem; }

    .report-card .card-footer {
        border: none;
        padding: .75rem 1.5rem;
        font-weight: 600;
        letter-spacing: .03em;
        font-size: .82rem;
        text-transform: uppercase;
    }

    .rpt-icon-wrap {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto .8rem;
        font-size: 1.5rem;
    }

    .rpt-card-ventas .rpt-icon-wrap { background: rgba(59,130,246,.12); color: var(--rpt-blue); }
    .rpt-card-fideliz .rpt-icon-wrap { background: rgba(212,168,67,.12); color: var(--rpt-amber); }
    .rpt-card-demanda .rpt-icon-wrap { background: rgba(16,185,129,.10); color: var(--rpt-success); }

    .rpt-card-ventas .card-footer { background: var(--rpt-navy-mid); color: white; }
    .rpt-card-fideliz .card-footer { background: var(--rpt-amber); color: var(--rpt-text); }
    .rpt-card-demanda .card-footer { background: var(--rpt-navy-mid); color: white; }

    .rpt-title { font-weight: 700; font-size: 1rem; color: var(--rpt-text); margin-bottom: .4rem; }
    .rpt-desc { font-size: .83rem; color: var(--rpt-muted); line-height: 1.4; margin: 0; }
</style>

<div class="container-fluid px-4">
    <div class="page-header animate-fade-up">
        <div class="page-header-text">
            <div class="page-header-icon"><i class="bi bi-bar-chart-line"></i></div>
            <div>
                <h1 class="page-title">Reportes Gerenciales</h1>
                <p class="page-subtitle">
                    <i class="bi bi-info-circle me-1"></i> Selecciona el reporte que querés generar.
                </p>
            </div>
        </div>
    </div>

    <div class="rpt-page-header mb-3">
        <div class="d-flex align-items-center gap-3">
            <div>
                <h2 class="mb-0 fw-bold"><i class="bi bi-bar-chart-line-fill me-2" style="color:var(--rpt-amber)"></i>Reportes</h2>
                <p class="mb-0 opacity-75" style="font-size:.9rem">Seleccioná el reporte que querés generar.</p>
            </div>
        </div>
    </div>

    <div class="rpt-body">

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row g-4">

            <div class="col-md-4">
                <a asp-action="Ventas" class="text-decoration-none">
                    <div class="report-card rpt-card-ventas">
                        <div class="card-body text-center">
                            <div class="rpt-icon-wrap"><i class="bi bi-graph-up-arrow"></i></div>
                            <div class="rpt-title">Ventas</div>
                            <p class="rpt-desc">Ingresos por período, sucursal y método de pago. Top productos.</p>
                        </div>
                        <div class="card-footer text-center">
                            Ver reporte <i class="bi bi-arrow-right ms-1"></i>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a asp-action="Fidelizacion" class="text-decoration-none">
                    <div class="report-card rpt-card-fideliz">
                        <div class="card-body text-center">
                            <div class="rpt-icon-wrap"><i class="bi bi-people-fill"></i></div>
                            <div class="rpt-title">Fidelización</div>
                            <p class="rpt-desc">Clasificación de pacientes: nuevos, regulares y frecuentes por período.</p>
                        </div>
                        <div class="card-footer text-center">
                            Ver reporte <i class="bi bi-arrow-right ms-1"></i>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a asp-action="Demanda" class="text-decoration-none">
                    <div class="report-card rpt-card-demanda">
                        <div class="card-body text-center">
                            <div class="rpt-icon-wrap"><i class="bi bi-calendar-check-fill"></i></div>
                            <div class="rpt-title">Demanda y Citas</div>
                            <p class="rpt-desc">Citas agendadas, atendidas y canceladas por mes y sucursal.</p>
                        </div>
                        <div class="card-footer text-center">
                            Ver reporte <i class="bi bi-arrow-right ms-1"></i>
                        </div>
                    </div>
                </a>
            </div>

        </div>
    </div>
</div>