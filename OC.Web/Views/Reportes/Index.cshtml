@{
    ViewData["Title"] = "Reportes Gerenciales";
}

<div class="card-dashboard">
    <h4 class="mb-1"><i class="bi bi-bar-chart-line me-2"></i>Reportes Gerenciales</h4>
    <p class="text-muted mb-4">Seleccioná el reporte que querés generar.</p>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-3">
        <div class="col-md-4">
            <a asp-action="Ventas" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm report-card">
                    <div class="card-body text-center py-4">
                        <div class="mb-3">
                            <i class="bi bi-graph-up-arrow text-primary" style="font-size:2.5rem;"></i>
                        </div>
                        <h5 class="fw-bold">Ventas</h5>
                        <p class="text-muted small mb-0">
                            Ingresos por período, sucursal y método de pago.
                            Top productos.
                        </p>
                    </div>
                    <div class="card-footer bg-primary text-white text-center py-2 small fw-semibold">
                        Ver reporte →
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-action="Fidelizacion" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm report-card">
                    <div class="card-body text-center py-4">
                        <div class="mb-3">
                            <i class="bi bi-people text-success" style="font-size:2.5rem;"></i>
                        </div>
                        <h5 class="fw-bold">Fidelización</h5>
                        <p class="text-muted small mb-0">
                            Clasificación de pacientes: nuevos, regulares y frecuentes por período.
                        </p>
                    </div>
                    <div class="card-footer bg-success text-white text-center py-2 small fw-semibold">
                        Ver reporte →
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-action="Demanda" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm report-card">
                    <div class="card-body text-center py-4">
                        <div class="mb-3">
                            <i class="bi bi-calendar-check text-warning" style="font-size:2.5rem;"></i>
                        </div>
                        <h5 class="fw-bold">Demanda y Citas</h5>
                        <p class="text-muted small mb-0">
                            Citas agendadas, atendidas y canceladas por mes y sucursal.
                        </p>
                    </div>
                    <div class="card-footer bg-warning text-dark text-center py-2 small fw-semibold">
                        Ver reporte →
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    .report-card {
        transition: transform .15s, box-shadow .15s;
        cursor: pointer;
    }

        .report-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(0,0,0,.12) !important;
        }
</style>