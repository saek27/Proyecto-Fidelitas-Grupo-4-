@model OC.Web.ViewModels.ReporteFidelizacionViewModel
@{
    ViewData["Title"] = "Reporte de Fidelización";
    var labPie = System.Text.Json.JsonSerializer.Serialize(new[] { "Nuevo", "Regular", "Frecuente", "Esporádico" });
    var datPie = System.Text.Json.JsonSerializer.Serialize(new[] {
        Model.TotalNuevos, Model.TotalRegulares, Model.TotalFrecuentes, Model.TotalEsporadicos
    });
}

<div class="card-dashboard">

    @* ── Toolbar ────────────────────────────────────────────────────────────── *@
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div class="d-flex align-items-center gap-2">
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left"></i>
            </a>
            <span class="fs-5 fw-bold">
                <i class="bi bi-people me-2 text-success"></i>Reporte de Fidelización
            </span>
        </div>

        <form method="get" asp-action="Fidelizacion"
              class="d-flex flex-wrap align-items-center gap-2">
            <input type="date" name="desde" class="form-control form-control-sm"
                   style="width:140px"
                   value="@Model.Desde?.ToString("yyyy-MM-dd")" />
            <input type="date" name="hasta" class="form-control form-control-sm"
                   style="width:140px"
                   value="@Model.Hasta?.ToString("yyyy-MM-dd")" />
            <select name="sucursalId" class="form-select form-select-sm" style="width:160px">
                <option value="">Todas las sucursales</option>
                @foreach (var s in Model.Sucursales)
                {
                    <option value="@s.Id" selected="@(Model.SucursalId == s.Id)">@s.Nombre</option>
                }
            </select>
            <button type="submit" class="btn btn-success btn-sm">
                <i class="bi bi-funnel me-1"></i>Filtrar
            </button>
            <a asp-action="ExportarFidelizacionExcel"
               asp-route-desde="@Model.Desde?.ToString("yyyy-MM-dd")"
               asp-route-hasta="@Model.Hasta?.ToString("yyyy-MM-dd")"
               asp-route-sucursalId="@Model.SucursalId"
               class="btn btn-sm btn-outline-success">
                <i class="bi bi-file-earmark-excel me-1"></i>Exportar
            </a>
        </form>
    </div>

    @* ── Contenido principal ─────────────────────────────────────────────────── *@
    <div class="row g-3">

        @* ── Columna izquierda: KPIs + gráfica ─────────────────────────────── *@
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 h-100">

                @* KPIs 2×2 *@
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <div class="rounded p-2 text-center" style="background:#fff3cd;">
                            <div class="fs-4 fw-bold text-warning">@Model.TotalNuevos</div>
                            <div class="small text-muted">Nuevos</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="rounded p-2 text-center" style="background:#cce5ff;">
                            <div class="fs-4 fw-bold text-primary">@Model.TotalRegulares</div>
                            <div class="small text-muted">Regulares</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="rounded p-2 text-center" style="background:#d4edda;">
                            <div class="fs-4 fw-bold text-success">@Model.TotalFrecuentes</div>
                            <div class="small text-muted">Frecuentes</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="rounded p-2 text-center" style="background:#f8f9fa;">
                            <div class="fs-4 fw-bold text-secondary">@Model.TotalEsporadicos</div>
                            <div class="small text-muted">Esporádicos</div>
                        </div>
                    </div>
                </div>

                @* Gráfica *@
                <canvas id="chartFidelizacion"></canvas>

                @* Leyenda *@
                <div class="mt-3 small">
                    <div class="d-flex align-items-center mb-1 gap-2">
                        <span class="badge" style="background:#ffc107; color:#000;">Nuevo</span>
                        Registrado en el último mes del período
                    </div>
                    <div class="d-flex align-items-center mb-1 gap-2">
                        <span class="badge bg-primary">Regular</span>
                        2–3 visitas en el período
                    </div>
                    <div class="d-flex align-items-center mb-1 gap-2">
                        <span class="badge bg-success">Frecuente</span>
                        4+ visitas en el período
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-secondary">Esporádico</span>
                        1 visita, no es nuevo
                    </div>
                </div>
            </div>
        </div>

        @* ── Columna derecha: tabla ──────────────────────────────────────────── *@
        <div class="col-md-8">
            <div class="card border-0 shadow-sm p-3 h-100">
                <h6 class="fw-bold mb-2">Detalle por paciente</h6>

                <input type="text" id="filtroPaciente"
                       class="form-control form-control-sm mb-2"
                       placeholder="Buscar paciente o cédula...">

                <div style="max-height:460px; overflow-y:auto;">
                    <table class="table table-sm table-hover mb-0" id="tablaFidelizacion">
                        <thead class="table-dark sticky-top">
                            <tr>
                                <th>Paciente</th>
                                <th>Cédula</th>
                                <th class="text-center">Visitas</th>
                                <th>Última visita</th>
                                <th>Categoría</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Detalle)
                            {
                                var badgeClass = p.Clasificacion switch
                                {
                                            "Frecuente" => "bg-success",
                                            "Regular" => "bg-primary",
                                            "Nuevo" => "bg-warning text-dark",
                                    _ => "bg-secondary"
                                };
                                <tr>
                                    <td>@p.NombreCompleto</td>
                                    <td class="text-muted">@p.Cedula</td>
                                    <td class="text-center fw-bold">@p.VisitasEnPeriodo</td>
                                    <td>@p.UltimaVisita.ToString("dd/MM/yyyy")</td>
                                    <td><span class="badge @badgeClass">@p.Clasificacion</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <script>
        new Chart(document.getElementById('chartFidelizacion'), {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(labPie),
                datasets: [{
                    data: @Html.Raw(datPie),
                    backgroundColor: ['#ffc107', '#1a3c6e', '#28a745', '#6c757d'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                cutout: '60%',
                plugins: {
                    legend: { display: false }
                }
            }
        });

        document.getElementById('filtroPaciente').addEventListener('input', function () {
            const q = this.value.toLowerCase();
            document.querySelectorAll('#tablaFidelizacion tbody tr').forEach(tr => {
                tr.style.display = tr.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        });
    </script>
}