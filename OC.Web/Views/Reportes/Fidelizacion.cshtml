@model OC.Web.ViewModels.ReporteFidelizacionViewModel
@{
    ViewData["Title"] = "Reporte de Fidelización";
    var labPie = System.Text.Json.JsonSerializer.Serialize(new[] { "Nuevo", "Regular", "Frecuente", "Esporádico" });
    var datPie = System.Text.Json.JsonSerializer.Serialize(new[] {
        Model.TotalNuevos, Model.TotalRegulares, Model.TotalFrecuentes, Model.TotalEsporadicos
    });
}

<div class="card-dashboard">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-2">
                <i class="bi bi-arrow-left"></i>
            </a>
            <span class="fs-5 fw-bold"><i class="bi bi-people me-2 text-success"></i>Reporte de Fidelización</span>
        </div>
        <a asp-action="ExportarFidelizacionExcel"
           asp-route-desde="@Model.Desde?.ToString("yyyy-MM-dd")"
           asp-route-hasta="@Model.Hasta?.ToString("yyyy-MM-dd")"
           asp-route-sucursalId="@Model.SucursalId"
           class="btn btn-sm btn-success">
            <i class="bi bi-file-earmark-excel me-1"></i>Exportar Excel
        </a>
    </div>

    @* ── Filtros ─────────────────────────────────────────────────────────── *@
    <form method="get" asp-action="Fidelizacion" class="card bg-light border-0 mb-4">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label form-label-sm mb-1">Desde</label>
                    <input type="date" name="desde" class="form-control form-control-sm"
                           value="@Model.Desde?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm mb-1">Hasta</label>
                    <input type="date" name="hasta" class="form-control form-control-sm"
                           value="@Model.Hasta?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm mb-1">Sucursal</label>
                    <select name="sucursalId" class="form-select form-select-sm">
                        <option value="">Todas</option>
                        @foreach (var s in Model.Sucursales)
                        {
                            <option value="@s.Id" selected="@(Model.SucursalId == s.Id)">@s.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-success btn-sm w-100">
                        <i class="bi bi-funnel me-1"></i>Filtrar
                    </button>
                </div>
            </div>
        </div>
    </form>

    @* ── KPIs ──────────────────────────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 text-center py-3" style="background:#fff3cd;">
                <div class="fs-2 fw-bold text-warning">@Model.TotalNuevos</div>
                <div class="small text-muted">🆕 Nuevos</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 text-center py-3" style="background:#cce5ff;">
                <div class="fs-2 fw-bold text-primary">@Model.TotalRegulares</div>
                <div class="small text-muted">🔄 Regulares</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 text-center py-3" style="background:#d4edda;">
                <div class="fs-2 fw-bold text-success">@Model.TotalFrecuentes</div>
                <div class="small text-muted">⭐ Frecuentes</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 text-center py-3" style="background:#f8f9fa;">
                <div class="fs-2 fw-bold text-secondary">@Model.TotalEsporadicos</div>
                <div class="small text-muted">👤 Esporádicos</div>
            </div>
        </div>
    </div>

    @* ── Gráfica + tabla ───────────────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 h-100">
                <h6 class="fw-bold mb-3">Distribución por categoría</h6>
                <canvas id="chartFidelizacion"></canvas>
                <div class="mt-3 small">
                    <div class="d-flex align-items-center mb-1">
                        <span class="badge me-2" style="background:#ffc107;">Nuevo</span>
                        Registrado en el último mes del período
                    </div>
                    <div class="d-flex align-items-center mb-1">
                        <span class="badge bg-primary me-2">Regular</span>
                        2–3 visitas en el período
                    </div>
                    <div class="d-flex align-items-center mb-1">
                        <span class="badge bg-success me-2">Frecuente</span>
                        4+ visitas en el período
                    </div>
                    <div class="d-flex align-items-center">
                        <span class="badge bg-secondary me-2">Esporádico</span>
                        1 visita, no es nuevo
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-0 shadow-sm p-3 h-100">
                <h6 class="fw-bold mb-3">Detalle por paciente</h6>

                @* Filtro client-side *@
                <input type="text" id="filtroPaciente" class="form-control form-control-sm mb-2"
                       placeholder="Buscar paciente...">

                <div style="max-height:400px; overflow-y:auto;">
                    <table class="table table-sm table-hover" id="tablaFidelizacion">
                        <thead class="table-dark sticky-top">
                            <tr>
                                <th>Paciente</th>
                                <th>Cédula</th>
                                <th class="text-center">Visitas</th>
                                <th>Última visita</th>
                                <th>Categoría</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Detalle)
                            {
                                var badgeClass = p.Clasificacion switch
                                {
                                            "Frecuente" => "bg-success",
                                            "Regular" => "bg-primary",
                                            "Nuevo" => "bg-warning text-dark",
                                    _ => "bg-secondary"
                                };
                                <tr>
                                    <td>@p.NombreCompleto</td>
                                    <td>@p.Cedula</td>
                                    <td class="text-center fw-bold">@p.VisitasEnPeriodo</td>
                                    <td>@p.UltimaVisita.ToString("dd/MM/yyyy")</td>
                                    <td><span class="badge @badgeClass">@p.Clasificacion</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <script>
        new Chart(document.getElementById('chartFidelizacion'), {
            type: 'pie',
            data: {
                labels: @Html.Raw(labPie),
                datasets: [{
                    data: @Html.Raw(datPie),
                    backgroundColor: ['#ffc107','#1a3c6e','#28a745','#6c757d']
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom' } }
            }
        });

        @* Filtro en tabla *@
        document.getElementById('filtroPaciente').addEventListener('input', function () {
            const q = this.value.toLowerCase();
            document.querySelectorAll('#tablaFidelizacion tbody tr').forEach(tr => {
                tr.style.display = tr.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        });
    </script>
}