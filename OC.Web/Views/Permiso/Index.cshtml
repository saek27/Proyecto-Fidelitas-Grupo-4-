@using OC.Core.Domain.Entities
@model OC.Core.Common.PagedResult<Permiso>
@{
    ViewData["Title"] = "Permisos";
    var pagination = new PaginationInfo
    {
        CurrentPage = Model.PageIndex,
        TotalPages = Model.TotalPages,
        GetPageUrl = (page) => Url.Action("Index", new { page })
    };
}

<div class="container-fluid px-4">
    <div class="page-header animate-fade-up">
        <div class="page-header-text">
            <div class="page-header-icon"><i class="bi bi-clock-history"></i></div>
            <div>
                <h1 class="page-title">Permisos</h1>
                <p class="page-subtitle">
                    <i class="bi bi-info-circle me-1"></i>
                    @(Model.TotalCount == 0 ? "Sin permisos registrados." : $"{Model.TotalCount} solicitud(es) de permiso.")
                </p>
            </div>
        </div>
        <div class="page-actions">
            <a asp-action="Create" class="btn btn-brand">
                <i class="bi bi-plus-circle me-1"></i> Solicitar permiso
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show animate-fade-up mb-3" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card-dashboard animate-fade-up delay-1">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Usuario</th>
                            <th>Tipo</th>
                            <th>Fechas</th>
                            <th>Motivo</th>
                            <th>Documento</th>
                            <th class="text-center" style="width:120px">Estado</th>
                            <th>Aprobado por</th>
                            <th class="text-center" style="width:100px">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Items)
                        {
                            <tr>
                                <td>@p.Usuario?.Nombre</td>
                                <td>@p.Tipo</td>
                                <td>
                                    <span class="text-nowrap">@p.FechaInicio.ToString("dd/MM/yyyy")</span>
                                    —
                                    <span class="text-nowrap">@p.FechaFin.ToString("dd/MM/yyyy")</span>
                                </td>
                                <td class="text-muted">@p.Motivo</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(p.RutaDocumentoIncapacidad))
                                    {
                                        <a href="@p.RutaDocumentoIncapacidad" target="_blank" rel="noopener"
                                           class="btn-action btn-action-info" title="Ver documento">
                                            <i class="bi bi-file-earmark-text"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @switch (p.Estado)
                                    {
                                        case "Aprobado":
                                            <span class="status-badge status-badge-active">
                                                <i class="bi bi-check-circle-fill"></i> Aprobado
                                            </span>
                                            break;
                                        case "Rechazado":
                                            <span class="status-badge" style="background:rgba(239,68,68,.12);color:#991b1b;">
                                                <i class="bi bi-x-circle-fill"></i> Rechazado
                                            </span>
                                            break;
                                        default:
                                            <span class="status-badge" style="background:rgba(245,158,11,.12);color:#92400e;">
                                                <i class="bi bi-clock"></i> Pendiente
                                            </span>
                                            break;
                                    }
                                </td>
                                <td>@(p.AprobadoPor?.Nombre ?? "—")</td>
                                <td class="text-center">
                                    @if (User.IsInRole("Admin") && p.Estado == "Pendiente")
                                    {
                                        <div class="action-buttons">
                                            <form asp-action="Aprobar" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@p.Id" />
                                                <button type="submit" class="btn-action btn-action-success" title="Aprobar">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                            </form>
                                            <form asp-action="Rechazar" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@p.Id" />
                                                <button type="submit" class="btn-action btn-action-danger" title="Rechazar">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Items.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-clock-history"></i></div>
                    <h5 class="empty-state-title">No hay permisos registrados</h5>
                    <p class="empty-state-text">Cuando un usuario solicite un permiso, aparecerá aquí.</p>
                </div>
            }
        </div>
    </div>

    @await Html.PartialAsync("_Pagination", pagination)
</div>
