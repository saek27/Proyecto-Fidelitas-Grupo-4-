@using OC.Core.Domain.Entities
@model OC.Core.Common.PagedResult<Permiso>

@{
    ViewData["Title"] = "Permisos";

    var pagination = new PaginationInfo
    {
        CurrentPage = Model.PageIndex,
        TotalPages = Model.TotalPages,
        GetPageUrl = (page) => Url.Action("Index", new { page })
    };
}

<div class="card-dashboard page-fade">
<h4 class="mb-3"><i class="bi bi-clock-history me-2"></i>Permisos</h4>

<a asp-action="Create" class="btn btn-brand mb-3"><i class="bi bi-plus-lg me-1"></i>Solicitar permiso</a>

<table class="table table-striped mt-2">
    <thead>
        <tr>
            <th>Usuario</th>
            <th>Tipo</th>
            <th>Fechas</th>
            <th>Motivo</th>
            <th>Documento</th>
            <th>Estado</th>
            <th>Aprobado por</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var p in Model.Items)
        {
            <tr>
                <td>@p.Usuario?.Nombre</td>

                <td>@p.Tipo</td>

                <td>
                    @p.FechaInicio.ToShortDateString() -
                    @p.FechaFin.ToShortDateString()
                </td>

                <td>@p.Motivo</td>

                <td>
                    @if (!string.IsNullOrEmpty(p.RutaDocumentoIncapacidad))
                    {
                        <a href="@p.RutaDocumentoIncapacidad" target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-file-earmark-text"></i> Ver
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>

                <td>
                    <span class="badge bg-@(p.Estado == "Aprobado" ? "success" : p.Estado == "Rechazado" ? "danger" : "warning")">
                        @p.Estado
                    </span>
                </td>

                <td>@p.AprobadoPor?.Nombre</td>

                <td>
                    @if (User.IsInRole("Admin") && p.Estado == "Pendiente")
                    {
                        <form asp-action="Aprobar" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@p.Id" />
                            <button type="submit" class="btn btn-success btn-sm" title="Aprobar">✔</button>
                        </form>

                        <form asp-action="Rechazar" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@p.Id" />
                            <button type="submit" class="btn btn-danger btn-sm" title="Rechazar">✖</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Items.Any())
{
    <div class="alert alert-info text-center m-3">
        No hay permisos registrados.
    </div>
}

@await Html.PartialAsync("_Pagination", pagination)
</div>