@model OC.Core.Common.PagedResult<OC.Core.Domain.Entities.Empleado>

<div class="card-dashboard">
    <h4>Empleados</h4>

    <a asp-action="Create" class="btn btn-brand mb-3">
        <i class="bi bi-plus-lg"></i> Nuevo Empleado
    </a>

    @if (!Model.Items.Any())
    {
        <p>No hay empleados registrados.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Cédula</th>
                    <th>Teléfono</th>
                    <th>Puesto</th>
                    <th>Sucursal</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model.Items)
                {
                    <tr>
                        <td>@e.Nombre @e.Apellidos</td>
                        <td>@e.Cedula</td>
                        <td>@e.Telefono</td>
                        <td>@e.Puesto</td>
                        <td>@e.Sucursal?.Nombre</td>
                        <td>
                            @if (e.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit"
                               asp-route-id="@e.Id"
                               class="btn btn-sm btn-warning">
                                Editar
                            </a>

                            <form asp-action="ToggleStatus"
                                  asp-route-id="@e.Id"
                                  method="post"
                                  class="d-inline"
                                  onsubmit="return confirm('¿Desea cambiar el estado del empleado?');">
                                <button type="submit"
                                        class="btn btn-sm btn-danger">
                                    @(e.Activo ? "Desactivar" : "Activar")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
