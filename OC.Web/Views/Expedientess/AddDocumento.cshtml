@model OC.Web.ViewModels.DocumentoExpedienteViewModel

<div class="card-dashboard">
    <h4>Adjuntar Documento al Expediente</h4>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="AddDocumento" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="ExpedienteId" />

        <div class="mb-3">
            <label asp-for="Archivo" class="form-label"></label>
            <input asp-for="Archivo" type="file" class="form-control" />
            <span asp-validation-for="Archivo" class="text-danger"></span>
            <small class="form-text text-muted">
                Formatos permitidos: PDF, JPG, JPEG, PNG, DOC, DOCX, XLS, XLSX. Tamaño máximo: 10 MB.
            </small>
        </div>

        <div class="mb-3">
            <label asp-for="Descripcion" class="form-label"></label>
            <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
            <span asp-validation-for="Descripcion" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">
            <i class="bi bi-upload"></i> Subir Documento
        </button>
        <a asp-action="Details" asp-route-id="@Model.ExpedienteId" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}