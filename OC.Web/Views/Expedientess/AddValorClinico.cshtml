@model OC.Web.ViewModels.ValorClinicoViewModel

<div class="card-dashboard">
    <h4>Agregar Valor Clínico</h4>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="alert alert-info mb-3">
        <strong>Paciente:</strong> @Model.NombrePaciente<br />
        <strong>Motivo de consulta:</strong> @Model.MotivoConsulta
    </div>

    <form asp-action="AddValorClinico" method="post">
        <input type="hidden" asp-for="ExpedienteId" />

        <div class="mb-3">
            <label asp-for="Diagnostico" class="form-label"></label>
            <textarea asp-for="Diagnostico" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Diagnostico" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6">
                <h5>Ojo Derecho (OD)</h5>
                <div class="mb-3">
                    <label asp-for="EsferaOD" class="form-label"></label>
                    <input asp-for="EsferaOD" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="EsferaOD" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="CilindroOD" class="form-label"></label>
                    <input asp-for="CilindroOD" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="CilindroOD" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="EjeOD" class="form-label"></label>
                    <input asp-for="EjeOD" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="EjeOD" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <h5>Ojo Izquierdo (OI)</h5>
                <div class="mb-3">
                    <label asp-for="EsferaOI" class="form-label"></label>
                    <input asp-for="EsferaOI" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="EsferaOI" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="CilindroOI" class="form-label"></label>
                    <input asp-for="CilindroOI" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="CilindroOI" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="EjeOI" class="form-label"></label>
                    <input asp-for="EjeOI" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="EjeOI" class="text-danger"></span>
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save"></i> Guardar
        </button>
        <a asp-action="Details" asp-route-id="@Model.ExpedienteId" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}