@model OC.Core.Domain.Entities.Producto
@{
    ViewData["Title"] = "Registrar producto";
}

<h2>Registrar producto</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label class="form-label">Nombre</label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">SKU</label>
        <input asp-for="SKU" class="form-control" placeholder="Ej: LENTE-001" />
        <span asp-validation-for="SKU" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Costo unitario</label>
        <input asp-for="CostoUnitario" type="number" step="0.01" min="0" class="form-control" />
        <span asp-validation-for="CostoUnitario" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Stock inicial</label>
        <input asp-for="Stock" type="number" min="0" class="form-control" />
        <span asp-validation-for="Stock" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-success">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
