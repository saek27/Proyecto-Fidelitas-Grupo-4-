@model OC.Core.Domain.Entities.Producto
@{
    ViewData["Title"] = "Nuevo Producto";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card-dashboard animate-on-scroll" data-delay="0">
                <h4 class="mb-4"><i class="bi bi-plus-circle me-2"></i> Nuevo Producto</h4>

                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-semibold">Nombre *</label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ej: Lentes de sol polarizados" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SKU" class="form-label fw-semibold">SKU *</label>
                        <input asp-for="SKU" class="form-control" placeholder="Ej: LENTE-001" />
                        <span asp-validation-for="SKU" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Imagen del producto</label>
                        <input type="file" name="imagenProducto" class="form-control" accept=".jpg,.jpeg,.png,.gif,.webp,image/jpeg,image/png,image/gif,image/webp" />
                        <div class="form-text">Opcional. JPG, PNG, GIF o WEBP. Máximo 5 MB.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CostoUnitario" class="form-label fw-semibold">Costo unitario *</label>
                        <input asp-for="CostoUnitario" type="number" step="0.01" min="0" class="form-control" />
                        <span asp-validation-for="CostoUnitario" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Stock" class="form-label fw-semibold">Stock inicial *</label>
                        <input asp-for="Stock" type="number" min="0" class="form-control" />
                        <span asp-validation-for="Stock" class="text-danger"></span>
                    </div>

                    <div class="form-footer-actions">
                        <div class="btn-toolbar mb-0" role="toolbar" aria-label="Enviar formulario">
                            <div class="btn-group" role="group">
                                <button type="submit" class="btn btn-brand btn-ripple">
                                    <i class="bi bi-check-lg me-2"></i> Guardar producto
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary btn-ripple">
                                    <i class="bi bi-x-lg me-2"></i> Cancelar
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
