@model OC.Core.Domain.Entities.Producto
@{
    ViewData["Title"] = $"Producto {Model.Nombre}";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card-dashboard animate-on-scroll" data-delay="0">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4><i class="bi bi-box-seam me-2"></i> Detalle del Producto</h4>
                    <span class="badge @(Model.Activo ? "bg-success" : "bg-secondary")">
                        @(Model.Activo ? "Activo" : "Inactivo")
                    </span>
                </div>

                @if (!string.IsNullOrEmpty(Model.RutaImagen))
                {
                    <div class="mb-4 text-center text-md-start">
                        <img src="@Model.RutaImagen" alt="@Model.Nombre" class="rounded border shadow-sm" style="max-height:200px;max-width:100%;object-fit:contain" />
                    </div>
                }

                <dl class="row">
                    <dt class="col-sm-3">Nombre</dt>
                    <dd class="col-sm-9">@Model.Nombre</dd>

                    <dt class="col-sm-3">SKU</dt>
                    <dd class="col-sm-9">@Model.SKU</dd>

                    <dt class="col-sm-3">Costo unitario</dt>
                    <dd class="col-sm-9">@Model.CostoUnitario.ToString("N2")</dd>

                    <dt class="col-sm-3">Stock disponible</dt>
                    <dd class="col-sm-9 @(Model.Stock < 6 ? "text-danger fw-bold" : "")">@Model.Stock</dd>
                </dl>

                @if (Model.Stock < 6)
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i> Este producto tiene bajo stock (≤5 unidades). Se recomienda realizar un pedido.
                    </div>
                }

                <div class="form-footer-actions justify-content-between align-items-center">
                    <div class="btn-toolbar mb-0" role="toolbar" aria-label="Navegación y edición">
                        <div class="btn-group" role="group">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-ripple">
                                <i class="bi bi-arrow-left me-1"></i> Volver al inventario
                            </a>
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-brand btn-ripple">
                                <i class="bi bi-pencil me-1"></i> Editar
                            </a>
                        </div>
                    </div>
                    <div class="btn-toolbar mb-0" role="toolbar" aria-label="Eliminar producto">
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="m-0" onsubmit="return confirm('¿Eliminar este producto del catálogo?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-ripple">
                                <i class="bi bi-trash me-1"></i> Eliminar del catálogo
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>