@model OC.Core.Domain.Entities.Producto
@{
    ViewData["Title"] = "Editar producto";
}

<h2>Editar producto</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="SKU" />
    <input type="hidden" asp-for="Activo" />

    <div class="mb-3">
        <label class="form-label">Nombre</label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">SKU</label>
        <input asp-for="SKU" class="form-control" readonly />
    </div>
    <div class="mb-3">
        <label class="form-label">Costo unitario</label>
        <input asp-for="CostoUnitario" type="number" step="0.01" min="0" class="form-control" />
        <span asp-validation-for="CostoUnitario" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Stock disponible</label>
        <input asp-for="Stock" type="number" min="0" class="form-control" />
        <span asp-validation-for="Stock" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Actualizar</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
