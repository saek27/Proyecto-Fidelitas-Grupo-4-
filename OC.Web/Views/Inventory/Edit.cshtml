@model OC.Core.Domain.Entities.Producto
@{
    ViewData["Title"] ="Editar Producto";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card-dashboard animate-on-scroll" data-delay="0">
                <h4 class="mb-4"><i class="bi bi-pencil-square me-2"></i> Editar Producto</h4>

                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="SKU" />
                    <input type="hidden" asp-for="Activo" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Nombre" class="form-label fw-semibold">Nombre *</label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="SKU" class="form-label fw-semibold">SKU</label>
                            <input asp-for="SKU" class="form-control" readonly />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Categoria" class="form-label fw-semibold">Categoría</label>
                            <select asp-for="Categoria" class="form-select" id="CategoriaSelect">
                                <option value="Lentes de Sol">Lentes de Sol</option>
                                <option value="Lentes Graduados">Lentes Graduados</option>
                                <option value="Accesorios">Accesorios</option>
                            </select>
                            <span asp-validation-for="Categoria" class="text-danger"></span>
                            <small class="form-text text-muted">Escriba una categoría nueva y presione Enter para agregarla.</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="PrecioPublico" class="form-label fw-semibold">Precio público (₡)</label>
                            <input asp-for="PrecioPublico" type="number" step="0.01" min="0" class="form-control" />
                            <span asp-validation-for="PrecioPublico" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DescripcionCorta" class="form-label fw-semibold">Descripción corta</label>
                        <textarea asp-for="DescripcionCorta" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="DescripcionCorta" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Imagen del producto</label>
                        @if (!string.IsNullOrEmpty(Model.RutaImagen))
                        {
                            <div class="mb-2">
                                <img src="@Model.RutaImagen" alt="@Model.Nombre" class="rounded border" style="max-height:100px; max-width:100px; object-fit:contain" />
                            </div>
                        }
                        <input type="file" name="imagenProducto" class="form-control" accept=".jpg,.jpeg,.png,.gif,.webp" />
                        <div class="form-text">Deje vacío para conservar la imagen actual.</div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="CostoUnitario" class="form-label fw-semibold">Costo unitario *</label>
                            <input asp-for="CostoUnitario" type="number" step="0.01" min="0" class="form-control" />
                            <span asp-validation-for="CostoUnitario" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Stock" class="form-label fw-semibold">Stock disponible *</label>
                            <input asp-for="Stock" type="number" min="0" class="form-control" />
                            <span asp-validation-for="Stock" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3 d-flex align-items-center">
                            <div class="form-check mt-4">
                                <input class="form-check-input" type="checkbox" asp-for="Destacado" />
                                <label class="form-check-label fw-semibold" asp-for="Destacado">Destacar en el landing</label>
                            </div>
                        </div>
                    </div>

                    <div class="form-footer-actions">
                        <div class="btn-group" role="group">
                            <button type="submit" class="btn btn-brand">
                                <i class="bi bi-check-lg me-2"></i> Guardar cambios
                            </button>
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg me-2"></i> Cancelar
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/js/select2.min.js"></script>
    <script>
        $(function () {
            $('#CategoriaSelect').select2({
                theme: 'bootstrap-5',
                placeholder: '-- Seleccione o escriba una categoría nueva --',
                allowClear: true,
                width: '100%',
                tags: true,
                language: { noResults: function () { return "Escriba y presione Enter para crear"; } }
            });
        });
    </script>
}