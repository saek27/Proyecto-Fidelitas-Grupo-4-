@using OC.Core.Domain.Entities
@model OC.Core.Common.PagedResult<Producto>
@{
    ViewData["Title"] = "Inventario";
    var pagination = new PaginationInfo
    {
        CurrentPage = Model.PageIndex,
        TotalPages = Model.TotalPages,
        GetPageUrl = (page) => Url.Action("Index", new { page, pageSize = ViewBag.PageSize })
    };
    var lowStock = ViewBag.LowStock as IEnumerable<Producto> ?? new List<Producto>();
}

<div class="container-fluid px-4">
    <div class="d-flex flex-column flex-md-row gap-3 justify-content-md-between align-items-md-center mb-4">
        <h2 class="text-dark mb-0">
            <i class="bi bi-box-seam me-2"></i> Inventario
        </h2>
        <div class="btn-toolbar page-header-toolbar mb-0 justify-content-md-end" role="toolbar" aria-label="Acciones de inventario">
            <a asp-action="Create" class="btn btn-brand btn-ripple">
                <i class="bi bi-plus-circle me-2"></i> Nuevo producto
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show animate-fade-up mb-3" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card-dashboard animate-on-scroll" data-delay="0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:72px">Imagen</th>
                            <th>Nombre</th>
                            <th>SKU</th>
                            <th>Costo unitario</th>
                            <th>Stock</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            var stockClass = item.Stock < 6 ? "text-danger fw-bold" : "";
                            <tr class="animate-on-scroll" data-delay="@(Model.Items.ToList().IndexOf(item) * 30)">
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(item.RutaImagen))
                                    {
                                        <img src="@item.RutaImagen" alt="" class="rounded border" style="height:48px;width:48px;object-fit:contain" />
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td>@item.Nombre</td>
                                <td>@item.SKU</td>
                                <td>@item.CostoUnitario.ToString("N2")</td>
                                <td class="@stockClass">@item.Stock</td>
                                <td>
                                    @if (item.Activo)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary"><i class="bi bi-x-circle"></i> Inactivo</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-toolbar table-row-toolbar justify-content-center flex-wrap mb-0" role="toolbar" aria-label="Acciones del producto">
                                        <div class="btn-group btn-group-sm" role="group" aria-label="Consulta y edición">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="Ver detalle">
                                                <i class="bi bi-eye"></i><span class="d-none d-xl-inline ms-1">Ver</span>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary" title="Editar">
                                                <i class="bi bi-pencil"></i><span class="d-none d-xl-inline ms-1">Editar</span>
                                            </a>
                                        </div>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="ms-1" onsubmit="return confirm('¿Eliminar este producto del catálogo?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar del catálogo">
                                                <i class="bi bi-trash"></i><span class="d-none d-xl-inline ms-1">Eliminar</span>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Items.Any())
            {
                <div class="alert alert-info text-center m-3">
                    <i class="bi bi-info-circle"></i> No hay productos registrados.
                    <a asp-action="Create" class="alert-link">Agregar el primero</a>
                </div>
            }
        </div>
    </div>

    @await Html.PartialAsync("_Pagination", pagination)

    @if (lowStock.Any())
    {
        <div class="card-dashboard mt-4 border-danger animate-on-scroll" data-delay="200">
            <div class="card-header bg-danger bg-opacity-10 border-bottom-0">
                <h5 class="mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Productos con bajo stock (≤5)
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-danger mb-0">
                        <thead>
                            <tr>
                                <th style="width:56px"></th>
                                <th>Nombre</th>
                                <th>SKU</th>
                                <th>Stock actual</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in lowStock)
                            {
                                <tr>
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(item.RutaImagen))
                                        {
                                            <img src="@item.RutaImagen" alt="" class="rounded" style="height:40px;width:40px;object-fit:contain" />
                                        }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                    <td>@item.Nombre</td>
                                    <td>@item.SKU</td>
                                    <td class="fw-bold text-danger">@item.Stock</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        anime({
            targets: '.animate-on-scroll',
            opacity: [0, 1],
            translateY: [15, 0],
            delay: function(el, i) { return parseInt(el.getAttribute('data-delay') || i * 30); },
            duration: 500,
            easing: 'easeOutQuad'
        });
    </script>
}