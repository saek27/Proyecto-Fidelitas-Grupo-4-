@model OC.Core.Common.PagedResult<OC.Core.Domain.Entities.Producto>
@{
    ViewData["Title"] = "Inventario";
}

<h2>Inventario</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<a asp-action="Create" class="btn btn-primary mb-3">Nuevo producto</a>

<form method="get">
    <label>Mostrar:</label>
    <select name="pageSize" onchange="this.form.submit()">
        <option value="5" selected="@(ViewBag.PageSize == 5)">5</option>
        <option value="10" selected="@(ViewBag.PageSize == 10)">10</option>
        <option value="20" selected="@(ViewBag.PageSize == 20)">20</option>
        <option value="50" selected="@(ViewBag.PageSize == 50)">50</option>
        <option value="100" selected="@(ViewBag.PageSize == 100)">100</option>
    </select>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>SKU</th>
            <th>Costo unitario</th>
            <th>Stock</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.SKU</td>
                <td>@item.CostoUnitario.ToString("N2")</td>
                <td>@item.Stock</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Ver</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('¿Eliminar este producto del catálogo?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (((IEnumerable<OC.Core.Domain.Entities.Producto>)ViewBag.LowStock).Any())
{
    <h3 class="mt-4 text-danger">⚠ Productos con bajo stock</h3>

    <table class="table table-danger">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Stock</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in (IEnumerable<OC.Core.Domain.Entities.Producto>)ViewBag.LowStock)
            {
                <tr>
                    <td>@item.Nombre</td>
                    <td>@item.Stock</td>
                </tr>
            }
        </tbody>
    </table>
}

