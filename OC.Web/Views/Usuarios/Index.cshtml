@using OC.Core.Common
@using OC.Core.Domain.Entities
@model PagedResult<Usuario>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="card-dashboard">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary"><i class="bi bi-people-fill"></i> Usuarios</h2>
        <div class="d-flex gap-2">
            <a asp-action="AssignRole" class="btn btn-outline-primary">
                <i class="bi bi-shield-lock"></i> Asignar Rol
            </a>
            <a asp-action="Create" class="btn btn-brand">
                <i class="bi bi-plus-lg"></i> Nuevo Usuario
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Correo</th>
                    <th>Rol</th>
                    <th>Sucursal</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="fw-bold">@item.Nombre</td>
                        <td>@item.Correo</td>
                        <td><span class="badge bg-info text-dark">@item.Rol.Nombre</span></td>
                        <td>@item.Sucursal.Nombre</td>
                        <td>
                            <div class="form-check form-switch m-0">
                                <form asp-action="ToggleStatus" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input class="form-check-input" type="checkbox" role="switch"
                                           id="u_@item.Id"
                                           checked="@(item.Activo)"
                                           onchange="this.form.submit()">
                                    <label class="form-check-label small" for="u_@item.Id">
                                        @(item.Activo ? "Desbloqueado" : "Bloqueado")
                                    </label>
                                </form>
                            </div>
                        </td>
                        <td>
                            <!-- Editar... -->
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <nav>
        <ul class="pagination justify-content-center">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a class="page-link" asp-route-pageIndex="@(Model.PageIndex - 1)">Anterior</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">Página @Model.PageIndex de @Model.TotalPages</span>
            </li>
            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a class="page-link" asp-route-pageIndex="@(Model.PageIndex + 1)">Siguiente</a>
            </li>
        </ul>
    </nav>
</div>