@using OC.Core.Common
@using OC.Core.Domain.Entities
@model PagedResult<Usuario>
@{
    ViewData["Title"] = "Usuarios";
    var pagination = new PaginationInfo
    {
        CurrentPage = Model.PageIndex,
        TotalPages = Model.TotalPages,
        GetPageUrl = (page) => Url.Action("Index", new { page })
    };
}

<div class="container-fluid px-4">
    <div class="page-header animate-fade-up">
        <div class="page-header-text">
            <div class="page-header-icon"><i class="bi bi-shield-lock"></i></div>
            <div>
                <h1 class="page-title">Usuarios</h1>
                <p class="page-subtitle">
                    <i class="bi bi-info-circle me-1"></i>
                    @(Model.TotalCount == 0 ? "Sin usuarios." : $"{Model.TotalCount} usuario(s) registrado(s).")
                </p>
            </div>
        </div>
        <div class="page-actions">
            <a asp-action="AssignRole" class="btn btn-outline-primary">
                <i class="bi bi-shield-lock me-1"></i> Asignar Rol
            </a>
            <a asp-action="Create" class="btn btn-brand">
                <i class="bi bi-plus-circle me-1"></i> Nuevo Usuario
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show animate-fade-up mb-3" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card-dashboard animate-fade-up delay-1">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Usuario</th>
                            <th>Correo</th>
                            <th>Rol</th>
                            <th>Sucursal</th>
                            <th class="text-center" style="width:130px">Estado</th>
                            <th class="text-center" style="width:80px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="entity-cell">
                                        <div class="entity-avatar bg-info-subtle text-info-emphasis">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                        <div>
                                            <div class="fw-semibold">@item.Nombre</div>
                                            <div class="text-muted small">@item.Cedula</div>
                                        </div>
                                    </div>
                                </td>
                                <td>@item.Correo</td>
                                <td>
                                    <span class="badge bg-light text-dark border">@item.Rol.Nombre</span>
                                </td>
                                <td>@item.Sucursal.Nombre</td>
                                <td class="text-center">
                                    <form asp-action="ToggleStatus" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <div class="form-check form-switch d-inline-block m-0">
                                            <input class="form-check-input" type="checkbox" role="switch"
                                                   id="u_@item.Id"
                                                   checked="@(item.Activo)"
                                                   onchange="this.form.submit()">
                                        </div>
                                    </form>
                                </td>
                                <td class="text-center">
                                    <div class="action-buttons">
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn-action btn-action-primary" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Items.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-shield-lock"></i></div>
                    <h5 class="empty-state-title">No hay usuarios registrados</h5>
                    <p class="empty-state-text">Empieza creando el primer usuario del sistema.</p>
                    <a asp-action="Create" class="btn btn-brand">
                        <i class="bi bi-plus-circle me-1"></i> Crear el primero
                    </a>
                </div>
            }
        </div>
    </div>

    @await Html.PartialAsync("_Pagination", pagination)
</div>
