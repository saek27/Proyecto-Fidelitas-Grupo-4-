@model OC.Web.ViewModels.UserViewModel

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card-dashboard">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="text-primary">Editar Usuario</h3>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left"></i> Volver al Listado
                </a>
            </div>

            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />
                <div class="row g-3">
                    <div class="col-md-12">
                        <label asp-for="Name" class="form-label fw-bold">Nombre Completo</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Cedula" class="form-label fw-bold">Cédula</label>
                        <input asp-for="Cedula" class="form-control" />
                        <span asp-validation-for="Cedula" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-bold">Correo Electrónico</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label fw-bold">Nueva Contraseña (opcional)</label>
                        <input asp-for="Password" class="form-control" placeholder="Dejar en blanco para no cambiar" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                        <small class="form-text text-muted">Solo si desea cambiar la contraseña</small>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="RoleId" class="form-label fw-bold">Rol de Usuario</label>
                        <select asp-for="RoleId" asp-items="Model.RolesList" class="form-select">
                            <option value="">-- Seleccionar Rol --</option>
                        </select>
                        <span asp-validation-for="RoleId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SucursalId" class="form-label fw-bold">Sucursal Asignada</label>
                        <select asp-for="SucursalId" asp-items="Model.SucursalesList" class="form-select">
                            <option value="">-- Seleccionar Sucursal --</option>
                        </select>
                        <span asp-validation-for="SucursalId" class="text-danger"></span>
                    </div>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="col-md-6">
                            <label asp-for="SalarioBase" class="form-label fw-bold">Salario Base (₡)</label>
                            <input asp-for="SalarioBase" class="form-control" />
                            <span asp-validation-for="SalarioBase" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="FechaContratacion" class="form-label fw-bold">Fecha de Contratación</label>
                            <input asp-for="FechaContratacion" type="date" class="form-control" />
                            <span asp-validation-for="FechaContratacion" class="text-danger"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="NumeroCuentaIBAN" class="form-label fw-bold">Número de Cuenta IBAN</label>
                            <input asp-for="NumeroCuentaIBAN" class="form-control" />
                            <span asp-validation-for="NumeroCuentaIBAN" class="text-danger"></span>
                        </div>
                    }
                </div>

                <div class="mt-4 d-grid gap-2 d-md-flex justify-content-md-end">
                    <button type="submit" class="btn btn-brand px-5">
                        <i class="bi bi-save me-2"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}