@model OC.Web.ViewModels.VacacionesSaldoViewModel
@{
    var titulo = ViewData["TituloSaldo"] as string ?? "Saldo";
}

<div class="card-dashboard animate-fade-up delay-1 mb-3">
    <div class="card-body">
        <h5 class="mb-3"><i class="bi bi-person-badge me-2"></i>@titulo: @Model.NombreUsuario</h5>
        @if (!Model.TieneFechaContratacion)
        {
            <div class="alert alert-warning mb-0">
                <i class="bi bi-exclamation-triangle me-2"></i>
                No tiene fecha de contratación registrada. El administrador debe completarla en <strong>Usuarios</strong> para calcular los días.
            </div>
        }
        else
        {
            <div class="row g-3">
                <div class="col-md-3 col-6">
                    <div class="info-card">
                        <div class="info-card-label">Contratación</div>
                        <div class="info-card-value">@Model.FechaContratacion!.Value.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="info-card">
                        <div class="info-card-label">Meses completos</div>
                        <div class="info-card-value">@Model.MesesCompletos</div>
                    </div>
                </div>
                <div class="col-md-2 col-6">
                    <div class="info-card">
                        <div class="info-card-label">Acumulados</div>
                        <div class="info-card-value">@Model.DiasAcumulados días</div>
                    </div>
                </div>
                <div class="col-md-2 col-6">
                    <div class="info-card">
                        <div class="info-card-label">Usados</div>
                        <div class="info-card-value">@Model.DiasUsados días</div>
                    </div>
                </div>
                <div class="col-md-2 col-6">
                    <div class="info-card">
                        <div class="info-card-label">Disponibles</div>
                        <div class="info-card-value text-primary fw-bold">@Model.DiasDisponibles días</div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
