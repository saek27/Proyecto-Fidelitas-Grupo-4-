@model IEnumerable<OC.Core.Domain.Entities.Cita>

<div class="card-dashboard">

    <h4>Historial de citas</h4>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No hay registros disponibles
        </div>
    }
    else
    {
        <table class="table table-striped">

            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Estado</th>
                    <th>Tratamiento</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var cita in Model)
                {
                    <tr>
                        <td>
                            @cita.FechaHora.ToString("dd/MM/yyyy HH:mm")
                        </td>

                        <td>
                            @cita.Estado
                        </td>

                        <td>
                            @(
                                cita.Expediente != null && !string.IsNullOrWhiteSpace(cita.Expediente.MotivoConsulta)
                                    ? cita.Expediente.MotivoConsulta
                                    : (string.IsNullOrWhiteSpace(cita.MotivoConsulta) ? "—" : cita.MotivoConsulta)
                             )
                        </td>

                        <td class="text-end">
                            <a asp-action="DetalleHistorial" asp-route-id="@cita.Id" class="btn btn-sm btn-outline-primary">
                                Ver detalle
                            </a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    }

</div>
