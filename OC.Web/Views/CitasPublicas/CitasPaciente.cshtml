@using OC.Core.Domain.Entities
@using OC.Web.Models
@model OC.Core.Common.PagedResult<Cita>
@{
    ViewData["Title"] = "Gestión de Citas";
    var pagination = new PaginationInfo
    {
        CurrentPage = Model.PageIndex,
        TotalPages = Model.TotalPages,
        GetPageUrl = (page) => Url.Action("CitasPaciente", new {
            page,
            search = ViewBag.Search,
            estado = ViewBag.Estado,
            fechaDesde = ViewBag.FechaDesde,
            fechaHasta = ViewBag.FechaHasta,
            sort = ViewBag.Sort
        }) ?? string.Empty
    };
}

<div class="card-dashboard">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4><i class="bi bi-calendar-check me-2"></i>Gestión de Citas</h4>
    </div>

    @* ── FILTROS + BÚSQUEDA + ORDEN (estilo OrdenesTrabajo) ── *@
    <div class="card mb-3 border-0 bg-light">
        <div class="card-body py-2">
            <form method="get" asp-action="CitasPaciente">
                <div class="row g-2 align-items-end">

                    <div class="col-md-3">
                        <label class="form-label form-label-sm mb-1">Búsqueda</label>
                        <div class="input-group input-group-sm">
                            <input type="text" name="search" value="@ViewBag.Search" class="form-control"
                                   placeholder="Paciente, cédula o # cita..."
                                   onchange="this.form.submit()" />
                            <button type="submit" class="btn btn-brand" title="Buscar">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label form-label-sm mb-1">Fecha desde</label>
                        <input type="date" name="fechaDesde" value="@ViewBag.FechaDesde" class="form-control form-control-sm"
                               onchange="this.form.submit()" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label form-label-sm mb-1">Fecha hasta</label>
                        <input type="date" name="fechaHasta" value="@ViewBag.FechaHasta" class="form-control form-control-sm"
                               onchange="this.form.submit()" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label form-label-sm mb-1">Estado</label>
                        <select name="estado" class="form-select form-select-sm" onchange="this.form.submit()">
                            <option value="">Todas</option>
                            <option value="Pendiente" selected="@(ViewBag.Estado == "Pendiente")">Pendiente</option>
                            <option value="Programada" selected="@(ViewBag.Estado == "Programada")">Programada</option>
                            <option value="Atendida" selected="@(ViewBag.Estado == "Atendida")">Atendida</option>
                            <option value="Cancelada" selected="@(ViewBag.Estado == "Cancelada")">Cancelada</option>
                            <option value="Confirmada" selected="@(ViewBag.Estado == "Confirmada")">Confirmada</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label form-label-sm mb-1">Ordenar por</label>
                        <select name="sort" class="form-select form-select-sm" onchange="this.form.submit()">
                            <option value="">Fecha (nuevas)</option>
                            <option value="asc" selected="@(ViewBag.Sort == "asc")">Fecha (viejas)</option>
                            <option value="patient" selected="@(ViewBag.Sort == "patient")">Paciente A-Z</option>
                            <option value="patient_desc" selected="@(ViewBag.Sort == "patient_desc")">Paciente Z-A</option>
                        </select>
                    </div>

                    <div class="col-md-1 d-flex align-items-end">
                        <button type="submit" class="btn btn-brand btn-sm w-100 d-flex align-items-center justify-content-center gap-1" title="Filtrar">
                            <i class="bi bi-funnel"></i>
                        </button>
                    </div>

                </div>
                <div class="row mt-2">
                    <div class="col-12">
                        <a asp-action="CitasPaciente" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-x-lg"></i> Limpiar filtros
                        </a>
                        @if (Model.TotalCount > 0)
                        {
                            <span class="text-muted small ms-2">
                                Mostrando @Model.Items.Count de @Model.TotalCount cita(s)
                                @if (!string.IsNullOrWhiteSpace(ViewBag.Search))
                                {
                                    <span> para "<strong>@ViewBag.Search</strong>"</span>
                                }
                            </span>
                        }
                    </div>
                </div>
            </form>
        </div>
    </div>

    @* ── TABLA ── *@
    @if (!Model.Items.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-calendar-x" style="font-size:3rem;"></i>
            <p class="mt-2 mb-0">No hay citas registradas para los filtros seleccionados.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Paciente</th>
                        <th>Cédula</th>
                        <th>Fecha y Hora</th>
                        <th>Estado</th>
                        <th>Motivo</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cita in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@cita.Paciente?.NombreCompleto</td>
                            <td class="text-muted">@cita.Paciente?.Cedula</td>
                            <td>@cita.FechaHora.ToString("dd/MM/yy HH:mm")</td>
                            <td>
                                @switch (cita.Estado)
                                {
                                    case "Pendiente":
                                        <span class="badge bg-warning">Pendiente</span>
                                        break;
                                    case "Programada":
                                        <span class="badge bg-primary">Programada</span>
                                        break;
                                    case "Confirmada":
                                        <span class="badge bg-info">Confirmada</span>
                                        break;
                                    case "Atendida":
                                        <span class="badge bg-success">Atendida</span>
                                        break;
                                    case "Cancelada":
                                        <span class="badge bg-danger">Cancelada</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">@cita.Estado</span>
                                        break;
                                }
                            </td>
                            <td class="text-muted small">@(cita.MotivoConsulta ?? "—")</td>
                            <td>
                                @if (User.IsInRole("Admin") || User.IsInRole("Optometrista") || User.IsInRole("Recepcion"))
                                {
                                    <a asp-action="Editar" asp-route-id="@cita.Id" class="btn btn-sm btn-outline-info">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-controller="CitasPublicas"
                                       asp-action="HistorialPaciente"
                                       asp-route-pacienteId="@cita.PacienteId"
                                       class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-clock-history"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* ── Paginación (patrón OrdenesTrabajo) ── *@
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Paginación" class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link"
                           asp-action="CitasPaciente"
                           asp-route-page="@(Model.PageIndex - 1)"
                           asp-route-search="@ViewBag.Search"
                           asp-route-estado="@ViewBag.Estado"
                           asp-route-fechaDesde="@ViewBag.FechaDesde"
                           asp-route-fechaHasta="@ViewBag.FechaHasta"
                           asp-route-sort="@ViewBag.Sort">
                            &laquo; Anterior
                        </a>
                    </li>

                    @{
                        var start = Math.Max(1, Model.PageIndex - 2);
                        var end = Math.Min(Model.TotalPages, Model.PageIndex + 2);
                    }
                    @if (start > 1)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               asp-action="CitasPaciente"
                               asp-route-page="1"
                               asp-route-search="@ViewBag.Search"
                               asp-route-estado="@ViewBag.Estado"
                               asp-route-fechaDesde="@ViewBag.FechaDesde"
                               asp-route-fechaHasta="@ViewBag.FechaHasta"
                               asp-route-sort="@ViewBag.Sort">1</a>
                        </li>
                        @if (start > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                    }
                    @for (var i = start; i <= end; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link"
                               asp-action="CitasPaciente"
                               asp-route-page="@i"
                               asp-route-search="@ViewBag.Search"
                               asp-route-estado="@ViewBag.Estado"
                               asp-route-fechaDesde="@ViewBag.FechaDesde"
                               asp-route-fechaHasta="@ViewBag.FechaHasta"
                               asp-route-sort="@ViewBag.Sort">@i</a>
                        </li>
                    }
                    @if (end < Model.TotalPages)
                    {
                        @if (end < Model.TotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link"
                               asp-action="CitasPaciente"
                               asp-route-page="@Model.TotalPages"
                               asp-route-search="@ViewBag.Search"
                               asp-route-estado="@ViewBag.Estado"
                               asp-route-fechaDesde="@ViewBag.FechaDesde"
                               asp-route-fechaHasta="@ViewBag.FechaHasta"
                               asp-route-sort="@ViewBag.Sort">@Model.TotalPages</a>
                        </li>
                    }

                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link"
                           asp-action="CitasPaciente"
                           asp-route-page="@(Model.PageIndex + 1)"
                           asp-route-search="@ViewBag.Search"
                           asp-route-estado="@ViewBag.Estado"
                           asp-route-fechaDesde="@ViewBag.FechaDesde"
                           asp-route-fechaHasta="@ViewBag.FechaHasta"
                           asp-route-sort="@ViewBag.Sort">
                            Siguiente &raquo;
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>
