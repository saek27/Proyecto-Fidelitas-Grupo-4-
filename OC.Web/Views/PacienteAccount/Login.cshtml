@{
    ViewData["Title"] = "Login Paciente";
}

<div class="card-dashboard">
    <h4>Iniciar Sesión - Paciente</h4>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (ViewData.ModelState[""]?.Errors.Any() == true)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @ViewData.ModelState[""].Errors.First().ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (ViewBag.AttemptsLeft != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            Tiene <strong>@ViewBag.AttemptsLeft</strong> intento(s) restante(s) antes del bloqueo.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (ViewBag.LockoutSeconds != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            Usuario bloqueado. Espere <strong id="lockoutTimer"></strong>.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <p class="text-muted">Ingrese su cédula en formato X-XXXX-XXXX y contraseña para acceder.</p>

    <form asp-action="Login" method="post">
        <div class="mb-3">
            <label for="cedula" class="form-label">Cédula</label>
            <input type="text" name="cedula" id="cedula" class="form-control" placeholder="Ej: 1-2345-6789" maxlength="11" title="Formato: X-XXXX-XXXX" required />
        </div>
        <div class="mb-3">
            <label for="contrasena" class="form-label">Contraseña</label>
            <input type="password" name="contrasena" id="contrasena" class="form-control" required />
        </div>

        <button type="submit" class="btn btn-brand">
            <i class="bi bi-box-arrow-in-right"></i> Iniciar Sesión
        </button>
        <a asp-controller="Pacientes" asp-action="Registro" class="btn btn-outline-primary">
            <i class="bi bi-person-plus"></i> Registrarse
        </a>
        <a asp-action="RecuperarContrasena" class="btn btn-link">¿Olvidó su contraseña?</a>
    </form>
</div>

@if (ViewBag.LockoutSeconds != null)
{
    <script>
        (function () {
            var seconds = parseInt("@ViewBag.LockoutSeconds", 10);
            if (isNaN(seconds) || seconds <= 0) return;

            function fmt(s) {
                var m = Math.floor(s / 60);
                var r = s % 60;
                return m + ":" + (r < 10 ? "0" + r : r);
            }

            var el = document.getElementById("lockoutTimer");
            if (!el) return;
            el.textContent = fmt(seconds);

            var t = setInterval(function () {
                seconds--;
                if (seconds <= 0) {
                    clearInterval(t);
                    el.textContent = "0:00";
                    return;
                }
                el.textContent = fmt(seconds);
            }, 1000);
        })();
    </script>
}
