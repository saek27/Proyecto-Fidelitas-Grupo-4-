@{
    ViewData["Title"] = "Login Paciente";
}

<div class="card-dashboard">
    <h4>Iniciar Sesión - Paciente</h4>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (ViewData.ModelState[""]?.Errors.Any() == true)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @ViewData.ModelState[""].Errors.First().ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <p class="text-muted">Ingrese su cédula (9 dígitos) y contraseña para acceder.</p>

    <form asp-action="Login" method="post">
        <div class="mb-3">
            <label for="cedula" class="form-label">Cédula (9 dígitos)</label>
            <input type="text" name="cedula" id="cedula" class="form-control" placeholder="Ej: 604240201" maxlength="9" pattern="\d{9}" title="Solo 9 dígitos numéricos" required />
        </div>
        <div class="mb-3">
            <label for="contrasena" class="form-label">Contraseña</label>
            <input type="password" name="contrasena" id="contrasena" class="form-control" required />
        </div>

        <button type="submit" class="btn btn-brand">
            <i class="bi bi-box-arrow-in-right"></i> Iniciar Sesión
        </button>
        <a asp-controller="Pacientes" asp-action="Registro" class="btn btn-outline-primary">
            <i class="bi bi-person-plus"></i> Registrarse
        </a>
        <a asp-action="RecuperarContrasena" class="btn btn-link">¿Olvidó su contraseña?</a>
    </form>
</div>
