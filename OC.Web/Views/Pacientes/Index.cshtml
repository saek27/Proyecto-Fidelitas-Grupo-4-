@model OC.Core.Common.PagedResult<OC.Core.Domain.Entities.Paciente>

<div class="card-dashboard">
    <h4>Pacientes</h4>

    <div class="row mb-3">
        <div class="col-md-8">
            <form method="get" asp-action="Index" class="d-flex">
                <input type="text" name="searchTerm" class="form-control me-2"
                       placeholder="Buscar por nombre o cédula..." value="@ViewBag.SearchTerm" />
                <button type="submit" class="btn btn-brand">
                    <i class="bi bi-search"></i> Buscar
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
                {
                    <a asp-action="Index" class="btn btn-secondary ms-2">
                        <i class="bi bi-x-circle"></i> Limpiar
                    </a>
                }
            </form>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-brand">
                <i class="bi bi-plus-lg"></i> Nuevo Paciente
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Items.Any())
    {
        <p>No hay pacientes registrados.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Nombre Completo</th>
                    <th>Cédula</th>
                    <th>Teléfono</th>
                    <th>Email</th>
                    <th>Fecha de Nacimiento</th>
                    <th>Fecha de Registro</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Items)
                {
                    <tr>
                        <td>@p.NombreCompleto</td>
                        <td>@p.Cedula</td>
                        <td>@(p.Telefono ?? "N/A")</td>
                        <td>@(p.Email ?? "N/A")</td>
                        <td>@p.FechaNacimiento.ToString("dd/MM/yyyy")</td>
                        <td>@p.FechaRegistro.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Editar
                            </a>

                            @if (User.IsInRole("Admin") || User.IsInRole("Optometrista") || User.IsInRole("Recepcion"))
                            {
                                <a asp-controller="CitasPublicas"
                                   asp-action="HistorialPaciente"
                                   asp-route-pacienteId="@p.Id"
                                   class="btn btn-sm btn-info">
                                    Ver Historial
                                </a>
                            }

                        </td>
                    </tr>
                    @if (!string.IsNullOrEmpty(ViewBag.SearchTerm) && p.Citas != null && p.Citas.Any(c => c.Expediente != null))
                    {
                        <tr>
                            <td colspan="7">
                                <div class="ms-4">
                                    <strong>Expedientes clínicos:</strong>
                                    <ul>
                                        @foreach (var cita in p.Citas.Where(c => c.Expediente != null))
                                        {
                                            <li>
                                                <a asp-controller="Expedientess"
                                                   asp-action="Details"
                                                   asp-route-id="@cita.Expediente.Id">
                                                    @cita.FechaHora.ToString("dd/MM/yyyy") - @cita.Expediente.MotivoConsulta
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        @if (string.IsNullOrEmpty(ViewBag.SearchTerm))
        {
            <nav>
                <ul class="pagination">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>