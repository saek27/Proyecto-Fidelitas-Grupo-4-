@model OC.Web.ViewModels.ValidarTotpViewModel
@{
    ViewData["Title"] = "Configurar autenticador";
}

<div class="card-dashboard">
    <h4>Paso 2 de 2: configurar autenticador (obligatorio)</h4>
    <p class="text-muted">
        Escanee el QR con Google Authenticator o Microsoft Authenticator.
        Luego ingrese el código de 6 dígitos para terminar su registro.
    </p>

    <div class="row">
        <div class="col-md-5 mb-3 text-center">
            <img src="@ViewBag.QrUrl" alt="QR TOTP" class="img-fluid border rounded p-2 bg-white" style="max-width:230px;" />
        </div>
        <div class="col-md-7 mb-3">
            <div class="alert alert-info mb-2">
                <strong>Cuenta:</strong> @ViewBag.Correo
            </div>
            <div class="alert alert-secondary">
                <strong>Llave manual:</strong><br />
                <code>@ViewBag.ManualKey</code>
            </div>
        </div>
    </div>

    <form asp-action="ConfigurarTotpRegistro" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <div class="mb-3">
            <label asp-for="Codigo" class="form-label"></label>
            <input asp-for="Codigo" class="form-control" maxlength="6" placeholder="123456" autocomplete="one-time-code" />
            <span asp-validation-for="Codigo" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-brand">Finalizar registro</button>
        <a asp-action="Registro" class="btn btn-secondary">Volver</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
