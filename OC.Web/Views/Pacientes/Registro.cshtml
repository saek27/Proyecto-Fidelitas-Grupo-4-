@model OC.Web.ViewModels.PacienteViewModel
@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Registro de paciente";
}

<div class="container mt-4 animate-on-scroll">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card-premium p-4 p-md-5 rounded-4 shadow-lg mb-5 border-0">

                <h4 class="text-white fw-bold mb-4">
                    <i class="bi bi-person-vcard text-info me-2"></i>Registro de Paciente
                </h4>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <p class="text-light opacity-75 mb-4 pb-3 border-bottom border-secondary border-opacity-25">
                    Complete el formulario para registrarse. Al final deberá configurar el autenticador TOTP (obligatorio) con QR.
                </p>

                <form asp-action="Registro" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Nombres" class="form-label text-light fw-medium"></label>
                            <input asp-for="Nombres" class="form-control input-premium" />
                            <span asp-validation-for="Nombres" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Apellidos" class="form-label text-light fw-medium"></label>
                            <input asp-for="Apellidos" class="form-control input-premium" />
                            <span asp-validation-for="Apellidos" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Cedula" class="form-label text-light fw-medium"></label>
                            <input asp-for="Cedula" class="form-control input-premium" placeholder="Ej: 1-2345-6789" maxlength="11" />
                            <span asp-validation-for="Cedula" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="Telefono" class="form-label text-light fw-medium"></label>
                            <input asp-for="Telefono" class="form-control input-premium" />
                            <span asp-validation-for="Telefono" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="FechaNacimiento" class="form-label text-light fw-medium"></label>
                            <input asp-for="FechaNacimiento" type="date" class="form-control input-premium" style="color-scheme: dark;" />
                            <span asp-validation-for="FechaNacimiento" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label text-light fw-medium"></label>
                        <input asp-for="Email" type="email" class="form-control input-premium" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                        <div class="form-text text-light opacity-75 mt-1">
                            <i class="bi bi-info-circle me-1"></i>Este será su correo para iniciar sesión.
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label asp-for="Contrasena" class="form-label text-light fw-medium"></label>
                            <input asp-for="Contrasena" type="password" class="form-control input-premium" />
                            <span asp-validation-for="Contrasena" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ConfirmarContrasena" class="form-label text-light fw-medium"></label>
                            <input asp-for="ConfirmarContrasena" type="password" class="form-control input-premium" />
                            <span asp-validation-for="ConfirmarContrasena" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-premium py-2 fw-semibold fs-5 shadow-sm">
                            <i class="bi bi-person-plus me-2"></i> Registrar Paciente
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}