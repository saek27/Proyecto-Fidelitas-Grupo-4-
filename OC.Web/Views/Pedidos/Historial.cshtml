@model OC.Core.Common.PagedResult<OC.Core.Domain.Entities.Pedido>
@using OC.Core.Domain.Entities

<h2 class="mb-4">Historial de Pedidos</h2>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Proveedor</th>
                <th>Fecha Pedido</th>
                <th>Entrega Estimada</th>
                <th>Entrega Real</th>
                <th>Estado</th>
                <th>Indicador</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pedido in Model.Items)
            {
                <tr>
                    <td>@pedido.Id</td>
                    <td>@pedido.Proveedor?.Nombre</td>
                    <td>@pedido.FechaPedido.ToShortDateString()</td>
                    <td>@pedido.FechaEntregaEstimada.ToShortDateString()</td>
                    <td>@(pedido.FechaEntregaReal?.ToShortDateString() ?? "-")</td>

                    <td>
                        <span class="badge bg-primary">
                            @pedido.Estado
                        </span>
                    </td>

                    <td>
                        @if (pedido.Indicador == IndicadorEntrega.A_Tiempo)
                        {
                            <span class="badge bg-success">A Tiempo</span>
                        }
                        else if (pedido.Indicador == IndicadorEntrega.Retrasado)
                        {
                            <span class="badge bg-danger">Retrasado</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pendiente</span>
                        }
                    </td>

                    <td class="text-center">

                        <div class="btn-group" role="group">

                            <!-- Ver Details -->
                            <a asp-action="Details"
                               asp-route-id="@pedido.Id"
                               class="btn btn-info btn-sm">
                                Ver
                            </a>

                            <!-- Editar -->
                            <a asp-action="Edit"
                               asp-route-id="@pedido.Id"
                               class="btn btn-warning btn-sm">
                                Editar
                            </a>

                            <!-- Desactivar -->
                            @if (pedido.Activo)
                            {
                                <form asp-action="Desactivar"
                                      asp-route-id="@pedido.Id"
                                      method="post"
                                      style="display:inline;">
                                    <button type="submit"
                                            class="btn btn-danger btn-sm">
                                        Desactivar
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="badge bg-dark">Inactivo</span>
                            }

                        </div>

                    </td>

                </tr>
            }
        </tbody>
    </table>
</div>
