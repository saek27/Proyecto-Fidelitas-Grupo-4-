@model OC.Core.Common.PagedResult<OC.Core.Domain.Entities.Pedido>
@using OC.Core.Domain.Entities
@{
    ViewData["Title"] = "Historial de Pedidos";
    int currentPage = Model.PageIndex;
    int totalPages = Model.TotalPages;
    bool hasPrevious = currentPage > 1;
    bool hasNext = currentPage < totalPages;
}

<div class="container-fluid px-4 py-3">
<div class="card-dashboard animate-on-scroll" data-delay="0">
    <div class="card-body">
    <div class="d-flex flex-column flex-md-row gap-3 justify-content-md-between align-items-md-start align-items-md-center mb-4">
        <h2 class="text-dark h4 mb-0">
            <i class="bi bi-clock-history me-2"></i> Historial de pedidos
        </h2>
        <div class="btn-toolbar page-header-toolbar mb-0 justify-content-md-end" role="toolbar" aria-label="Acciones del historial">
            <div class="btn-group" role="group">
                <a asp-action="Index" class="btn btn-outline-secondary btn-ripple">
                    <i class="bi bi-truck me-2"></i> Pedidos activos
                </a>
                <a asp-action="Create" class="btn btn-brand btn-ripple">
                    <i class="bi bi-plus-circle me-2"></i> Nuevo pedido
                </a>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Proveedor</th>
                    <th>Fecha pedido</th>
                    <th>Entrega estimada</th>
                    <th>Entrega real</th>
                    <th>Estado</th>
                    <th>Indicador</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pedido in Model.Items)
                {
                    <tr>
                        <td>@pedido.Id</td>
                        <td>@pedido.Proveedor?.Nombre</td>
                        <td>@pedido.FechaPedido.ToString("dd/MM/yyyy")</td>
                        <td>@pedido.FechaEntregaEstimada.ToString("dd/MM/yyyy")</td>
                        <td>@(pedido.FechaEntregaReal?.ToString("dd/MM/yyyy") ?? "-")</td>
                        <td>
                            <span class="badge bg-@(pedido.Estado == EstadoPedido.Pendiente ? "warning" :
                                                                                              pedido.Estado == EstadoPedido.Enviado ? "info" :
                                                                                              pedido.Estado == EstadoPedido.Recibido ? "success" : "secondary")">
                                @pedido.Estado
                            </span>
                        </td>
                        <td>
                            @if (pedido.Indicador == IndicadorEntrega.A_Tiempo)
                            {
                                <span class="badge bg-success">A tiempo</span>
                            }
                            else if (pedido.Indicador == IndicadorEntrega.Retrasado)
                            {
                                <span class="badge bg-danger">Retrasado</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pendiente</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (pedido.Activo)
                            {
                                <div class="btn-toolbar table-row-toolbar justify-content-center flex-wrap mb-0" role="toolbar" aria-label="Acciones del pedido">
                                    <div class="btn-group btn-group-sm" role="group" aria-label="Consulta y edición">
                                        <a asp-action="Details" asp-route-id="@pedido.Id" class="btn btn-outline-info" title="Ver detalle">
                                            <i class="bi bi-eye"></i><span class="d-none d-xl-inline ms-1">Ver</span>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@pedido.Id" class="btn btn-outline-secondary" title="Editar">
                                            <i class="bi bi-pencil"></i><span class="d-none d-xl-inline ms-1">Editar</span>
                                        </a>
                                    </div>
                                    <form asp-action="Desactivar" asp-route-id="@pedido.Id" method="post" class="ms-1" onsubmit="return confirm('¿Desactivar este pedido?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Desactivar pedido">
                                            <i class="bi bi-archive"></i><span class="d-none d-xl-inline ms-1">Desactivar</span>
                                        </button>
                                    </form>
                                </div>
                            }
                            else
                            {
                                <div class="btn-toolbar flex-column align-items-center gap-2 mb-0" role="toolbar" aria-label="Pedido inactivo">
                                    <span class="badge bg-secondary">Inactivo</span>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Details" asp-route-id="@pedido.Id" class="btn btn-outline-info" title="Ver detalle">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="alert alert-info text-center">
            <i class="bi bi-info-circle"></i> No hay pedidos registrados.
            <a asp-action="Create" class="alert-link">Crear el primero</a>
        </div>
    }

    @if (totalPages > 1)
    {
        <nav aria-label="Paginación del historial" class="mt-3">
            <ul class="pagination justify-content-center mb-0 flex-wrap">
                <li class="page-item @(hasPrevious ? "" : "disabled")">
                    <a class="page-link" asp-action="Historial" asp-route-page="@(currentPage - 1)">Anterior</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(currentPage == i ? "active" : "")">
                        <a class="page-link" asp-action="Historial" asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(hasNext ? "" : "disabled")">
                    <a class="page-link" asp-action="Historial" asp-route-page="@(currentPage + 1)">Siguiente</a>
                </li>
            </ul>
        </nav>
    }

    </div>
</div>
</div>

@section Scripts {
    <script>
        if (typeof anime !== 'undefined') {
            anime({
                targets: '.animate-on-scroll',
                opacity: [0, 1],
                translateY: [20, 0],
                duration: 600,
                easing: 'easeOutCubic'
            });
        }
    </script>
}