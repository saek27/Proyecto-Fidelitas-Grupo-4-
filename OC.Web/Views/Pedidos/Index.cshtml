@model OC.Core.Common.PagedResult<OC.Core.Domain.Entities.Pedido>
@using OC.Core.Domain.Entities

@{
    ViewData["Title"] = "Gestión de Pedidos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Gestión de Pedidos</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nuevo Pedido
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Proveedor</th>
                        <th>Fecha Pedido</th>
                        <th>Entrega Estimada</th>
                        <th>Entrega Real</th>
                        <th>Estado</th>
                        <th>Indicador</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pedido in Model.Items)
                    {
                        <tr>
                            <td>@pedido.Id</td>
                            <td>@pedido.Proveedor?.Nombre</td>
                            <td>@pedido.FechaPedido.ToShortDateString()</td>
                            <td>@pedido.FechaEntregaEstimada.ToShortDateString()</td>
                            <td>@(pedido.FechaEntregaReal?.ToShortDateString() ?? "-")</td>
                            <td>
                                <span class="badge bg-@(pedido.Estado == EstadoPedido.Pendiente ? "warning" :
                                                                                             pedido.Estado == EstadoPedido.Enviado ? "info" :
                                                                                             pedido.Estado == EstadoPedido.Recibido ? "success" : "secondary")">
                                    @pedido.Estado
                                </span>
                            </td>
                            <td>
                                @if (pedido.Indicador == IndicadorEntrega.A_Tiempo)
                                {
                                    <span class="badge bg-success">A Tiempo</span>
                                }
                                else if (pedido.Indicador == IndicadorEntrega.Retrasado)
                                {
                                    <span class="badge bg-danger">Retrasado</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Pendiente</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@pedido.Id" class="btn btn-sm btn-outline-info" title="Ver detalle">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@pedido.Id" class="btn btn-sm btn-outline-warning" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (pedido.Activo)
                                    {
                                        <form asp-action="Desactivar" asp-route-id="@pedido.Id" method="post" style="display:inline;">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Desactivar" onclick="return confirm('¿Desactivar este pedido?')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="badge bg-dark">Inactivo</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Items.Any())
        {
            <div class="alert alert-info text-center">
                <i class="bi bi-info-circle"></i> No hay pedidos registrados.
                <a asp-action="Create" class="alert-link">Crear el primero</a>
            </div>
        }

        <!-- Paginación -->
        @{
            int currentPage = ViewBag.CurrentPage;
            int totalPages = ViewBag.TotalPages;
            bool hasPrevious = ViewBag.HasPreviousPage;
            bool hasNext = ViewBag.HasNextPage;
        }

        @if (totalPages > 1)
        {
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(hasPrevious ? "" : "disabled")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)">Anterior</a>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(currentPage == i ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(hasNext ? "" : "disabled")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)">Siguiente</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Confirmación para desactivar (opcional, ya se usa en el onclick)
    </script>
}