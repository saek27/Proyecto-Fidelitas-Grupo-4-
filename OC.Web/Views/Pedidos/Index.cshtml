@using OC.Core.Domain.Entities
@model OC.Core.Common.PagedResult<Pedido>
@{
    ViewData["Title"] = "Gestión de Pedidos";
    var pagination = new PaginationInfo
    {
        CurrentPage = Model.PageIndex,
        TotalPages = Model.TotalPages,
        GetPageUrl = (page) => Url.Action("Index", new { page })
    };
}

<div class="container-fluid px-4">
    <div class="d-flex flex-column flex-md-row gap-3 justify-content-md-between align-items-md-center mb-4">
        <h2 class="text-dark mb-0">
            <i class="bi bi-truck me-2"></i> Gestión de pedidos
        </h2>
        <div class="btn-toolbar page-header-toolbar mb-0 justify-content-md-end" role="toolbar" aria-label="Acciones de pedidos">
            <div class="btn-group" role="group">
                <a asp-action="Historial" class="btn btn-outline-secondary btn-ripple">
                    <i class="bi bi-clock-history me-2"></i> Historial
                </a>
                <a asp-action="Create" class="btn btn-brand btn-ripple">
                    <i class="bi bi-plus-circle me-2"></i> Nuevo pedido
                </a>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show animate-fade-up mb-3" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card-dashboard animate-on-scroll" data-delay="0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Proveedor</th>
                            <th>Fecha Pedido</th>
                            <th>Entrega Estimada</th>
                            <th>Entrega Real</th>
                            <th>Estado</th>
                            <th>Indicador</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pedido in Model.Items)
                        {
                            <tr class="animate-on-scroll" data-delay="@(Model.Items.ToList().IndexOf(pedido) * 30)">
                                <td>@pedido.Id</td>
                                <td><strong>@pedido.Proveedor?.Nombre</strong></td>
                                <td>@pedido.FechaPedido.ToString("dd/MM/yyyy")</td>
                                <td>@pedido.FechaEntregaEstimada.ToString("dd/MM/yyyy")</td>
                                <td>@(pedido.FechaEntregaReal?.ToString("dd/MM/yyyy") ?? "-")</td>
                                <td>
                                    <span class="badge @(pedido.Estado == EstadoPedido.Pendiente ? "bg-warning text-dark" :
                                                                                                 pedido.Estado == EstadoPedido.Enviado ? "bg-info" :
                                                                                                 pedido.Estado == EstadoPedido.Recibido ? "bg-success" : "bg-secondary")">
                                        @pedido.Estado
                                    </span>
                                </td>
                                <td>
                                    @if (pedido.Indicador == IndicadorEntrega.A_Tiempo)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> A Tiempo</span>
                                    }
                                    else if (pedido.Indicador == IndicadorEntrega.Retrasado)
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-exclamation-triangle"></i> Retrasado</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary"><i class="bi bi-question-circle"></i> Pendiente</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (pedido.Activo)
                                    {
                                        <div class="btn-toolbar table-row-toolbar justify-content-center flex-wrap mb-0" role="toolbar" aria-label="Acciones del pedido">
                                            <div class="btn-group btn-group-sm" role="group" aria-label="Consulta y edición">
                                                <a asp-action="Details" asp-route-id="@pedido.Id" class="btn btn-outline-info" title="Ver detalle">
                                                    <i class="bi bi-eye"></i><span class="d-none d-xl-inline ms-1">Ver</span>
                                                </a>
                                                <a asp-action="Edit" asp-route-id="@pedido.Id" class="btn btn-outline-secondary" title="Editar">
                                                    <i class="bi bi-pencil"></i><span class="d-none d-xl-inline ms-1">Editar</span>
                                                </a>
                                            </div>
                                            <form asp-action="Desactivar" asp-route-id="@pedido.Id" method="post" class="ms-1" onsubmit="return confirm('¿Desactivar este pedido?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Desactivar pedido">
                                                    <i class="bi bi-archive"></i><span class="d-none d-xl-inline ms-1">Desactivar</span>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="btn-toolbar flex-column align-items-center gap-2 mb-0" role="toolbar" aria-label="Pedido inactivo">
                                            <span class="badge bg-secondary">Inactivo</span>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a asp-action="Details" asp-route-id="@pedido.Id" class="btn btn-outline-info" title="Ver detalle">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </div>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Items.Any())
            {
                <div class="alert alert-info text-center m-3">
                    <i class="bi bi-info-circle"></i> No hay pedidos registrados.
                    <a asp-action="Create" class="alert-link">Crear el primero</a>
                </div>
            }
        </div>
    </div>

    @await Html.PartialAsync("_Pagination", pagination)
</div>

@section Scripts {
    <script>
        anime({
            targets: '.animate-on-scroll',
            opacity: [0, 1],
            translateY: [15, 0],
            delay: function(el, i) { return parseInt(el.getAttribute('data-delay') || i * 30); },
            duration: 500,
            easing: 'easeOutQuad'
        });
    </script>
}