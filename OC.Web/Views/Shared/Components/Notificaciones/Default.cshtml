@model int

@if (Model > 0)
{
    <a asp-controller="SolicitudesCitas" 
       asp-action="Index" 
       class="btn btn-warning btn-sm position-relative me-2">
        <i class="bi bi-bell-fill"></i>
        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
            @Model
        </span>
    </a>
}
