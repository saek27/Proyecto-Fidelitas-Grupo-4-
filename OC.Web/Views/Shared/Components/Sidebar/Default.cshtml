@using OC.Web.ViewComponents.Sidebar
@model List<MenuItem>

<nav id="sidebar">
    <div class="sidebar-header">
        <h3><i class="bi bi-eyeglasses"></i> OC Visión</h3>
        <small class="text-light opacity-50">Sistema Óptica Comunal</small>
    </div>

    <ul class="list-unstyled components">
        @{
            // Separar items normales de los de Mesa de Ayuda
            var helpDeskItems = Model.Where(m => m.IsHelpDeskItem).ToList();
            var regularItems = Model.Where(m => !m.IsHelpDeskItem).ToList();
        }

        @foreach (var item in regularItems)
        {
            <li>
                <a href="@item.Url">
                    <i class="bi @item.Icon me-2"></i> @item.Title
                </a>
            </li>
        }

        @if (helpDeskItems.Any())
        {
            <!-- Separador visual (opcional) -->
            <li class="mt-2" style="border-top: 1px solid rgba(255,255,255,0.2);"></li>

            <!-- Menú desplegable de Mesa de Ayuda -->
            <li class="dropdown">
                <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown" role="button" aria-expanded="false">
                    <i class="bi bi-headset me-2"></i> Mesa de Ayuda
                </a>
                <ul class="dropdown-menu">
                    @foreach (var item in helpDeskItems)
                    {
                        <li>
                            <a class="dropdown-item" href="@item.Url">
                                <i class="bi @item.Icon me-2"></i> @item.Title
                            </a>
                        </li>
                    }
                </ul>
            </li>
        }
    </ul>

    <div class="mt-auto p-3">
        <a asp-controller="Account" asp-action="Logout"
           class="btn btn-danger w-100 btn-sm d-flex align-items-center justify-content-center">
            <i class="bi bi-box-arrow-left me-2"></i> Salir
        </a>
    </div>
</nav>

