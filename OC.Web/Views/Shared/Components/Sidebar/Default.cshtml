@using OC.Web.ViewComponents.Sidebar
@model SidebarViewModel

@{
    var currentUrl = Context.Request.Path.ToString();
}

<ul class="components">
    @foreach (var item in Model.Items)
    {
        var isActive = item.Url == "/"
        ? currentUrl == "/"
        : currentUrl.StartsWith(item.Url, StringComparison.OrdinalIgnoreCase);

        <li class="@(isActive ? "active" : "")">
            <a href="@item.Url">
                <i class="bi @item.Icon"></i>
                @item.Title
            </a>
        </li>
    }

    @if (Model.HelpDeskItems.Any())
    {
        var helpActive = Model.HelpDeskItems.Any(h =>
        currentUrl.StartsWith(h.Url, StringComparison.OrdinalIgnoreCase));

        <li>
            <a class="dropdown-toggle"
               data-bs-toggle="collapse"
               href="#helpDeskMenu"
               role="button"
               aria-expanded="@(helpActive ? "true" : "false")">
                <i class="bi bi-headset"></i>
                Mesa de Ayuda
            </a>
            <div class="collapse @(helpActive ? "show" : "")" id="helpDeskMenu">
                <ul class="list-unstyled" style="padding:4px 0 4px 12px;">
                    @foreach (var h in Model.HelpDeskItems)
                    {
                        var hActive = currentUrl.StartsWith(h.Url, StringComparison.OrdinalIgnoreCase);
                        <li>
                            <a href="@h.Url"
                               style="padding:9px 14px; font-size:13px; display:flex; align-items:center; gap:8px;
                                              color:rgba(255,255,255,.7); text-decoration:none; border-radius:6px;
                                              background:@(hActive ? "rgba(59,130,246,.3)" : "transparent");
                                              transition:all .2s ease;"
                               onmouseover="this.style.background='rgba(255,255,255,.09)';this.style.color='#fff'"
                               onmouseout="this.style.background='@(hActive ? "rgba(59,130,246,.3)" : "transparent")';this.style.color='rgba(255,255,255,.7)'">
                                <i class="bi @h.Icon" style="font-size:14px;width:16px;text-align:center;"></i>
                                @h.Title
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </li>
    }
</ul>