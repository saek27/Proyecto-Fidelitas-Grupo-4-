@using OC.Web.Models
@model PaginationInfo

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center mt-4">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="@Model.PreviousPageUrl">
                    <i class="bi bi-chevron-left"></i> Anterior
                </a>
            </li>

            @{
                int start = Math.Max(1, Model.CurrentPage - 2);
                int end = Math.Min(Model.TotalPages, start + 4);
                if (end - start < 4 && start > 1) start = Math.Max(1, end - 4);
            }

            @if (start > 1)
            {
                <li class="page-item"><a class="page-link" href="@Model.GetPageUrl(1)">1</a></li>
                @if (start > 2)
                {
                    <li class="page-item disabled"><span class="page-link">...</span></li>
                }
            }

            @for (int i = start; i <= end; i++)
            {
                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                    <a class="page-link" href="@Model.GetPageUrl(i)">@i</a>
                </li>
            }

            @if (end < Model.TotalPages)
            {
                @if (end < Model.TotalPages - 1)
                {
                    <li class="page-item disabled"><span class="page-link">...</span></li>
                }
                <li class="page-item"><a class="page-link" href="@Model.GetPageUrl(Model.TotalPages)">@Model.TotalPages</a></li>
            }

            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="@Model.NextPageUrl">
                    Siguiente <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}