<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@ViewData["Title"] - Óptica Comunal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg fixed-top navbar-dark glass-nav">
            <div class="container">
                <a class="navbar-brand" href="/landing">
                    <img src="/uploads/productos/logo.png" alt="Óptica Comunal" height="45" />
                </a>
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" href="/landing">Inicio</a></li>
                        <li class="nav-item"><a class="nav-link" href="/landing/catalogo">Lentes</a></li>
                        <li class="nav-item"><a class="nav-link" href="/landing/sucursales">Sucursales</a></li>
                        <li class="nav-item"><a class="nav-link" href="/landing/tecnologias">Tecnologías</a></li>
                        <li class="nav-item"><a class="nav-link" href="/landing/contacto">Contacto</a></li>
                    </ul>
                    <div class="d-flex align-items-center">
                        @if (User.Identity.IsAuthenticated && User.IsInRole("Paciente"))
                        {
                            <div class="dropdown">
                                <button class="btn btn-outline-premium dropdown-toggle me-3" type="button" id="cuentaDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i> Mi Cuenta
                                </button>
                                <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end shadow" aria-labelledby="cuentaDropdown">
                                    <li><a class="dropdown-item" href="/landing/mis-citas"><i class="bi bi-calendar-event me-2"></i>Mis Citas</a></li>
                                    <li><a class="dropdown-item" href="/landing/estado-orden"><i class="bi bi-eyeglasses me-2"></i>Estado de Orden</a></li>
                                    <li><a class="dropdown-item" href="/landing/mis-facturas"><i class="bi bi-receipt me-2"></i>Mis Facturas</a></li>
                                    <li><a class="dropdown-item" href="/landing/notificaciones"><i class="bi bi-bell me-2"></i>Notificaciones</a></li>
                                    <li><hr class="dropdown-divider border-secondary"></li>
                                    <li><a class="dropdown-item text-danger" href="/Account/Logout"><i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión</a></li>
                                </ul>
                            </div>
                            <a href="/landing/carrito" class="btn btn-premium d-flex align-items-center gap-2">
                                <i class="bi bi-cart"></i> Carrito
                            </a>
                        }
                        else if (User.Identity.IsAuthenticated)
                        {
                            <a href="/Home/Index" class="btn btn-premium">Ir al Panel</a>
                        }
                        else
                        {
                            <a href="/Account/Login" class="btn btn-outline-premium me-3">Iniciar Sesión</a>
                            <a href="/Pacientes/Registro" class="btn btn-premium">Registrarse</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3 pt-5 mt-4">
        @RenderBody()
    </main>

    <footer class="footer pt-5 pb-3">
        <div class="container text-white">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5 class="text-white fw-bold mb-3">Óptica Comunal</h5>
                    <p>Tu salud visual es nuestra prioridad, combinando artesanía clínica con tecnología de precisión.</p>
                    <p class="mb-1"><i class="bi bi-geo-alt me-2 text-primary"></i> San José, Costa Rica</p>
                    <p class="mb-1"><i class="bi bi-telephone me-2 text-primary"></i> +506 2221-1187</p>
                    <p><i class="bi bi-envelope me-2 text-primary"></i> lentesyprocesos@hotmail.com</p>
                </div>
                <div class="col-md-4 mb-4">
                    <h5 class="text-white fw-bold mb-3">Horarios</h5>
                    <p class="mb-1"><i class="bi bi-clock me-2"></i> Lunes a Viernes: 8:00 - 18:00</p>
                    <p class="mb-1"><i class="bi bi-clock me-2"></i> Sábados: 9:00 - 14:00</p>
                    <p><i class="bi bi-clock me-2"></i> Domingos: Cerrado</p>
                </div>
                <div class="col-md-4 mb-4">
                    <h5 class="text-white fw-bold mb-3">Síguenos</h5>
                    <div class="d-flex gap-3">
                        <a href="https://www.facebook.com/opticacomunalsj" target="_blank" class="text-white fs-4 transition"><i class="bi bi-facebook hover-primary"></i></a>
                        <a href="https://www.instagram.com/optica.comunal/" target="_blank" class="text-white fs-4"><i class="bi bi-instagram hover-primary"></i></a>
                        <a href="https://wa.me/50686970611" target="_blank" class="text-white fs-4"><i class="bi bi-whatsapp hover-primary"></i></a>
                    </div>
                </div>
            </div>
            <hr class="border-secondary mt-4 mb-4" />
            <p class="text-center mb-0 small">&copy; @DateTime.Now.Year - Óptica Comunal | Todos los derechos reservados</p>
        </div>
    </footer>

    <a href="https://wa.me/50686970611" class="btn-whatsapp shadow-lg" target="_blank" style="position:fixed; bottom:30px; right:30px; background:#25D366; color:white; border-radius:50%; width:60px; height:60px; display:flex; align-items:center; justify-content:center; font-size:28px; z-index:1000; transition: transform 0.3s;">
        <i class="bi bi-whatsapp"></i>
    </a>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/landing.js" asp-append-version="true"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    }
                });
            }, { threshold: 0.1 });

            document.querySelectorAll('.animate-on-scroll').forEach((el) => {
                observer.observe(el);
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>