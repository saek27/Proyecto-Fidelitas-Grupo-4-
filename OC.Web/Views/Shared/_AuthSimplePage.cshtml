@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Óptica Comunal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(160deg, #0f172a 0%, #1e3a8a 55%, #1e40af 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', 'Segoe UI', sans-serif;
            padding: 24px;
        }
        .auth-card {
            width: 100%;
            max-width: 480px;
            background: rgba(255,255,255,.06);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,.13);
            border-radius: 24px;
            padding: 36px 32px;
            box-shadow: 0 24px 64px rgba(0,0,0,.35);
            color: #fff;
        }
        .auth-card .form-label { color: rgba(255,255,255,.75); font-size: 12px; font-weight: 600; text-transform: uppercase; }
        .auth-card .form-control {
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.15);
            color: #fff;
            border-radius: 12px;
        }
        .auth-card .form-control:focus {
            background: rgba(255,255,255,.12);
            border-color: rgba(59,130,246,.8);
            color: #fff;
            box-shadow: 0 0 0 3px rgba(59,130,246,.2);
        }
        .auth-card .text-muted { color: rgba(255,255,255,.55) !important; }
        .auth-card .alert-danger { background: rgba(239,68,68,.15); border-color: rgba(239,68,68,.3); color: #fca5a5; }
        .auth-card .alert-info { background: rgba(59,130,246,.15); border-color: rgba(59,130,246,.3); color: #bfdbfe; }
        .auth-card code { color: #93c5fd; }
    </style>
</head>
<body>
    <div class="auth-card">
        @RenderBody()
    </div>
    @RenderSection("Scripts", required: false)
</body>
</html>
