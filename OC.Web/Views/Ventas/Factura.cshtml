@model OC.Web.ViewModels.FacturaViewModel
@{
    Layout = null; @* Sin sidebar ni navbar — es un documento *@
    var venta = Model.Venta;
    var vc    = Model.ValorClinico;
    var volverUrl = User.IsInRole("Paciente") ? "/landing" : "/Ventas";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Factura @venta.NumeroFactura</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            font-size: 13px;
            color: #1a1a1a;
            background: #f0f0f0;
        }

        .page {
            width: 210mm;
            min-height: 297mm;
            margin: 20px auto;
            background: #fff;
            padding: 14mm 14mm 12mm;
            box-shadow: 0 4px 24px rgba(0,0,0,.15);
        }

        @* ── Encabezado ─────────────────────────────────────────── *@
        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding-bottom: 12px;
            border-bottom: 3px solid #1a3c6e;
            margin-bottom: 18px;
        }

        .logo-area h1 {
            font-size: 22px;
            font-weight: 700;
            color: #1a3c6e;
            letter-spacing: -.5px;
        }

        .logo-area p {
            font-size: 11px;
            color: #666;
            margin-top: 2px;
        }

        .factura-id {
            text-align: right;
        }

        .factura-id .numero {
            font-size: 18px;
            font-weight: 700;
            color: #1a3c6e;
        }

        .factura-id .fecha {
            font-size: 11px;
            color: #666;
            margin-top: 2px;
        }

        @* ── Partes involucradas ─────────────────────────────────── *@
        .partes {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }

        .parte {
            flex: 1;
            background: #f8f9fc;
            border-left: 3px solid #1a3c6e;
            padding: 10px 12px;
            border-radius: 0 4px 4px 0;
        }

        .parte h3 {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .8px;
            color: #1a3c6e;
            margin-bottom: 6px;
        }

        .parte p {
            font-size: 12px;
            line-height: 1.6;
            color: #333;
        }

        .metodo-pago {
            display: inline-block;
            margin-top: 6px;
            padding: 2px 10px;
            background: #1a3c6e;
            color: #fff;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        @* ── Tabla de productos ──────────────────────────────────── *@
        .tabla-titulo {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .8px;
            color: #1a3c6e;
            margin-bottom: 6px;
        }

        table.detalle {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 4px;
        }

        table.detalle thead th {
            background: #1a3c6e;
            color: #fff;
            font-size: 11px;
            font-weight: 600;
            padding: 7px 10px;
            text-align: left;
        }

        table.detalle thead th.right { text-align: right; }

        table.detalle tbody tr:nth-child(even) { background: #f4f6fb; }

        table.detalle tbody td {
            padding: 7px 10px;
            font-size: 12px;
            border-bottom: 1px solid #e8eaf0;
            vertical-align: middle;
        }

        table.detalle tbody td.right { text-align: right; font-variant-numeric: tabular-nums; }

        .badge-lente {
            display: inline-block;
            padding: 1px 6px;
            background: #e8eef8;
            color: #1a3c6e;
            border-radius: 3px;
            font-size: 10px;
            font-weight: 600;
            margin-right: 4px;
        }

        @* ── Total ──────────────────────────────────────────────── *@
        .total-box {
            display: flex;
            justify-content: flex-end;
            margin-top: 8px;
            margin-bottom: 20px;
        }

        .total-inner {
            border-top: 2px solid #1a3c6e;
            padding-top: 8px;
            min-width: 220px;
            text-align: right;
        }

        .total-inner .label {
            font-size: 11px;
            color: #666;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .total-inner .monto {
            font-size: 22px;
            font-weight: 700;
            color: #1a3c6e;
        }

        @* ── Receta ─────────────────────────────────────────────── *@
        .receta-box {
            border: 1px solid #c8d4e8;
            border-radius: 6px;
            padding: 12px 14px;
            margin-bottom: 20px;
            background: #f8f9fc;
        }

        .receta-box h3 {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .8px;
            color: #1a3c6e;
            margin-bottom: 8px;
        }

        table.receta {
            border-collapse: collapse;
            font-size: 12px;
        }

        table.receta th, table.receta td {
            border: 1px solid #d0d8ea;
            padding: 5px 12px;
            text-align: center;
        }

        table.receta th {
            background: #e8eef8;
            font-weight: 600;
            color: #1a3c6e;
        }

        table.receta td:first-child { font-weight: 700; background: #f4f6fb; }

        .diagnostico { font-size: 11px; color: #555; margin-top: 6px; }

        @* ── Notas ──────────────────────────────────────────────── *@
        .notas {
            font-size: 11px;
            color: #555;
            padding: 8px 12px;
            background: #fffbeb;
            border-left: 3px solid #f0b429;
            border-radius: 0 4px 4px 0;
            margin-bottom: 20px;
        }

        @* ── Pie de página ───────────────────────────────────────── *@
        .footer {
            border-top: 1px solid #dde1ea;
            padding-top: 10px;
            text-align: center;
            font-size: 10px;
            color: #999;
            margin-top: auto;
        }

        @* ── Botones (solo en pantalla) ──────────────────────────── *@
        .acciones {
            width: 210mm;
            margin: 0 auto 12px;
            display: flex;
            justify-content: space-between;
        }

        .btn-accion {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 20px;
            border-radius: 5px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            text-decoration: none;
        }

        .btn-volver  { background: #e9ecef; color: #333; }
        .btn-print   { background: #1a3c6e; color: #fff; }

        @@media print {
            body { background: white; }
            .acciones { display: none; }
            .page { box-shadow: none; margin: 0; padding: 10mm; width: 100%; min-height: auto; }
        }
    </style>
</head>
<body>

    <div class="acciones">
        <a href="@volverUrl" class="btn-accion btn-volver">← Volver</a>
        <button onclick="window.print()" class="btn-accion btn-print">🖨 Imprimir / Guardar PDF</button>
    </div>

    <div class="page">

        @* ── Encabezado ──────────────────────────────────────────────────── *@
        <div class="header">
            <div class="logo-area">
                <h1>Óptica Comunal</h1>
                <p>Comprobante interno de venta</p>
            </div>
            <div class="factura-id">
                <div class="numero">@venta.NumeroFactura</div>
                <div class="fecha">@venta.FechaVenta.ToString("dd 'de' MMMM, yyyy — HH:mm", new System.Globalization.CultureInfo("es-CR"))</div>
            </div>
        </div>

        @* ── Partes ───────────────────────────────────────────────────────── *@
        <div class="partes">
            <div class="parte">
                <h3>Cliente</h3>
                <p>
                    <strong>@venta.Paciente?.NombreCompleto</strong><br />
                    Cédula: @venta.Paciente?.Cedula<br />
                    @if (!string.IsNullOrEmpty(venta.Paciente?.Email))
                    {
                        @venta.Paciente.Email
                    }
                </p>
            </div>
            <div class="parte">
                <h3>Emisor</h3>
                <p>
                    <strong>Óptica Comunal</strong><br />
                    Atendido por: @venta.Usuario?.Nombre
                </p>
                
            </div>
        </div>

        @* ── Productos ────────────────────────────────────────────────────── *@
        <p class="tabla-titulo">Detalle de la venta</p>
        <table class="detalle">
            <thead>
                <tr>
                    <th>Descripción</th>
                    <th style="width:70px; text-align:center;">Cant.</th>
                    <th style="width:130px;" class="right">Precio unit.</th>
                    <th style="width:130px;" class="right">Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in venta.Detalles)
                {
                    <tr>
                        <td>
                            @if (d.ProductoId == null)
                            {
                                <span class="badge-lente">LENTE</span>
                            }
                            @d.DescripcionSnapshot
                        </td>
                        <td style="text-align:center;">@d.Cantidad</td>
                        <td class="right">₡ @d.PrecioUnitario.ToString("N2")</td>
                        <td class="right">₡ @d.Subtotal.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>

        @* ── Total (subtotal + IVA 13 % Costa Rica) ─────────────────────── *@
        @{
            var subGravado = (venta.Detalles ?? Enumerable.Empty<OC.Core.Domain.Entities.DetalleVenta>()).Sum(d => d.Subtotal);
            var ivaDoc = Math.Max(0m, venta.Total - subGravado);
        }
                <div class="total-box p-3 rounded shadow-sm bg-light">
                    <div class="small text-muted mb-2">Desglose de impuesto (referencia)</div>
                    <div class="d-flex justify-content-between small mb-1">
                        <span>Subtotal gravado</span>
                        <span>₡ @subGravado.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between small mb-2">
                        <span>IVA 13%</span>
                        <span>₡ @ivaDoc.ToString("N2")</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">

                        <div>
                            <div class="text-muted small">Total a pagar</div>
                            <div class="fw-bold fs-3 text-success">
                                ₡ @venta.Total.ToString("N2")
                            </div>
                        </div>

                        <span class="badge bg-secondary fs-6">
                            @(venta.MetodoPago switch {
                                OC.Core.Domain.Enums.MetodoPago.Efectivo => "💵 Efectivo",
                                OC.Core.Domain.Enums.MetodoPago.SINPE    => "📱 SINPE Móvil",
                                OC.Core.Domain.Enums.MetodoPago.Tarjeta  => "💳 Tarjeta",
                                _ => venta.MetodoPago.ToString()
                            })
                        </span>

                    </div>

                </div>

       

        @* ── Receta óptica (solo si aplica) ──────────────────────────────── *@
        @if (vc != null)
        {
            <div class="receta-box">
                <h3>Receta Óptica Incluida</h3>
                <table class="receta">
                    <thead>
                        <tr>
                            <th></th>
                            <th>Esfera</th>
                            <th>Cilindro</th>
                            <th>Eje</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>OD</td>
                            <td>@vc.EsferaOD</td>
                            <td>@vc.CilindroOD</td>
                            <td>@vc.EjeOD</td>
                        </tr>
                        <tr>
                            <td>OI</td>
                            <td>@vc.EsferaOI</td>
                            <td>@vc.CilindroOI</td>
                            <td>@vc.EjeOI</td>
                        </tr>
                    </tbody>
                </table>
                <p class="diagnostico">
                    Diagnóstico: <strong>@vc.Diagnostico</strong> —
                    Fecha: @vc.FechaRegistro.ToString("dd/MM/yyyy")
                </p>
            </div>
        }

        @* ── Notas ───────────────────────────────────────────────────────── *@
        @if (!string.IsNullOrEmpty(venta.Notas))
        {
            <div class="notas"><strong>Notas:</strong> @venta.Notas</div>
        }

        @* ── Pie ─────────────────────────────────────────────────────────── *@
            <div class="footer">
                Un placer servirle en nuestra sucursal: <strong>@venta.Sucursal?.Nombre</strong><br />
                Documento generado el @DateTime.Now.ToString("dd/MM/yyyy HH:mm") —
                Comprobante interno. Óptica Comunal © @DateTime.Now.Year
            </div>

    </div>
</body>
</html>